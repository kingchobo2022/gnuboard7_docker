{
  "meta": {
    "is_partial": true,
    "description": "알림 발송 이력 상세 모달",
    "editor_label": "$t:admin.modal_label.admin_notification_log_list.modal_notification_log_detail"
  },
  "id": "modal_notification_log_detail",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.notification_log.detail_title",
    "size": "lg"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid-2col"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-tertiary block font-medium mb-1"
                  },
                  "text": "$t:admin.notification_log.col_channel"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary text-sm"
                  },
                  "text": "{{$parent._local.selectedLog?.channel ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-tertiary block font-medium mb-1"
                  },
                  "text": "$t:admin.notification_log.col_status"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "{{($parent._local.selectedLog?.status === 'sent') ? 'text-sm text-green-600 dark:text-green-400 font-medium' : ($parent._local.selectedLog?.status === 'failed') ? 'text-sm text-red-600 dark:text-red-400 font-medium' : 'text-sm text-gray-500 dark:text-gray-400 font-medium'}}"
                  },
                  "text": "{{$parent._local.selectedLog?.status ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-tertiary block font-medium mb-1"
                  },
                  "text": "$t:admin.notification_log.col_type"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary text-sm font-mono"
                  },
                  "text": "{{$parent._local.selectedLog?.notification_type ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-tertiary block font-medium mb-1"
                  },
                  "text": "$t:admin.notification_log.col_sent_at"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary text-sm"
                  },
                  "text": "{{$parent._local.selectedLog?.sent_at ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-tertiary block font-medium mb-1"
                  },
                  "text": "$t:admin.notification_log.col_recipient"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary text-sm"
                  },
                  "text": "{{($parent._local.selectedLog?.recipient_name ?? '') + ' (' + ($parent._local.selectedLog?.recipient_identifier ?? '') + ')'}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-tertiary block font-medium mb-1"
                  },
                  "text": "$t:admin.notification_log.col_extension"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary text-sm"
                  },
                  "text": "{{$parent._local.selectedLog?.extension_identifier ?? ''}}"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{$parent._local.selectedLog?.subject}}",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "text-tertiary block font-medium mb-1"
              },
              "text": "$t:admin.notification_log.col_subject"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-primary text-sm"
              },
              "text": "{{$parent._local.selectedLog?.subject ?? ''}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{$parent._local.selectedLog?.body}}",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "text-tertiary block font-medium mb-1"
              },
              "text": "$t:admin.notification_log.detail_body"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-body bg-gray-50 dark:bg-gray-900/50 rounded-lg p-3 max-h-64 overflow-y-auto",
                "dangerouslySetInnerHTML": "{{$parent._local.selectedLog?.body ?? ''}}"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{$parent._local.selectedLog?.error_message}}",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-error-xs block font-medium mb-1"
              },
              "text": "$t:admin.notification_log.detail_error"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-error-soft bg-red-50 dark:bg-red-900/20 rounded-lg p-3"
              },
              "text": "{{$parent._local.selectedLog?.error_message ?? ''}}"
            }
          ]
        }
      ],
      "props": {
      }
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end pt-4 border-t border-gray-200 dark:border-gray-700 mt-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 text-body font-medium bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700"
          },
          "text": "$t:common.close",
          "actions": [
            {
              "type": "click",
              "handler": "closeModal",
              "target": "modal_notification_log_detail"
            }
          ]
        }
      ]
    }
  ]
}
