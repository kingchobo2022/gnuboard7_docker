{
    "meta": {
        "is_partial": true,
        "description": "Identity Logs Purge Confirm Modal",
        "editor_label": "$t:admin.modal_label.admin_identity_logs.identity_log_purge_confirm_modal"
    },
    "id": "identity_log_purge_confirm_modal",
    "type": "composite",
    "name": "Modal",
    "props": {
        "title": "$t:admin.identity.logs.purge_button",
        "size": "sm"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": {
                "className": "py-2"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "P",
                    "props": {
                        "className": "text-gray-700 dark:text-gray-300"
                    },
                    "text": "$t:admin.identity.logs.purge_confirm"
                }
            ]
        },
        {
            "type": "basic",
            "name": "Div",
            "props": {
                "className": "modal-footer-buttons"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "className": "btn btn-secondary",
                        "disabled": "{{_global.isPurgingIdentityLogs}}"
                    },
                    "actions": [
                        {
                            "type": "click",
                            "handler": "closeModal",
                            "target": "identity_log_purge_confirm_modal"
                        }
                    ],
                    "children": [
                        {
                            "type": "basic",
                            "name": "Span",
                            "text": "$t:common.cancel"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "className": "flex-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
                        "disabled": "{{_global.isPurgingIdentityLogs}}"
                    },
                    "actions": [
                        {
                            "type": "click",
                            "handler": "sequence",
                            "params": {
                                "actions": [
                                    {
                                        "handler": "setState",
                                        "params": {
                                            "target": "global",
                                            "isPurgingIdentityLogs": true
                                        }
                                    },
                                    {
                                        "handler": "apiCall",
                                        "auth_required": true,
                                        "target": "/api/admin/identity/logs/purge",
                                        "params": {
                                            "method": "POST",
                                            "body": {
                                                "older_than_days": 180
                                            }
                                        },
                                        "onSuccess": [
                                            {
                                                "handler": "setState",
                                                "params": {
                                                    "target": "global",
                                                    "isPurgingIdentityLogs": false
                                                }
                                            },
                                            {
                                                "handler": "refetchDataSource",
                                                "params": {
                                                    "dataSourceId": "identityLogs"
                                                }
                                            },
                                            {
                                                "handler": "toast",
                                                "params": {
                                                    "message": "$t:admin.identity.logs.purge_success",
                                                    "type": "success"
                                                }
                                            },
                                            {
                                                "handler": "closeModal",
                                                "target": "identity_log_purge_confirm_modal"
                                            }
                                        ],
                                        "onError": [
                                            {
                                                "handler": "setState",
                                                "params": {
                                                    "target": "global",
                                                    "isPurgingIdentityLogs": false
                                                }
                                            },
                                            {
                                                "handler": "toast",
                                                "params": {
                                                    "type": "error",
                                                    "message": "{{error.message}}"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        }
                    ],
                    "children": [
                        {
                            "type": "basic",
                            "name": "Icon",
                            "if": "{{_global.isPurgingIdentityLogs}}",
                            "props": {
                                "name": "fa-solid fa-spinner",
                                "className": "spinner-sm"
                            }
                        },
                        {
                            "type": "basic",
                            "name": "Span",
                            "text": "$t:admin.identity.logs.purge_button"
                        }
                    ]
                }
            ]
        }
    ]
}
