                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-heading"
                      },
                      "text": "{{systemInfo?.data?.php_version ?? '-'}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-between"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "$t:admin.settings.info.mysql_version"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-heading"
                      },
                      "text": "{{systemInfo?.data?.mysql_version ?? '-'}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-between"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "$t:admin.settings.info.g7_version"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-heading"
                          },
                          "text": "{{systemInfo?.data?.g7_version ?? '-'}}"
                        },
                        {
                          "type": "composite",
                          "name": "StatusBadge",
                          "if": "{{_local.coreUpdateInfo?.update_available}}",
                          "props": {
                            "status": "success",
                            "label": "{{_local.coreUpdateInfo?.latest_version ?? ''}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors disabled:opacity-50",
                            "disabled": "{{_local.checkingCoreUpdate}}"
                          },
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "checkingCoreUpdate": true
                                  }
                                },
                                {
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "/api/admin/core-update/check",
                                  "params": {
                                    "method": "POST"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "checkingCoreUpdate": false,
                                        "coreUpdateInfo": "{{result.data}}"
                                      }
                                    },
                                    {
                                      "handler": "openModal",
                                      "target": "core_update_result_modal"
                                    }
                                  ],
                                  "onError": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "checkingCoreUpdate": false,
                                        "coreUpdateError": "{{error.errors?.reason ?? ''}}"
                                      }
                                    },
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "type": "error",
                                        "message": "{{error.errors?.reason ?? $t('admin.settings.info.update_check_failed')}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{_local.checkingCoreUpdate}}",
                              "props": {
                                "name": "spinner",
                                "className": "w-3 h-3 animate-spin"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{!_local.checkingCoreUpdate}}",
                              "text": "$t:admin.settings.info.check_update"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors disabled:opacity-50",
                            "disabled": "{{_local.loadingChangelog}}"
                          },
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "loadingChangelog": true
                                  }
                                },
                                {
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "/api/admin/core-update/changelog",
                                  "params": {
                                    "method": "GET"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "loadingChangelog": false,
                                        "coreChangelog": "{{result.data.changelog ?? []}}"
                                      }
                                    },
                                    {
                                      "handler": "openModal",
                                      "target": "core_changelog_modal"
                                    }
                                  ],
                                  "onError": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "loadingChangelog": false
                                      }
                                    },
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "type": "error",
                                        "message": "$t:admin.settings.info.changelog_load_failed"
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{_local.loadingChangelog}}",
                              "props": {
                                "name": "spinner",
                                "className": "w-3 h-3 animate-spin"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{!_local.loadingChangelog}}",
                              "text": "$t:admin.settings.info.view_changelog"
                            }
                          ]
                        }
