{
  "meta": {
    "is_partial": true,
    "description": "환경설정 정보 탭 콘텐츠"
  },
  "id": "tab_content_info",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab) === 'info'}}",
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "grid-2col-responsive"
      },
      "children": [
        {
