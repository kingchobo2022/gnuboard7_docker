{
  "meta": {
    "is_partial": true,
    "description": "IDV 메시지 정의 기본값 복원 확인 모달 (스피너 포함) — 알림 reset 모달 미러",
    "editor_label": "$t:admin.modal_label.admin_settings.modal_identity_message_definition_reset"
  },
  "id": "modal_identity_message_definition_reset",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.settings.identity.messages.reset_modal.title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-gray-700 dark:text-gray-300"
      },
      "text": "$t:admin.settings.identity.messages.reset_modal.confirm_message"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mt-4 p-3 bg-gray-100 dark:bg-gray-700 rounded-lg"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "form-sub-label"
          },
          "text": "$t:admin.settings.identity.messages.reset_modal.target_label"
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-primary font-medium"
          },
          "text": "{{_global.resetIdentityMessageTargetName ?? ''}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "alert-danger"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-error-soft"
          },
          "text": "$t:admin.settings.identity.messages.reset_modal.warning_message"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "btn btn-secondary",
            "disabled": "{{_global.isResettingIdentityMessage}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal",
              "target": "modal_identity_message_definition_reset"
            }
          ],
          "text": "$t:common.cancel"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isResettingIdentityMessage}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "params": {
                "actions": [
                  {
                    "handler": "setState",
                    "params": {
                      "target": "global",
                      "isResettingIdentityMessage": true
                    }
                  },
                  {
                    "handler": "apiCall",
                    "auth_required": true,
                    "target": "/api/admin/identity/messages/definitions/{{_global.resetIdentityMessageTargetId}}/reset",
                    "params": {
                      "method": "POST"
                    },
                    "onSuccess": [
                      {
                        "handler": "setState",
                        "params": {
                          "target": "global",
                          "isResettingIdentityMessage": false,
                          "resetIdentityMessageTargetId": null,
                          "resetIdentityMessageTargetName": ""
                        }
                      },
                      {
                        "handler": "refetchDataSource",
                        "params": {
                          "dataSourceId": "identityMessages"
                        }
                      },
                      {
                        "handler": "toast",
                        "params": {
                          "type": "success",
                          "message": "$t:admin.settings.identity.messages.reset_modal.reset_success"
                        }
                      },
                      {
                        "handler": "closeModal",
                        "target": "modal_identity_message_definition_reset"
                      }
                    ],
                    "onError": [
                      {
                        "handler": "setState",
                        "params": {
                          "target": "global",
                          "isResettingIdentityMessage": false
                        }
                      },
                      {
                        "handler": "toast",
                        "params": {
                          "type": "error",
                          "message": "{{error.message ?? '$t:admin.settings.identity.messages.reset_modal.reset_failed'}}"
                        }
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isResettingIdentityMessage}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isResettingIdentityMessage ? '$t:admin.settings.identity.messages.reset_modal.btn_confirming' : '$t:admin.settings.identity.messages.reset_modal.btn_confirm'}}"
            }
          ]
        }
      ]
    }
  ]
}
