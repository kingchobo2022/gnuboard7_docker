              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-heading block"
                  },
                  "text": "$t:admin.settings.seo.sitemap_last_updated_at"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-col gap-2 md:flex-row md:items-center md:"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "disabled": true,
                        "value": "{{_local.form?.seo?.sitemap_last_updated_at ?? '-'}}",
                        "className": "md:flex-1 dark:bg-gray-900 text-gray-700 dark:text-gray-300"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "disabled": "{{_computed.isReadOnly || _local.sitemapUpdating === true}}",
                        "className": "w-full md:w-auto px-4 py-2 bg-blue-600 hover:bg-blue-700 disabled:bg-gray-400 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap"
                      },
                      "text": "{{_local.sitemapUpdating === true ? $t('admin.settings.seo.sitemap_updating') : $t('admin.settings.seo.sitemap_manual_update')}}",
                      "actions": [
                        {
                          "type": "click",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "sitemapUpdating": true
                          },
                          "onSuccess": [
                            {
                              "handler": "apiCall",
                              "auth_required": true,
                              "target": "/api/admin/seo/sitemap/regenerate",
                              "params": {
                                "method": "POST"
                              },
                              "onSuccess": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "sitemapUpdating": false,
                                    "form": {
                                      "seo": {
                                        "sitemap_last_updated_at": "{{response.data?.last_updated_at ?? ''}}"
                                      }
                                    }
                                  }
                                },
                                {
                                  "handler": "toast",
                                  "params": {
                                    "type": "success",
                                    "message": "{{$t('admin.settings.seo.sitemap_update_success')}}"
                                  }
                                }
                              ],
                              "onError": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "sitemapUpdating": false
                                  }
                                },
                                {
                                  "handler": "toast",
                                  "params": {
                                    "type": "error",
                                    "message": "{{error.message ?? $t('admin.settings.seo.sitemap_update_failed')}}"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "props": {
  }
}
