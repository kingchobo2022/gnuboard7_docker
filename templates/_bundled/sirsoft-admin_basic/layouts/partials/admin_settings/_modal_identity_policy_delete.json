{
    "meta": {
        "is_partial": true,
        "description": "본인인증 정책 삭제 확인 모달",
        "editor_label": "$t:admin.modal_label.admin_settings.identity_policy_delete_modal"
    },
    "id": "identity_policy_delete_modal",
    "type": "composite",
    "name": "Modal",
    "props": {
        "title": "$t:admin.identity.policies.delete_title",
        "size": "sm"
    },
    "children": [
        {
            "type": "basic",
            "name": "P",
            "props": {
                "className": "text-gray-700 dark:text-gray-300"
            },
            "text": "$t:admin.identity.policies.delete_confirm"
        },
        {
            "type": "basic",
            "name": "Div",
            "props": {
                "className": "modal-footer-buttons"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "className": "btn btn-secondary",
                        "disabled": "{{_global.identityPolicyDeleting}}"
                    },
                    "actions": [
                        {
                            "type": "click",
                            "handler": "closeModal",
                            "target": "identity_policy_delete_modal"
                        }
                    ],
                    "text": "$t:common.cancel"
                },
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "className": "flex-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
                        "disabled": "{{_global.identityPolicyDeleting}}"
                    },
                    "actions": [
                        {
                            "type": "click",
                            "handler": "sequence",
                            "actions": [
                                {
                                    "handler": "setState",
                                    "params": {
                                        "target": "global",
                                        "identityPolicyDeleting": true
                                    }
                                },
                                {
                                    "handler": "apiCall",
                                    "auth_required": true,
                                    "target": "/api/admin/identity/policies/{{_global.identityPolicyDeleteId}}",
                                    "params": {
                                        "method": "DELETE"
                                    },
                                    "onSuccess": [
                                        {
                                            "handler": "setState",
                                            "params": {
                                                "target": "global",
                                                "identityPolicyDeleting": false,
                                                "identityPolicyDeleteId": null
                                            }
                                        },
                                        {
                                            "handler": "toast",
                                            "params": {
                                                "type": "success",
                                                "message": "$t:admin.identity.policies.delete_success"
                                            }
                                        },
                                        {
                                            "handler": "refetchDataSource",
                                            "params": {
                                                "dataSourceId": "policies"
                                            }
                                        },
                                        {
                                            "handler": "closeModal",
                                            "target": "identity_policy_delete_modal"
                                        }
                                    ],
                                    "onError": [
                                        {
                                            "handler": "setState",
                                            "params": {
                                                "target": "global",
                                                "identityPolicyDeleting": false
                                            }
                                        },
                                        {
                                            "handler": "toast",
                                            "params": {
                                                "type": "error",
                                                "message": "{{error.message ?? '$t:admin.identity.policies.delete_failed'}}"
                                            }
                                        }
                                    ]
                                }
                            ]
                        }
                    ],
                    "children": [
                        {
                            "type": "basic",
                            "name": "Icon",
                            "if": "{{_global.identityPolicyDeleting}}",
                            "props": {
                                "name": "spinner",
                                "className": "spinner-sm"
                            }
                        },
                        {
                            "type": "basic",
                            "name": "Span",
                            "text": "{{_global.identityPolicyDeleting ? '$t:common.deleting' : '$t:common.delete'}}"
                        }
                    ]
                }
            ]
        }
    ]
}
