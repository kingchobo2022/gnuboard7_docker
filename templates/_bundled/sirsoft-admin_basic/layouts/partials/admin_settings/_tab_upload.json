{
  "meta": {
    "is_partial": true,
    "description": "환경설정 업로드 탭 콘텐츠"
  },
  "id": "tab_content_upload",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab || 'general') === 'upload'}}",
  "children": [
    {
      "id": "card_upload_settings",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:admin.settings.upload.file_settings"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:admin.settings.upload.file_settings_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid-2col-responsive"
              },
              "children": [
                {
                  "id": "field_max_file_size",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:admin.settings.upload.max_file_size"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-1"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "upload.max_file_size",
                            "min": "1",
                            "max": "1024",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "input flex-1 {{_local.errors?.['upload.max_file_size'] ? 'input-error' : ''}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-label-subtle"
                          },
                          "text": "MB"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['upload.max_file_size']}}",
                      "props": {
                        "className": "form-error"
                      },
                      "text": "{{_local.errors?.['upload.max_file_size']?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "id": "field_allowed_extensions",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:admin.settings.upload.allowed_extensions"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-1"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "name": "upload.allowed_extensions",
                        "placeholder": "jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,zip",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "input {{_local.errors?.['upload.allowed_extensions'] ? 'input-error' : ''}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "form-hint"
                      },
                      "text": "$t:admin.settings.upload.allowed_extensions_hint"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['upload.allowed_extensions']}}",
                      "props": {
                        "className": "form-error"
                      },
                      "text": "{{_local.errors?.['upload.allowed_extensions']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_image_settings",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:admin.settings.upload.image_settings"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:admin.settings.upload.image_settings_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-3 gap-4"
          },
          "children": [
            {
              "id": "field_image_max_width",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:admin.settings.upload.image_max_width"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.image_max_width",
                        "min": "100",
                        "max": "10000",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "input flex-1"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "px"
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_image_max_height",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:admin.settings.upload.image_max_height"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.image_max_height",
                        "min": "100",
                        "max": "10000",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "input flex-1"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "px"
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_image_quality",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:admin.settings.upload.image_quality"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.image_quality",
                        "min": "1",
                        "max": "100",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "input flex-1"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "%"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:admin.settings.upload.image_quality_hint"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "props": {
  }
}
