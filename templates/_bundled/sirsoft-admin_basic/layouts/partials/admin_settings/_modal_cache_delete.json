{
  "meta": {
    "editor_label": "$t:admin.modal_label.admin_settings.settings_cache_delete_modal",
    "is_partial": true,
    "description": "캐시 삭제 확인 모달"
  },
  "id": "settings_cache_delete_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.settings.modals.cache_delete_title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-gray-700 dark:text-gray-300"
          },
          "text": "$t:admin.settings.modals.cache_delete_confirm"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-2 text-label-subtle"
          },
          "text": "$t:admin.settings.modals.cache_delete_warning"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "btn btn-secondary",
            "disabled": "{{_global.isDeletingCache}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isDeletingCache}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isDeletingCache": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/settings/clear-cache",
                  "params": {
                    "method": "POST"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isDeletingCache": false
                      }
                    },
                    {
                      "handler": "closeModal"
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.settings.cache_cleared"
                      }
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isDeletingCache": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isDeletingCache}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isDeletingCache ? '$t:admin.settings.modals.deleting' : '$t:admin.settings.modals.delete_cache'}}"
            }
          ]
        }
      ]
    }
  ]
}
