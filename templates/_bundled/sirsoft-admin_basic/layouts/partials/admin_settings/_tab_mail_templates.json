{
  "meta": {
    "is_partial": true,
    "description": "환경설정 메일 템플릿 탭 콘텐츠"
  },
  "id": "tab_content_mail_templates",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab || 'general') === 'mail_templates'}}",
  "children": [
    {
      "id": "mail_templates_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-between"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "text": "$t:admin.settings.mail_templates.title"
            },
            {
              "type": "basic",
              "name": "P",
              "text": "$t:admin.settings.mail_templates.description"
            }
          ],
          "props": {
            "className": "section-header"
          }
        }
      ]
    },
    {
      "id": "mail_templates_search",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "composite",
              "name": "Select",
              "props": {
                "name": "mailTemplateSearchType",
                "className": "w-32 px-3 py-2 bg-gray-100 dark:bg-gray-700 border-0 rounded-lg text-body font-medium focus:ring-2 focus:ring-indigo-500",
                "value": "{{_local.mailTemplateFilter?.searchType || 'all'}}",
                "options": [
                  {
                    "value": "all",
                    "label": "$t:admin.settings.mail_templates.search_type_all"
                  },
                  {
                    "value": "subject",
                    "label": "$t:admin.settings.mail_templates.search_type_subject"
                  },
                  {
                    "value": "body",
                    "label": "$t:admin.settings.mail_templates.search_type_body"
                  }
                ]
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "mailTemplateFilter.searchType": "{{$event.target.value}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "relative flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "fa-solid fa-search",
                    "className": "absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500 text-sm pointer-events-none"
                  }
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "name": "mailTemplateSearch",
                    "type": "text",
                    "placeholder": "$t:admin.settings.mail_templates.search_placeholder",
                    "className": "input pl-10",
                    "value": "{{_local.mailTemplateFilter?.search || ''}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "mailTemplateFilter.search": "{{$event.target.value}}"
                      }
                    },
                    {
                      "type": "keydown",
                      "key": "Enter",
                      "handler": "navigate",
                      "params": {
                        "path": "/admin/settings",
                        "replace": true,
                        "query": {
                          "tab": "mail_templates",
                          "page": 1,
                          "search": "{{_local.mailTemplateFilter?.search || undefined}}",
                          "search_type": "{{_local.mailTemplateFilter?.searchType !== 'all' ? _local.mailTemplateFilter?.searchType : undefined}}",
                          "per_page": "{{query.per_page || undefined}}"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 transition-colors"
              },
              "text": "$t:admin.settings.mail_templates.btn_search",
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/admin/settings",
                    "replace": true,
                    "query": {
                      "tab": "mail_templates",
                      "page": 1,
                      "search": "{{_local.mailTemplateFilter?.search || undefined}}",
                      "search_type": "{{_local.mailTemplateFilter?.searchType !== 'all' ? _local.mailTemplateFilter?.searchType : undefined}}",
                      "per_page": "{{query.per_page || undefined}}"
                    }
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-body font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
              },
              "text": "$t:admin.settings.mail_templates.btn_reset_filter",
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "mailTemplateFilter": {
                          "search": "",
                          "searchType": "all"
                        }
                      }
                    },
                    {
                      "handler": "navigate",
                      "params": {
                        "path": "/admin/settings",
                        "query": {
                          "tab": "mail_templates"
                        },
                        "replace": true
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "mail_templates_info",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-between"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:admin.settings.mail_templates.total_count|count={{mailTemplates?.data?.pagination?.total ?? 0}}"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-label-subtle"
              },
              "text": "$t:admin.settings.mail_templates.per_page_label"
            },
            {
              "type": "composite",
              "name": "Select",
              "props": {
                "name": "mailTemplatePerPage",
                "className": "w-20 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                "value": "{{String(query.per_page || 20)}}",
                "options": [
                  {
                    "value": "10",
                    "label": "10"
                  },
                  {
                    "value": "20",
                    "label": "20"
                  },
                  {
                    "value": "50",
                    "label": "50"
                  },
                  {
                    "value": "100",
                    "label": "100"
                  }
                ]
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "navigate",
                  "params": {
                    "path": "/admin/settings",
                    "replace": true,
                    "mergeQuery": true,
                    "query": {
                      "per_page": "{{$event.target.value}}",
                      "page": 1
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "mail_templates_list",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "grid grid-cols-1 gap-4"
      },
      "children": [
        {
          "id": "template_card",
          "type": "basic",
          "name": "Div",
          "iteration": {
            "source": "{{mailTemplates?.data?.data ?? []}}",
            "item_var": "tpl",
            "index_var": "tplIdx"
          },
          "props": {
            "className": "admin-card mb-3"
          },
          "children": [
            {
              "id": "btn_expand_{{tplIdx}}",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-shrink-0 pt-0.5"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "p-1.5 rounded-md text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "{{(_local.expandedMailTemplateIds ?? []).includes(tpl.id) ? 'fa-solid fa-chevron-up' : 'fa-solid fa-chevron-down'}}",
                        "className": "text-sm"
                      }
                    }
                  ],
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "expandedMailTemplateIds": "{{(_local.expandedMailTemplateIds ?? []).includes(tpl.id) ? (_local.expandedMailTemplateIds ?? []).filter(id => id !== tpl.id) : [...(_local.expandedMailTemplateIds ?? []), tpl.id]}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1 min-w-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-start justify-between"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1 min-w-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-center gap-2 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "H4",
                              "if": "{{tpl.is_default}}",
                              "props": {
                                "className": "text-primary text-base font-medium"
                              },
                              "text": "$t:admin.settings.mail_templates.types.{{tpl.type}}"
                            },
                            {
                              "type": "basic",
                              "name": "H4",
                              "if": "{{!tpl.is_default}}",
                              "props": {
                                "className": "text-primary text-base font-medium"
                              },
                              "text": "{{tpl.type}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-tertiary font-mono px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 rounded"
                              },
                              "text": "{{tpl.type}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "{{tpl.is_active ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'}} text-xs font-medium px-2 py-0.5 rounded-full"
                              },
                              "text": "{{tpl.is_active ? '$t:admin.settings.mail_templates.active' : '$t:admin.settings.mail_templates.inactive'}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{tpl.is_default}}",
                              "props": {
                                "className": "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300 text-xs font-medium px-2 py-0.5 rounded-full"
                              },
                              "text": "$t:admin.settings.mail_templates.default_badge"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-label-subtle truncate"
                          },
                          "text": "{{tpl.subject?.[$locale] ?? tpl.subject?.ko ?? ''}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-2 ml-4 flex-shrink-0"
                      },
                      "children": [
                        {
                          "id": "btn_toggle_{{tplIdx}}",
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "text-body px-3 py-1.5 rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                          },
                          "text": "{{tpl.is_active ? '$t:admin.settings.mail_templates.btn_deactivate' : '$t:admin.settings.mail_templates.btn_activate'}}",
                          "actions": [
                            {
                              "type": "click",
                              "handler": "apiCall",
                              "auth_required": true,
                              "target": "/api/admin/mail-templates/{{tpl.id}}/toggle-active",
                              "params": {
                                "method": "PATCH"
                              },
                              "onSuccess": [
                                {
                                  "handler": "navigate",
                                  "params": {
                                    "path": "/admin/settings",
                                    "replace": true,
                                    "mergeQuery": true,
                                    "query": {}
                                  }
                                },
                                {
                                  "handler": "toast",
                                  "params": {
                                    "message": "$t:admin.settings.mail_templates.toggle_success",
                                    "type": "success"
                                  }
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "id": "btn_edit_{{tplIdx}}",
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "text-sm px-3 py-1.5 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                          },
                          "text": "$t:admin.settings.mail_templates.btn_edit",
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "editingTemplate": "{{tpl}}",
                                    "editLang": "{{$locale}}",
                                    "templateErrors": null,
                                    "isSaving": false
                                  }
                                },
                                {
                                  "handler": "openModal",
                                  "target": "modal_mail_template_form"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "id": "btn_reset_{{tplIdx}}",
                          "type": "basic",
                          "name": "Button",
                          "if": "{{!tpl.is_default}}",
                          "props": {
                            "type": "button",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "text-sm px-3 py-1.5 rounded-md border border-orange-300 dark:border-orange-600 text-orange-700 dark:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-900/30 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                          },
                          "text": "$t:admin.settings.mail_templates.btn_reset",
                          "actions": [
                            {
                              "type": "click",
                              "handler": "apiCall",
                              "auth_required": true,
                              "target": "/api/admin/mail-templates/{{tpl.id}}/reset",
                              "params": {
                                "method": "POST"
                              },
                              "onSuccess": [
                                {
                                  "handler": "navigate",
                                  "params": {
                                    "path": "/admin/settings",
                                    "replace": true,
                                    "mergeQuery": true,
                                    "query": {}
                                  }
                                },
                                {
                                  "handler": "toast",
                                  "params": {
                                    "message": "$t:admin.settings.mail_templates.reset_success",
                                    "type": "success"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "mt-3 flex flex-wrap gap-1.5"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "iteration": {
                        "source": "{{tpl.variables ?? []}}",
                        "item_var": "variable",
                        "index_var": "varIdx"
                      },
                      "props": {
                        "className": "text-secondary inline-flex items-center text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-700 rounded font-mono"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{{variable.key}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "} - {{variable.description ?? ''}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{(_local.expandedMailTemplateIds ?? []).includes(tpl.id)}}",
                  "props": {
                    "className": "mt-3 pt-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-tertiary font-medium mb-2"
                      },
                      "text": "$t:admin.settings.mail_templates.edit_modal.body"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-xs text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-900/50 rounded-lg p-3 max-h-48 overflow-y-auto whitespace-pre-wrap font-mono"
                      },
                      "text": "{{tpl.body?.[$locale] ?? tpl.body?.ko ?? ''}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "mail_templates_empty",
      "type": "basic",
      "name": "Div",
      "if": "{{(mailTemplates?.data?.data ?? []).length === 0}}",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "fa-solid fa-envelope",
            "className": "text-4xl text-gray-300 dark:text-gray-600 mb-3"
          }
        },
        {
          "type": "basic",
          "name": "P",
          "if": "{{query.search || query.search_type}}",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:admin.settings.mail_templates.empty_no_results"
        },
        {
          "type": "basic",
          "name": "P",
          "if": "{{!query.search && !query.search_type}}",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:admin.settings.mail_templates.empty_message"
        }
      ]
    },
    {
      "id": "mail_templates_pagination",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-center"
      },
      "children": [
        {
          "type": "composite",
          "name": "Pagination",
          "props": {
            "currentPage": "{{mailTemplates?.data?.pagination?.current_page || 1}}",
            "totalPages": "{{mailTemplates?.data?.pagination?.last_page || 1}}"
          },
          "actions": [
            {
              "event": "onPageChange",
              "type": "action",
              "handler": "navigate",
              "params": {
                "path": "/admin/settings",
                "replace": true,
                "mergeQuery": true,
                "query": {
                  "page": "{{$args[0]}}"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "props": {
  }
}
