{
  "meta": {
    "is_partial": true,
    "description": "환경설정 본인인증 메시지 정의 서브탭 — 알림 템플릿 관리 화면 패리티 (채널 서브탭 + 페이지당 + 정의 추가 + 카드 펼침 + 페이지네이션)"
  },
  "id": "identity_section_messages",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "scroll-mt-44 space-y-6"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "text": "$t:admin.settings.identity.messages.title"
        },
        {
          "type": "basic",
          "name": "P",
          "text": "$t:admin.settings.identity.messages.intro"
        }
      ],
      "props": {
        "className": "section-header"
      }
    },
    {
      "id": "identity_messages_channel_sub_tabs",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex border-b border-gray-200 dark:border-gray-700 overflow-x-auto"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "{{(_local.activeIdentityMessageChannel ?? 'mail') === 'mail' ? 'border-b-2 border-indigo-500 dark:border-indigo-400 text-indigo-600 dark:text-indigo-400' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'}} px-4 py-2.5 text-sm font-medium whitespace-nowrap flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "fa-solid fa-envelope",
                "className": "text-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:admin.settings.identity.messages.channels.mail"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "local",
                "activeIdentityMessageChannel": "mail"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "identity_messages_list_info",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-between py-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:admin.settings.identity.messages.total_count|count={{identityMessages?.data?.meta?.total ?? identityMessages?.data?.pagination?.total ?? 0}}"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-label-subtle"
              },
              "text": "$t:admin.settings.identity.messages.per_page_label"
            },
            {
              "type": "composite",
              "name": "Select",
              "props": {
                "name": "identityMessagesPerPage",
                "className": "w-20 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                "value": "{{String(query.messages_per_page || 20)}}",
                "options": [
                  {
                    "value": "10",
                    "label": "10"
                  },
                  {
                    "value": "20",
                    "label": "20"
                  },
                  {
                    "value": "50",
                    "label": "50"
                  }
                ]
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "navigate",
                  "params": {
                    "path": "/admin/settings",
                    "replace": true,
                    "mergeQuery": true,
                    "query": {
                      "messages_per_page": "{{$event.target.value}}",
                      "messages_page": 1
                    }
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "ml-2 inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-indigo-600",
                "disabled": "{{identityMessages?.data?.abilities?.can_create !== true}}"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "fa-solid fa-plus",
                    "className": "text-xs"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:admin.settings.identity.messages.btn_add_definition"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "params": {
                    "actions": [
                      {
                        "handler": "setState",
                        "params": {
                          "target": "global",
                          "identity_message_definition_add_modal": {
                            "editLang": "{{$locale}}",
                            "form": {
                              "provider_id": "g7:core.mail",
                              "scope_type": "policy",
                              "scope_value": "",
                              "name": {},
                              "channels": [
                                "mail"
                              ],
                              "subject": {},
                              "body": {}
                            },
                            "errors": null,
                            "isSaving": false
                          }
                        }
                      },
                      {
                        "handler": "openModal",
                        "target": "modal_identity_message_definition_add"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "identity_messages_list",
      "type": "basic",
      "name": "Div",
      "props": {
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "iteration": {
            "source": "{{identityMessages?.data?.data ?? []}}",
            "item_var": "def",
            "index_var": "defIdx"
          },
          "props": {
            "className": "admin-card mb-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-start gap-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-shrink-0 pt-0.5"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "p-1.5 rounded-md text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "{{(_local.expandedIdentityMessages ?? {})[def.id] ? 'fa-solid fa-chevron-up' : 'fa-solid fa-chevron-down'}}",
                            "size": "sm"
                          }
                        }
                      ],
                      "actions": [
                        {
                          "type": "click",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "expandedIdentityMessages": "{{Object.assign({}, _local.expandedIdentityMessages ?? {}, {[def.id]: !(_local.expandedIdentityMessages ?? {})[def.id]})}}"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-1 min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-1 min-w-0"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": {
                                "className": "flex-center flex-wrap gap-2 mb-1"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "H4",
                                  "props": {
                                    "className": "text-primary text-base font-medium"
                                  },
                                  "text": "{{def.name?.[$locale] ?? def.name?.ko ?? (def.provider_id + ' / ' + def.scope_type)}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "text-tertiary font-mono px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 rounded"
                                  },
                                  "text": "{{def.scope_type === 'provider_default' ? 'provider_default' : (def.scope_type + ':' + def.scope_value)}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "{{def.is_active ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'}} text-xs font-medium px-2 py-0.5 rounded-full"
                                  },
                                  "text": "{{def.is_active ? '$t:admin.settings.identity.messages.status_active' : '$t:admin.settings.identity.messages.status_inactive'}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "if": "{{def.is_default}}",
                                  "props": {
                                    "className": "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300 text-xs font-medium px-2 py-0.5 rounded-full"
                                  },
                                  "text": "$t:admin.settings.identity.messages.default_badge"
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-label-subtle truncate"
                              },
                              "text": "{{def.templates?.[0]?.subject?.[$locale] ?? def.templates?.[0]?.subject?.ko ?? ''}}"
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{(def.variables ?? []).length > 0}}",
                              "props": {
                                "className": "flex flex-wrap gap-1 mt-2"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "iteration": {
                                    "source": "{{def.variables ?? []}}",
                                    "item_var": "v"
                                  },
                                  "props": {
                                    "className": "text-tertiary px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 rounded font-mono"
                                  },
                                  "children": [
                                    {
                                      "type": "basic",
                                      "name": "Span",
                                      "text": "{"
                                    },
                                    {
                                      "type": "basic",
                                      "name": "Span",
                                      "text": "{{v.key}}"
                                    },
                                    {
                                      "type": "basic",
                                      "name": "Span",
                                      "text": "}"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-center gap-3 flex-shrink-0"
                          },
                          "children": [
                            {
                              "type": "composite",
                              "name": "Toggle",
                              "props": {
                                "size": "sm",
                                "checked": "{{def.is_active}}",
                                "disabled": "{{!(def.abilities?.can_update ?? false)}}"
                              },
                              "actions": [
                                {
                                  "type": "change",
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "{{'/api/admin/identity/messages/definitions/' + def.id + '/toggle-active'}}",
                                  "params": {
                                    "method": "PATCH"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "message": "$t:admin.settings.identity.messages.toggle_success",
                                        "variant": "success"
                                      }
                                    },
                                    {
                                      "handler": "refetchDataSource",
                                      "params": {
                                        "dataSourceId": "identityMessages"
                                      }
                                    }
                                  ],
                                  "onError": [
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "message": "$t:admin.settings.identity.messages.toggle_failed",
                                        "variant": "error"
                                      }
                                    },
                                    {
                                      "handler": "refetchDataSource",
                                      "params": {
                                        "dataSourceId": "identityMessages"
                                      }
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Button",
                              "props": {
                                "type": "button",
                                "disabled": "{{!(def.abilities?.can_update ?? false)}}",
                                "className": "text-sm px-3 py-1.5 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-indigo-600"
                              },
                              "text": "$t:admin.settings.identity.messages.edit",
                              "actions": [
                                {
                                  "type": "click",
                                  "handler": "sequence",
                                  "params": {
                                    "actions": [
                                      {
                                        "handler": "setState",
                                        "params": {
                                          "target": "global",
                                          "identity_message_template_form_modal": {
                                            "editLang": "{{$locale}}",
                                            "definition": {
                                              "id": "{{def.id}}",
                                              "name": "{{def.name ?? ''}}",
                                              "provider_id": "{{def.provider_id ?? ''}}",
                                              "scope_type": "{{def.scope_type ?? ''}}",
                                              "scope_value": "{{def.scope_value ?? ''}}",
                                              "variables": "{{def.variables ?? []}}"
                                            },
                                            "template": {
                                              "id": "{{def.templates?.[0]?.id}}",
                                              "subject": "{{def.templates?.[0]?.subject ?? ''}}",
                                              "body": "{{def.templates?.[0]?.body ?? ''}}"
                                            },
                                            "isSaving": false,
                                            "errors": null
                                          }
                                        }
                                      },
                                      {
                                        "handler": "openModal",
                                        "target": "modal_identity_message_template_form"
                                      }
                                    ]
                                  }
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Button",
                              "if": "{{!def.is_default}}",
                              "props": {
                                "type": "button",
                                "disabled": "{{!(def.abilities?.can_update ?? false)}}",
                                "className": "text-sm px-3 py-1.5 rounded-md border border-orange-300 dark:border-orange-600 text-orange-700 dark:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-900/30 transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-transparent"
                              },
                              "text": "$t:admin.settings.identity.messages.btn_reset",
                              "actions": [
                                {
                                  "type": "click",
                                  "handler": "sequence",
                                  "params": {
                                    "actions": [
                                      {
                                        "handler": "setState",
                                        "params": {
                                          "target": "global",
                                          "resetIdentityMessageTargetId": "{{def.id}}",
                                          "resetIdentityMessageTargetName": "{{def.name?.[$locale] ?? def.name?.ko ?? ''}}"
                                        }
                                      },
                                      {
                                        "handler": "openModal",
                                        "target": "modal_identity_message_definition_reset"
                                      }
                                    ]
                                  }
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Button",
                              "if": "{{def.abilities?.can_delete && def.scope_type === 'policy'}}",
                              "props": {
                                "type": "button",
                                "className": "text-sm px-3 py-1.5 rounded-md border border-red-300 dark:border-red-600 text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30 transition-colors"
                              },
                              "text": "$t:admin.settings.identity.messages.btn_delete",
                              "actions": [
                                {
                                  "type": "click",
                                  "handler": "sequence",
                                  "params": {
                                    "actions": [
                                      {
                                        "handler": "setState",
                                        "params": {
                                          "target": "global",
                                          "deleteIdentityMessageTargetId": "{{def.id}}",
                                          "deleteIdentityMessageTargetName": "{{def.name?.[$locale] ?? def.name?.ko ?? ''}}"
                                        }
                                      },
                                      {
                                        "handler": "openModal",
                                        "target": "modal_identity_message_definition_delete"
                                      }
                                    ]
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(_local.expandedIdentityMessages ?? {})[def.id]}}",
                      "props": {
                        "className": "mt-3 pt-3"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-tertiary font-medium mb-2 block"
                          },
                          "text": "$t:admin.settings.identity.messages.body_preview"
                        },
                        {
                          "type": "composite",
                          "name": "HtmlContent",
                          "props": {
                            "content": "{{def.templates?.[0]?.body?.[$locale] ?? def.templates?.[0]?.body?.ko ?? ''}}",
                            "isHtml": true,
                            "className": "prose dark:prose-invert prose-sm max-w-none bg-gray-50 dark:bg-gray-900/50 rounded-lg p-3 max-h-48 overflow-y-auto"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "identity_messages_empty",
      "type": "basic",
      "name": "Div",
      "if": "{{(identityMessages?.data?.data ?? []).length === 0}}",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "fa-solid fa-envelope",
            "className": "text-4xl text-gray-300 dark:text-gray-600 mb-3"
          }
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:admin.settings.identity.messages.empty"
        }
      ]
    },
    {
      "id": "identity_messages_pagination",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-center mt-4"
      },
      "children": [
        {
          "type": "composite",
          "name": "Pagination",
          "props": {
            "currentPage": "{{identityMessages?.data?.meta?.current_page ?? identityMessages?.data?.pagination?.current_page ?? 1}}",
            "totalPages": "{{identityMessages?.data?.meta?.last_page ?? identityMessages?.data?.pagination?.last_page ?? 1}}"
          },
          "actions": [
            {
              "event": "onPageChange",
              "type": "action",
              "handler": "navigate",
              "params": {
                "path": "/admin/settings",
                "replace": true,
                "mergeQuery": true,
                "query": {
                  "messages_page": "{{$args[0]}}"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
