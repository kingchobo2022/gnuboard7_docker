{
    "meta": { "is_partial": true, "description": "코어 업데이트 확인 결과 모달", "editor_label": "$t:admin.modal_label.admin_settings.core_update_result_modal" },
    "id": "core_update_result_modal",
    "type": "composite",
    "name": "Modal",
    "props": {
        "title": "$t:admin.settings.info.update_result_title",
        "size": "md"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": { "className": "row-stack" },
            "children": [
                {
                    "type": "basic",
                    "name": "Div",
                    "props": { "className": "flex-between border-b border-gray-100 dark:border-gray-700" },
                    "children": [
                        { "type": "basic", "name": "Span", "props": { "className": "text-label" }, "text": "$t:admin.settings.info.current_version" },
                        { "type": "basic", "name": "Span", "props": { "className": "text-heading" }, "text": "{{$parent._local.coreUpdateInfo?.current_version ?? '-'}}" }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "props": { "className": "flex-between border-b border-gray-100 dark:border-gray-700" },
                    "children": [
                        { "type": "basic", "name": "Span", "props": { "className": "text-label" }, "text": "$t:admin.settings.info.latest_version" },
                        { "type": "basic", "name": "Span", "props": { "className": "text-heading" }, "text": "{{$parent._local.coreUpdateInfo?.latest_version ?? '-'}}" }
                    ]
                },
                {
                    "id": "update_available_section",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{$parent._local.coreUpdateInfo?.update_available}}",
                    "props": { "className": "space-y-3" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "alert-success" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "P",
                                    "props": { "className": "text-success-soft" },
                                    "text": "$t:admin.settings.info.update_available_message"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex gap-2 justify-end" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Button",
                                    "props": {
                                        "type": "button",
                                        "className": "px-3 py-1.5 text-sm font-medium text-white bg-gray-900 dark:bg-white dark:text-gray-900 rounded-md hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors"
                                    },
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "apiCall",
                                            "auth_required": true,
                                            "target": "/api/admin/core-update/changelog",
                                            "params": {
                                                "method": "GET",
                                                "query": {
                                                    "from_version": "{{$parent._local.coreUpdateInfo?.current_version ?? ''}}",
                                                    "to_version": "{{$parent._local.coreUpdateInfo?.latest_version ?? ''}}"
                                                }
                                            },
                                            "onSuccess": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "local",
                                                        "coreChangelog": "{{result.data.changelog ?? []}}"
                                                    }
                                                },
                                                {
                                                    "handler": "openModal",
                                                    "target": "core_changelog_modal"
                                                }
                                            ],
                                            "onError": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "local",
                                                        "coreChangelog": []
                                                    }
                                                },
                                                {
                                                    "handler": "openModal",
                                                    "target": "core_changelog_modal"
                                                }
                                            ]
                                        }
                                    ],
                                    "text": "$t:admin.settings.info.view_changelog"
                                },
                                {
                                    "type": "basic",
                                    "name": "Button",
                                    "props": {
                                        "type": "button",
                                        "className": "px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors"
                                    },
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "openModal",
                                            "target": "core_update_guide_modal"
                                        }
                                    ],
                                    "text": "$t:admin.settings.info.how_to_update"
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "no_update_section",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{!$parent._local.coreUpdateInfo?.update_available}}",
                    "props": { "className": "" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "alert-info" },
                            "children": [
                                { "type": "basic", "name": "P", "props": { "className": "text-info-soft" }, "text": "$t:admin.settings.info.no_update_message" }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
