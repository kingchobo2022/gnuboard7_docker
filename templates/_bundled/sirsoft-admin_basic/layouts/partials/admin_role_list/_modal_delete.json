{
  "meta": {
    "is_partial": true,
    "description": "역할 삭제 확인 모달",
    "editor_label": "$t:admin.modal_label.admin_role_list.delete_confirm_modal"
  },
  "id": "delete_confirm_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.roles.modals.delete_title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-gray-700 dark:text-gray-300"
      },
      "text": "$t:admin.roles.modals.delete_confirm"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "btn btn-secondary",
            "disabled": "{{_global.isDeleting}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal",
              "target": "delete_confirm_modal"
            }
          ],
          "text": "$t:common.cancel"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isDeleting}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isDeleting": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/roles/{{_global.deleteTargetId}}",
                  "params": {
                    "method": "DELETE"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isDeleting": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "deleteTargetId": null,
                        "deleteTargetName": ""
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.roles.modals.delete_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "roles"
                      }
                    },
                    {
                      "handler": "closeModal",
                      "target": "delete_confirm_modal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isDeleting": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message ?? $t:admin.roles.errors.delete_failed}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isDeleting}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isDeleting ? '$t:common.deleting' : '$t:common.delete'}}"
            }
          ]
        }
      ]
    }
  ]
}
