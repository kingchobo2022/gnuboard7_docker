{
    "meta": {
        "is_partial": true,
        "description": "번들 언어팩 설치 확인 모달 — 모듈/플러그인의 install 모달과 동일한 패턴. 행의 '설치' 버튼이 즉시 apiCall 하지 않고 본 모달을 열어 운영자가 확인 후 진행.",
        "editor_label": "$t:admin.modal_label.admin_language_pack_list.language_pack_install_bundled_modal"
    },
    "id": "language_pack_install_bundled_modal",
    "type": "composite",
    "name": "Modal",
    "props": {
        "title": "$t:admin.language_packs.modals.install_bundled_title",
        "size": "sm"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": { "className": "py-2 space-y-3" },
            "children": [
                {
                    "type": "basic",
                    "name": "P",
                    "props": { "className": "text-gray-700 dark:text-gray-300" },
                    "text": "$t:admin.language_packs.modals.install_bundled_confirm|identifier={{_global.selectedBundledLanguagePack?.identifier ?? ''}}"
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "props": { "className": "rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-2 text-sm space-y-1" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "text-secondary flex justify-between" },
                            "children": [
                                { "type": "basic", "name": "Span", "text": "$t:admin.language_packs.columns.scope" },
                                { "type": "basic", "name": "Span", "props": { "className": "font-medium text-gray-900 dark:text-gray-100" }, "text": "{{_global.selectedBundledLanguagePack?.scope ?? '-'}}" }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "if": "{{_global.selectedBundledLanguagePack?.target_identifier}}",
                            "props": { "className": "text-secondary flex justify-between" },
                            "children": [
                                { "type": "basic", "name": "Span", "text": "$t:admin.language_packs.columns.target" },
                                { "type": "basic", "name": "Span", "props": { "className": "font-medium text-gray-900 dark:text-gray-100" }, "text": "{{_global.selectedBundledLanguagePack?.target_identifier}}" }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "text-secondary flex justify-between" },
                            "children": [
                                { "type": "basic", "name": "Span", "text": "$t:admin.language_packs.columns.locale" },
                                { "type": "basic", "name": "Span", "props": { "className": "font-medium text-gray-900 dark:text-gray-100" }, "text": "{{_global.selectedBundledLanguagePack?.locale}} · {{_global.selectedBundledLanguagePack?.locale_native_name ?? ''}}" }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "text-secondary flex justify-between" },
                            "children": [
                                { "type": "basic", "name": "Span", "text": "$t:admin.language_packs.columns.version" },
                                { "type": "basic", "name": "Span", "props": { "className": "font-medium text-gray-900 dark:text-gray-100" }, "text": "{{_global.selectedBundledLanguagePack?.version ?? '-'}}" }
                            ]
                        }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "if": "{{_global.selectedBundledLanguagePack?.install_blocked_reason}}",
                    "props": { "className": "rounded-md border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 px-3 py-2 text-warning-soft" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex-start gap-2" },
                            "children": [
                                { "type": "basic", "name": "Icon", "props": { "name": "fas fa-triangle-exclamation", "size": "sm", "className": "mt-0.5" } },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_global.selectedBundledLanguagePack?.install_blocked_reason === 'core_locale_missing'}}",
                                    "text": "$t:admin.language_packs.modals.install_bundled_core_required|locale={{_global.selectedBundledLanguagePack?.locale}}"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_global.selectedBundledLanguagePack?.install_blocked_reason === 'target_not_installed'}}",
                                    "text": "$t:admin.language_packs.modals.install_blocked_target_not_installed|scope={{_global.selectedBundledLanguagePack?.scope}}|target={{_global.selectedBundledLanguagePack?.target_identifier ?? ''}}"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_global.selectedBundledLanguagePack?.install_blocked_reason === 'target_inactive'}}",
                                    "text": "$t:admin.language_packs.modals.install_blocked_target_inactive|scope={{_global.selectedBundledLanguagePack?.scope}}|target={{_global.selectedBundledLanguagePack?.target_identifier ?? ''}}"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_global.selectedBundledLanguagePack?.install_blocked_reason === 'target_version_too_old'}}",
                                    "text": "$t:admin.language_packs.modals.install_blocked_target_version_too_old|scope={{_global.selectedBundledLanguagePack?.scope}}|target={{_global.selectedBundledLanguagePack?.target_identifier ?? ''}}"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "basic",
            "name": "Div",
            "props": { "className": "modal-footer-buttons" },
            "children": [
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "className": "btn btn-secondary",
                        "disabled": "{{_global.isLanguagePackInstalling}}"
                    },
                    "actions": [
                        { "event": "onClick", "handler": "closeModal" }
                    ],
                    "children": [
                        { "type": "basic", "name": "Span", "text": "$t:common.cancel" }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "className": "flex-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed",
                        "disabled": "{{_global.isLanguagePackInstalling || _global.selectedBundledLanguagePack?.install_blocked_reason || _global.selectedBundledLanguagePack?.abilities?.can_install !== true}}"
                    },
                    "actions": [
                        {
                            "event": "onClick",
                            "handler": "sequence",
                            "params": {
                                "actions": [
                                    {
                                        "handler": "setState",
                                        "params": { "target": "global", "isLanguagePackInstalling": true }
                                    },
                                    {
                                        "handler": "apiCall",
                                        "auth_required": true,
                                        "target": "/api/admin/language-packs/install-from-bundled",
                                        "params": {
                                            "method": "POST",
                                            "body": {
                                                "identifier": "{{_global.selectedBundledLanguagePack?.identifier}}",
                                                "auto_activate": false
                                            }
                                        },
                                        "onSuccess": [
                                            { "handler": "setState", "params": { "target": "global", "isLanguagePackInstalling": false, "selectedBundledLanguagePack": null } },
                                            { "handler": "toast", "params": { "type": "success", "message": "$t:admin.language_packs.messages.install_success" } },
                                            { "handler": "refetchDataSource", "params": { "dataSourceId": "language_packs" } },
                                            { "handler": "reloadExtensions" },
                                            { "handler": "closeModal" }
                                        ],
                                        "onError": [
                                            { "handler": "setState", "params": { "target": "global", "isLanguagePackInstalling": false } },
                                            { "handler": "toast", "params": { "type": "error", "message": "{{error.message ?? '$t:admin.language_packs.messages.install_failed'}}" } }
                                        ]
                                    }
                                ]
                            }
                        }
                    ],
                    "children": [
                        { "type": "basic", "name": "Icon", "if": "{{!_global.isLanguagePackInstalling}}", "props": { "name": "fas fa-download", "size": "sm" } },
                        { "type": "basic", "name": "Icon", "if": "{{_global.isLanguagePackInstalling}}", "props": { "name": "fas fa-spinner", "className": "animate-spin", "size": "sm" } },
                        { "type": "basic", "name": "Span", "text": "{{_global.isLanguagePackInstalling ? '$t:admin.language_packs.installing' : '$t:admin.language_packs.actions.install'}}" }
                    ]
                }
            ]
        }
    ]
}
