{
    "meta": {
        "editor_label": "$t:admin.modal_label.admin_language_pack_list.language_pack_update_modal",
        "is_partial": true,
        "description": "언어팩 업데이트 확인 모달 — 모듈/플러그인 update 모달과 동일 수준. 로딩 스피너, reloadExtensions 후속 호출 포함."
    },
    "id": "language_pack_update_modal",
    "type": "composite",
    "name": "Modal",
    "props": {
        "title": "$t:admin.language_packs.modal.update.title",
        "size": "sm"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": { "className": "py-2 space-y-3" },
            "children": [
                {
                    "type": "basic",
                    "name": "P",
                    "props": { "className": "text-body" },
                    "text": "$t:admin.language_packs.modal.update.body|current={{_local.updateCurrent}}|latest={{_local.updateLatest}}"
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "props": { "className": "text-secondary rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-2 text-xs" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex-start gap-2" },
                            "children": [
                                { "type": "basic", "name": "Icon", "props": { "name": "fas fa-info-circle", "size": "sm", "className": "mt-0.5" } },
                                { "type": "basic", "name": "Span", "text": "$t:admin.language_packs.modal.update.user_overrides_notice" }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "basic",
            "name": "Div",
            "props": { "className": "flex justify-end gap-2 mt-6" },
            "children": [
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "disabled": "{{_global.isLanguagePackUpdating}}",
                        "className": "px-4 py-2 bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 text-sm font-medium rounded-md disabled:opacity-50 disabled:cursor-not-allowed"
                    },
                    "actions": [
                        { "event": "onClick", "handler": "closeModal", "target": "language_pack_update_modal" }
                    ],
                    "children": [
                        { "type": "basic", "name": "Span", "text": "$t:common.cancel" }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Button",
                    "props": {
                        "type": "button",
                        "disabled": "{{_global.isLanguagePackUpdating}}",
                        "className": "flex-center gap-2 px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white text-sm font-medium rounded-md disabled:opacity-50 disabled:cursor-not-allowed"
                    },
                    "actions": [
                        {
                            "event": "onClick",
                            "handler": "sequence",
                            "params": {
                                "actions": [
                                    {
                                        "handler": "setState",
                                        "params": { "target": "global", "isLanguagePackUpdating": true }
                                    },
                                    {
                                        "handler": "apiCall",
                                        "auth_required": true,
                                        "target": "/api/admin/language-packs/{{_local.updateId}}/update",
                                        "params": { "method": "POST" },
                                        "onSuccess": [
                                            { "handler": "setState", "params": { "target": "global", "isLanguagePackUpdating": false } },
                                            { "handler": "toast", "params": { "type": "success", "message": "$t:admin.language_packs.messages.update_success" } },
                                            { "handler": "refetchDataSource", "params": { "dataSourceId": "language_packs" } },
                                            { "handler": "reloadExtensions" },
                                            { "handler": "closeModal", "target": "language_pack_update_modal" }
                                        ],
                                        "onError": [
                                            { "handler": "setState", "params": { "target": "global", "isLanguagePackUpdating": false } },
                                            { "handler": "toast", "params": { "type": "error", "message": "{{error.message ?? '$t:admin.language_packs.messages.update_failed'}}" } }
                                        ]
                                    }
                                ]
                            }
                        }
                    ],
                    "children": [
                        { "type": "basic", "name": "Icon", "if": "{{!_global.isLanguagePackUpdating}}", "props": { "name": "fas fa-arrow-up", "size": "sm" } },
                        { "type": "basic", "name": "Icon", "if": "{{_global.isLanguagePackUpdating}}", "props": { "name": "fas fa-spinner", "className": "animate-spin", "size": "sm" } },
                        { "type": "basic", "name": "Span", "text": "{{_global.isLanguagePackUpdating ? '$t:admin.language_packs.updating' : '$t:admin.language_packs.actions.update_now'}}" }
                    ]
                }
            ]
        }
    ]
}
