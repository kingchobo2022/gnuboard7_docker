{
  "meta": {
    "is_partial": true,
    "description": "플러그인 업데이트 확인 모달",
    "editor_label": "$t:admin.modal_label.admin_plugin_list.plugin_update_modal"
  },
  "id": "plugin_update_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.plugins.modals.update_title",
    "size": "medium"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_global.selectedPlugin?.is_compatible === false}}",
      "props": {
        "className": "mb-3 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-lg",
        "role": "alert"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "exclamation-triangle",
                "className": "text-amber-600 dark:text-amber-400 mt-0.5 shrink-0"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm font-medium text-warning-soft"
                  },
                  "text": "$t:extensions.update_modal.compat_warning_title"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-warning-soft mt-1"
                  },
                  "text": "$t:defer:extensions.update_modal.compat_warning_message|type=$t:extensions.types.plugin|required={{_global.selectedPlugin?.required_core_version ?? _global.selectedPlugin?.incompatible_required_version ?? ''}}|installed={{_global.selectedPlugin?.current_core_version ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium border border-amber-500 dark:border-amber-400 bg-white dark:bg-gray-800 text-warning-soft hover:bg-amber-50 dark:hover:bg-gray-700 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 dark:focus:ring-amber-400 focus:ring-offset-2 transition-colors cursor-pointer mt-2"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "openModal",
                      "target": "core_update_guide_modal"
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "external-link",
                        "size": "xs"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:extensions.update_modal.compat_guide_link"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex-center gap-2 mt-3 text-warning-soft cursor-pointer select-none"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "checked": "{{_global.pluginForceUpdate === true}}",
                        "className": "w-4 h-4 rounded border-amber-300 dark:border-amber-600 text-amber-600 dark:text-amber-400 focus:ring-amber-500 dark:focus:ring-amber-400"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "pluginForceUpdate": "{{!_global.pluginForceUpdate}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:extensions.update_modal.force_label"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_global.pluginUpdateError}}",
      "props": {
        "className": "mb-3 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "exclamation-circle",
                "className": "text-red-500 dark:text-red-400 mt-0.5 shrink-0"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-error-soft break-all"
              },
              "text": "{{_global.pluginUpdateError}}"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-gray-700 dark:text-gray-300"
          },
          "text": "$t:admin.plugins.modals.update_confirm|name={{_global.selectedPlugin.name ?? ''}}"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mt-3 p-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg space-y-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 text-sm"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:admin.plugins.modals.field_version"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary font-medium"
                  },
                  "text": "$t:admin.plugins.modals.update_version_info|from={{_global.selectedPlugin.version ?? ''}}|to={{_global.selectedPlugin.latest_version ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 text-sm"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:admin.plugins.modals.field_vendor"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-700 dark:text-gray-300"
                  },
                  "text": "{{_global.selectedPlugin.vendor ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 text-sm"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:admin.plugins.modals.field_update_source"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-700 dark:text-gray-300"
                  },
                  "text": "{{_global.selectedPlugin.update_source === 'github' ? '$t:admin.plugins.modals.update_source_github' : (_global.selectedPlugin.update_source === 'pending' ? '$t:admin.plugins.modals.update_source_pending' : '$t:admin.plugins.modals.update_source_bundled')}}"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{_global.updateChangelog && _global.updateChangelog.length > 0}}",
          "props": {
            "className": "mt-3 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-lg"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-sm font-medium text-info-soft mb-2"
              },
              "text": "$t:admin.plugins.modals.update_changelog_title"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "max-h-48 overflow-y-auto"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "iteration": {
                    "source": "_global.updateChangelog",
                    "item_var": "entry",
                    "index_var": "entryIdx"
                  },
                  "props": {
                    "className": "pb-3 mb-3 border-b border-blue-200 dark:border-blue-700 last:border-b-0 last:mb-0 last:pb-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-2 mb-1.5"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-info-soft inline-flex items-center px-2 py-0.5 rounded-md font-semibold bg-blue-100 dark:bg-blue-800"
                          },
                          "text": "v{{entry.version}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{entry.date}}",
                          "props": {
                            "className": "text-hint"
                          },
                          "text": "{{entry.date}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "row-stack"
                      },
                      "iteration": {
                        "source": "entry.categories",
                        "item_var": "category",
                        "index_var": "catIdx"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-secondary text-xs font-medium"
                              },
                              "text": "{{category.name}}"
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": {
                                "className": "ml-3 space-y-0.5"
                              },
                              "iteration": {
                                "source": "category.items",
                                "item_var": "changeItem",
                                "index_var": "itemIdx"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "props": {
                                    "className": "text-secondary text-xs"
                                  },
                                  "text": "• {{changeItem}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{_global.selectedPlugin.github_changelog_url}}",
          "props": {
            "className": "mt-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "A",
              "props": {
                "href": "{{_global.selectedPlugin.github_changelog_url}}",
                "target": "_blank",
                "className": "inline-flex items-center gap-1.5 text-sm text-blue-600 dark:text-blue-400 hover:underline"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "external-link",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:admin.plugins.modals.view_changelog"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mt-4 p-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
              },
              "text": "$t:admin.plugins.modals.layout_strategy_title"
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_global.hasModifiedPluginLayouts}}",
              "props": {
                "className": "mb-2 p-2 bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-700 rounded text-xs text-amber-700 dark:text-amber-400"
              },
              "text": "$t:admin.plugins.modals.modified_layouts_warning|count={{_global.modifiedPluginLayoutsCount ?? 0}}"
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{!_global.hasModifiedPluginLayouts}}",
              "props": {
                "className": "mb-2 p-2 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded text-xs text-green-700 dark:text-green-400"
              },
              "text": "$t:admin.plugins.modals.no_modified_layouts"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "row-stack"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex-start gap-2 p-2 rounded cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "plugin_layout_strategy",
                        "value": "overwrite",
                        "checked": "{{(_global.pluginLayoutStrategy ?? 'overwrite') === 'overwrite'}}",
                        "className": "radio mt-0.5"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "pluginLayoutStrategy": "overwrite"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-sm font-medium text-gray-700 dark:text-gray-300"
                          },
                          "text": "$t:admin.plugins.modals.layout_strategy_overwrite"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-tertiary"
                          },
                          "text": "$t:admin.plugins.modals.layout_strategy_overwrite_desc"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex-start gap-2 p-2 rounded cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "plugin_layout_strategy",
                        "value": "keep",
                        "checked": "{{(_global.pluginLayoutStrategy ?? 'overwrite') === 'keep'}}",
                        "className": "radio mt-0.5"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "pluginLayoutStrategy": "keep"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-sm font-medium text-gray-700 dark:text-gray-300"
                          },
                          "text": "$t:admin.plugins.modals.layout_strategy_keep"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-tertiary"
                          },
                          "text": "$t:admin.plugins.modals.layout_strategy_keep_desc"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{(_global.pluginLayoutStrategy ?? 'overwrite') === 'keep' && _global.modifiedPluginLayouts && _global.modifiedPluginLayouts.length > 0}}",
                  "props": {
                    "className": "ml-6 mt-2 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-lg"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-xs font-medium text-warning-soft mb-2"
                      },
                      "text": "$t:admin.plugins.modals.modified_layouts_list_title|count={{_global.modifiedPluginLayouts?.length ?? 0}}"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "space-y-1 max-h-40 overflow-y-auto"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "iteration": {
                            "source": "_global.modifiedPluginLayouts",
                            "item_var": "modLayout"
                          },
                          "props": {
                            "className": "flex-center gap-3 text-xs px-2 py-1.5 bg-white dark:bg-gray-800 rounded"
                          },
                          "children": [
                            {
                              "type": "composite",
                              "name": "Icon",
                              "props": {
                                "name": "file-alt",
                                "className": "text-amber-500 dark:text-amber-400 shrink-0"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "font-mono flex-1 text-gray-700 dark:text-gray-300"
                              },
                              "text": "{{modLayout.name}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-400 dark:text-gray-500 shrink-0"
                              },
                              "text": "{{modLayout.updated_at}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center mt-2 text-xs text-amber-600 dark:text-amber-400 gap-1"
                      },
                      "children": [
                        {
                          "type": "composite",
                          "name": "Icon",
                          "props": {
                            "name": "info-circle",
                            "size": "xs"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:admin.plugins.modals.modified_layouts_keep_notice"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "btn btn-secondary",
            "disabled": "{{_global.isPluginUpdating}}",
            "type": "button"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex-center gap-2 px-4 py-2 bg-amber-600 dark:bg-amber-500 text-white rounded-lg hover:bg-amber-700 dark:hover:bg-amber-600 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isPluginUpdating || (_global.selectedPlugin?.is_compatible === false && _global.pluginForceUpdate !== true)}}",
            "type": "button"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isPluginUpdating": true,
                    "pluginUpdateError": null
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/plugins/{{_global.selectedPlugin.identifier}}/update",
                  "params": {
                    "method": "POST",
                    "body": {
                      "layout_strategy": "{{_global.pluginLayoutStrategy ?? 'overwrite'}}",
                      "force": "{{_global.pluginForceUpdate === true}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isPluginUpdating": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "selectedPlugin": null,
                        "pluginLayoutStrategy": "overwrite",
                        "hasModifiedPluginLayouts": false,
                        "modifiedPluginLayoutsCount": 0,
                        "modifiedPluginLayouts": []
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.plugins.update_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "plugins"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isPluginUpdating": false,
                        "pluginUpdateError": "{{error.message}}"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isPluginUpdating}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isPluginUpdating ? '$t:admin.plugins.updating' : '$t:admin.plugins.actions.update'}}"
            }
          ]
        }
      ]
    }
  ]
}
