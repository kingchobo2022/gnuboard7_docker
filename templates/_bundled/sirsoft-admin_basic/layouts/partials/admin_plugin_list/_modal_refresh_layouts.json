{
  "meta": {
    "is_partial": true,
    "description": "플러그인 레이아웃 갱신 확인 모달",
    "editor_label": "$t:admin.modal_label.admin_plugin_list.plugin_refresh_layouts_modal"
  },
  "id": "plugin_refresh_layouts_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.plugins.modals.refresh_layouts_title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "alert-warning"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "exclamation-triangle",
                "className": "w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-warning-soft"
              },
              "text": "$t:admin.plugins.modals.refresh_layouts_warning"
            }
          ]
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-gray-700 dark:text-gray-300"
          },
          "text": "$t:admin.plugins.modals.refresh_layouts_confirm|name={{_global.selectedPlugin.name}}"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-2 text-label-subtle"
          },
          "text": "$t:admin.plugins.modals.refresh_layouts_description"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "btn btn-secondary",
            "disabled": "{{_global.isPluginRefreshingLayouts}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex-center gap-2 px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isPluginRefreshingLayouts}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isPluginRefreshingLayouts": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/plugins/refresh-layouts",
                  "params": {
                    "method": "POST",
                    "body": {
                      "plugin_name": "{{_global.selectedPlugin.identifier}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isPluginRefreshingLayouts": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "selectedPlugin": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.plugins.refresh_layouts_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "plugins"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isPluginRefreshingLayouts": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isPluginRefreshingLayouts}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isPluginRefreshingLayouts ? '$t:admin.plugins.refreshing_layouts' : '$t:admin.plugins.actions.refresh_layouts'}}"
            }
          ]
        }
      ]
    }
  ]
}
