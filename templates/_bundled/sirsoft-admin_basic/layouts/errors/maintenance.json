{
    "version": "1.0.0",
    "layout_name": "errors/maintenance",
    "extends": "_admin_base",
    "meta": {
        "title": "$t:errors.maintenance.title",
        "is_error_layout": true,
        "error_code": 503
    },
    "slots": {
        "content": [
            {
                "id": "maintenance_container",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "flex-center flex-col justify-center min-h-[60vh] text-center p-8"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "Icon",
                        "props": {
                            "name": "gear",
                            "className": "w-24 h-24 text-blue-500 dark:text-blue-400 mb-6 animate-spin"
                        }
                    },
                    {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                            "className": "text-primary text-3xl font-bold mb-4"
                        },
                        "text": "$t:errors.maintenance.title"
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "text-secondary text-lg mb-2 max-w-md"
                        },
                        "text": "$t:errors.maintenance.message"
                    },
                    {
                        "type": "basic",
                        "name": "P",
                        "props": {
                            "className": "text-sm text-gray-500 dark:text-gray-500 max-w-md"
                        },
                        "text": "$t:errors.maintenance.description"
                    }
                ]
            }
        ]
    }
}
