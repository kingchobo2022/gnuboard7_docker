{
  "target_layout": "admin_user_form",
  "injections": [
    {
      "target_id": "user_form_tabs",
      "position": "inject_props",
      "props": {
        "tabs": {
          "_append": [
            {
              "id": "ext_notification",
              "label": "$t:sirsoft-board.admin.users.form.sections.notification_settings",
              "iconName": "cubes"
            }
          ]
        }
      }
    },
    {
      "target_id": "extension_form_content",
      "position": "append_child",
      "components": [
        {
          "id": "ext_notification_form_content",
          "type": "basic",
          "name": "Div",
          "props": {
            "id": "ext_notification",
            "className": "scroll-mt-32 mt-6"
          },
          "children": [
            {
              "id": "section_notification_settings",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "admin-card"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-between mb-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "bell",
                            "className": "text-secondary w-5 h-5"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "H3",
                          "props": {
                            "className": "section-heading"
                          },
                          "text": "$t:sirsoft-board.admin.users.form.sections.notification_settings"
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "ExtensionBadge",
                      "props": {
                        "type": "module",
                        "identifier": "sirsoft-board",
                        "installedModules": "{{_global.installedModules}}"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "grid-2col-responsive"
                  },
                  "children": [
                    {
                      "id": "field_notify_post_complete",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "flex-center gap-2 cursor-pointer"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "checkbox",
                                "name": "notify_post_complete",
                                "checked": "{{_local.form?.notify_post_complete ?? false}}",
                                "className": "w-4 h-4 text-blue-600 border-gray-300 dark:border-gray-600 rounded focus:ring-blue-500"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-body"
                              },
                              "text": "$t:sirsoft-board.admin.users.form.notifications.post_complete"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "id": "field_notify_post_reply",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "flex-center gap-2 cursor-pointer"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "checkbox",
                                "name": "notify_post_reply",
                                "checked": "{{_local.form?.notify_post_reply ?? false}}",
                                "className": "w-4 h-4 text-blue-600 border-gray-300 dark:border-gray-600 rounded focus:ring-blue-500"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-body"
                              },
                              "text": "$t:sirsoft-board.admin.users.form.notifications.post_reply"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "id": "field_notify_comment",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "flex-center gap-2 cursor-pointer"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "checkbox",
                                "name": "notify_comment",
                                "checked": "{{_local.form?.notify_comment ?? false}}",
                                "className": "w-4 h-4 text-blue-600 border-gray-300 dark:border-gray-600 rounded focus:ring-blue-500"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-body"
                              },
                              "text": "$t:sirsoft-board.admin.users.form.notifications.comment"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "id": "field_notify_reply_comment",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "flex-center gap-2 cursor-pointer"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "checkbox",
                                "name": "notify_reply_comment",
                                "checked": "{{_local.form?.notify_reply_comment ?? false}}",
                                "className": "w-4 h-4 text-blue-600 border-gray-300 dark:border-gray-600 rounded focus:ring-blue-500"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-body"
                              },
                              "text": "$t:sirsoft-board.admin.users.form.notifications.reply_comment"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "priority": 300
}
