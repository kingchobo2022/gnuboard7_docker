{
  "meta": {
    "is_partial": true,
    "description": "Board Form - Basic Tab Content"
  },
  "id": "section_basic_card",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
        {
          "id": "section_basic_settings",
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.form.tabs.basic"
        },
        {
          "id": "section_basic_fields",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
        {
          "id": "field_is_active",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start justify-between"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-heading"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.is_active"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.form.descriptions.is_active"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Toggle",
              "props": {
                "name": "is_active",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "flex-shrink-0 ml-4"
              }
            }
          ]
        },
        {
          "id": "field_slug",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "id": "field_slug_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "required": true,
                "className": "block text-heading mb-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.slug"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-required"
                  },
                  "text": "*"
                }
              ]
            },
            {
              "id": "field_slug_input",
              "type": "basic",
              "name": "Input",
              "props": {
                "name": "slug",
                "type": "text",
                "placeholder": "$t:sirsoft-board.admin.form.placeholders.slug",
                "required": true,
                "disabled": "{{!!route?.id || _computed.isReadOnly}}",
                "className": "font-mono"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.slug}}",
              "props": {
                "className": "form-error-xs mt-1"
              },
              "text": "{{_local.errors?.slug?.[0] ?? ''}}"
            },
            {
              "id": "field_slug_description",
              "type": "basic",
              "name": "P",
              "props": {
                "className": "form-hint"
              },
              "text": "$t:sirsoft-board.admin.form.descriptions.slug"
            },
            {
              "id": "field_menu_guide",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "mt-4 p-4 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-start gap-2 mb-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "circle-info",
                        "className": "text-secondary w-4 h-4 mt-0.5 flex-shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-body"
                      },
                      "text": "$t:sirsoft-board.admin.form.menu.manual_guide"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-secondary space-y-2 text-xs"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-baseline gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-medium text-gray-700 dark:text-gray-300"
                          },
                          "text": "•"
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-center gap-2 flex-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "font-medium"
                                  },
                                  "text": "$t:sirsoft-board.admin.form.menu.manual_admin_label:"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "ml-2 px-2 py-0.5 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded text-gray-800 dark:text-gray-200 font-mono"
                                  },
                                  "text": "/admin/board/{{_local.form?.slug ?? 'notice'}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-baseline gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-medium text-gray-700 dark:text-gray-300"
                          },
                          "text": "•"
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "font-medium"
                              },
                              "text": "$t:sirsoft-board.admin.form.menu.manual_user_label:"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "ml-2 px-2 py-0.5 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded text-gray-800 dark:text-gray-200 font-mono"
                              },
                              "text": "/board/{{_local.form?.slug ?? 'notice'}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-3 mt-4 pt-3 border-t border-gray-200 dark:border-gray-700"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-heading"
                          },
                          "text": "$t:sirsoft-board.admin.form.menu.show_in_admin_menu"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-secondary text-xs mt-0.5"
                          },
                          "text": "$t:sirsoft-board.admin.form.menu.show_in_admin_menu_desc"
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "name": "add_to_menu",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "flex-shrink-0"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "field_name",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "id": "field_name_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "required": true,
                "className": "block text-heading mb-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.name"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-required"
                  },
                  "text": "*"
                }
              ]
            },
            {
              "id": "field_name_input",
              "type": "composite",
              "name": "MultilingualInput",
              "props": {
                "name": "name",
                "layout": "tabs",
                "placeholder": "$t:sirsoft-board.admin.form.placeholders.name",
                "maxLength": 100,
                "required": true,
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.name}}",
              "props": {
                "className": "form-error-xs mt-1"
              },
              "text": "{{_local.errors?.name?.[0] ?? ''}}"
            }
          ]
        },
        {
          "id": "field_description",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "id": "field_description_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-heading mb-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.description"
                }
              ]
            },
            {
              "id": "field_description_input",
              "type": "composite",
              "name": "MultilingualInput",
              "props": {
                "name": "description",
                "layout": "tabs",
                "inputType": "textarea",
                "placeholder": "$t:sirsoft-board.admin.form.placeholders.description",
                "rows": 3,
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.description}}",
              "props": {
                "className": "form-error-xs mt-1"
              },
              "text": "{{_local.errors?.description?.[0] ?? ''}}"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "form-hint"
              },
              "text": "$t:sirsoft-board.admin.form.descriptions.description"
            }
          ]
        },
        {
          "id": "field_type",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "id": "field_type_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "required": true,
                "className": "block text-heading mb-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.type"
                }
              ]
            },
            {
              "id": "field_type_select",
              "type": "composite",
              "name": "Select",
              "props": {
                "name": "type",
                "options": "{{boards?.data?.board_types?.map(t => ({value: t.slug, label: (t.name[_global.locale ?? $locale ?? 'ko'] ?? t.name.ko ?? t.slug) + ' (' + t.slug + ')'})) ?? []}}",
                "placeholder": "$t:sirsoft-board.admin.form.placeholders.select_type",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "w-full"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "form-hint"
              },
              "text": "$t:sirsoft-board.admin.form.descriptions.type"
            }
          ]
        },
        {
          "id": "field_categories",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "id": "field_categories_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "text-heading"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.categories"
                }
              ]
            },
            {
              "id": "field_categories_description",
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-tertiary mb-2"
              },
              "text": "$t:sirsoft-board.admin.form.descriptions.categories"
            },
            {
              "id": "field_categories_input",
              "type": "composite",
              "name": "TagInput",
              "props": {
                "name": "categories",
                "options": "{{_local.form?.category_options ?? []}}",
                "creatable": true,
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.categories}}",
              "props": {
                "className": "form-error-xs mt-1"
              },
              "text": "{{_local.errors?.categories?.[0] ?? ''}}"
            },
            {
              "id": "field_categories_notice",
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-amber-600 dark:text-amber-400 mt-2"
              },
              "text": "$t:sirsoft-board.admin.form.descriptions.categories_notice"
            }
          ]
        },
        {
          "id": "field_secret_mode",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-between"
          },
          "children": [
            {
              "id": "field_secret_mode_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "text-heading"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.secret_mode"
                }
              ]
            },
            {
              "id": "field_secret_mode_select",
              "type": "composite",
              "name": "Select",
              "props": {
                "name": "secret_mode",
                "disabled": "{{_computed.isReadOnly}}",
                "options": [
                  {
                    "value": "disabled",
                    "label": "$t:sirsoft-board.admin.form.options.secret_mode.disabled"
                  },
                  {
                    "value": "enabled",
                    "label": "$t:sirsoft-board.admin.form.options.secret_mode.enabled"
                  },
                  {
                    "value": "always",
                    "label": "$t:sirsoft-board.admin.form.options.secret_mode.always"
                  }
                ],
                "className": "w-48"
              }
            }
          ]
        },
        {
          "id": "field_show_view_count",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start justify-between"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-heading"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.show_view_count"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.form.descriptions.show_view_count"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Toggle",
              "props": {
                "name": "show_view_count",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "flex-shrink-0 ml-4"
              }
            }
          ]
        },
        {
          "id": "field_use_report",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start justify-between"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-heading"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.use_report"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.form.descriptions.use_report"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Toggle",
              "props": {
                "name": "use_report",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "flex-shrink-0 ml-4"
              }
            }
          ]
        }
          ]
        }
      ]
}
