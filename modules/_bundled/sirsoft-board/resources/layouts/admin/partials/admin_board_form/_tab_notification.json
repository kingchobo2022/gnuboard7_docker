{
  "meta": {
    "is_partial": true,
    "description": "Board Form - Notification Tab Content"
  },
  "id": "section_notification_card",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "id": "section_notification",
      "type": "basic",
      "name": "H3",
      "props": {
        "className": "card-title"
      },
      "text": "$t:sirsoft-board.admin.form.tabs.notification"
    },
    {
      "id": "section_notification_fields",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "row-stack"
      },
      "children": [
        {
          "id": "notify_author_toggle",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start justify-between"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-heading"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.notify_author.label"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.notify_author.description"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Toggle",
              "props": {
                "name": "notify_author",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "flex-shrink-0 ml-4"
              }
            }
          ]
        },
        {
          "id": "notify_admin_on_post_toggle",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start justify-between"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-heading"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.notify_admin_on_post.label"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.notify_admin_on_post.description"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Toggle",
              "props": {
                "name": "notify_admin_on_post",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "flex-shrink-0 ml-4"
              }
            }
          ]
        }
      ]
    }
  ]
}
