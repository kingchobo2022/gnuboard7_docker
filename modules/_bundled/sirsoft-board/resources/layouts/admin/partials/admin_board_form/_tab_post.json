                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "max_file_size",
                    "placeholder": "$t:sirsoft-board.admin.form.fields.max_file_size.placeholder",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": ""
                  }
                },
                {
                  "id": "max_file_size_hint",
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.max_file_size.hint|maxMB={{board_config?.data?.limits?.max_file_size_max ?? 200}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.max_file_size}}",
                  "props": {
                    "className": "form-error-xs mt-1"
                  },
                  "text": "{{_local.errors?.max_file_size?.[0] ?? ''}}"
                }
              ]
            }
          ]
        },
        {
          "id": "allowed_extensions_field",
          "type": "basic",
          "name": "Div",
          "if": "{{_local.form.use_file_upload}}",
          "props": {
            "className": ""
          },
          "children": [
            {
              "id": "allowed_extensions_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.form.fields.allowed_extensions.label"
                }
              ]
            },
            {
              "id": "allowed_extensions_input",
              "type": "composite",
              "name": "TagInput",
              "props": {
                "name": "allowed_extensions",
                "placeholder": "$t:sirsoft-board.admin.form.fields.allowed_extensions.placeholder",
                "creatable": true,
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "id": "allowed_extensions_description",
              "type": "basic",
              "name": "P",
              "props": {
                "className": "form-hint"
              },
              "text": "$t:sirsoft-board.admin.form.fields.allowed_extensions.description"
            }
          ]
        }
      ]
    }
  ]
}
