{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 일괄 적용 확인 모달"
  },
  "id": "bulk_apply_confirm_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-board.admin.settings.bulk_apply_modal.title",
    "size": "lg"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "comment": "저장/되돌릴수없음 경고 배너",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "alert-warning"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "text-amber-600 dark:text-amber-400 flex-shrink-0",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-warning-soft"
              },
              "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.message"
            }
          ]
        },
        {
          "comment": "권한 항목 선택 시 안내 배너",
          "type": "basic",
          "name": "Div",
          "if": "{{(function() { const fields = _global.bulkApplySnapshot?.fields ?? []; return fields.some(f => f.includes('.') || f === 'manager'); })()}}",
          "props": {
            "className": "alert-info"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "circle-info",
                "className": "text-blue-600 dark:text-blue-400 flex-shrink-0",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-info-soft"
              },
              "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.permission_notice"
            }
          ]
        },
        {
          "comment": "선택된 항목 목록 (섹션별 그루핑)",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "toggle-group"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "px-4 py-2.5 bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700 flex-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "list-check",
                    "size": "sm",
                    "className": "text-gray-500 dark:text-gray-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-body font-medium"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.selected_fields"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "inline-flex items-center justify-center min-w-5 h-5 px-1.5 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 text-xs font-bold rounded-full"
                  },
                  "text": "{{(_global.bulkApplySnapshot?.fields ?? []).length}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "max-h-48 overflow-y-auto"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{!(_global.bulkApplySnapshot?.fields ?? []).length}}",
                  "props": {
                    "className": "block p-3 text-sm text-gray-400 dark:text-gray-500 italic"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.no_fields"
                },
                {
                  "comment": "섹션별 그루핑 iteration",
                  "type": "basic",
                  "name": "Div",
                  "iteration": {
                    "source": "(function() { const fields = _global.bulkApplySnapshot?.fields ?? []; const sectionMap = { type:'basic', show_view_count:'basic', secret_mode:'basic', use_comment:'basic', use_reply:'basic', use_report:'basic', per_page:'list', per_page_mobile:'list', order_by:'list', order_direction:'list', min_title_length:'post', max_title_length:'post', min_content_length:'post', max_content_length:'post', max_reply_depth:'post', blocked_keywords:'post', new_display_hours:'post', comment_order:'comment', min_comment_length:'comment', max_comment_length:'comment', max_comment_depth:'comment', use_file_upload:'attachment', max_file_size:'attachment', max_file_count:'attachment', allowed_extensions:'attachment', notify_admin_on_post:'notification', notify_author:'notification', manager:'permissions' }; const sectionOrder = ['basic','list','post','comment','attachment','notification','permissions']; const grouped = {}; fields.forEach(k => { const sk = k.includes('.') ? 'permissions' : (sectionMap[k] ?? 'basic'); if (!grouped[sk]) grouped[sk] = []; grouped[sk].push(k); }); return sectionOrder.filter(sk => grouped[sk]).map(sk => ({ sectionKey: sk, items: grouped[sk] })); })()",
                    "item_var": "sectionGroup"
                  },
                  "props": {
                    "className": "border-b border-gray-100 dark:border-gray-700/50 last:border-b-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "px-3 py-1.5 bg-gray-100 dark:bg-gray-700"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wide"
                          },
                          "text": "$t:sirsoft-board.admin.settings.sections.{{sectionGroup.sectionKey}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "px-3 py-2 flex flex-wrap gap-1.5"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "iteration": {
                            "source": "sectionGroup.items",
                            "item_var": "fieldKey"
                          },
                          "props": {
                            "className": "inline-flex items-center px-2 py-0.5 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 text-xs rounded"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{!fieldKey.includes('.') && fieldKey !== 'manager'}}",
                              "text": "$t:sirsoft-board.admin.settings.bulk_apply.field_labels.{{fieldKey}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{fieldKey.includes('.') || fieldKey === 'manager'}}",
                              "text": "$t:sirsoft-board.board.permissions.{{fieldKey}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "선택된 게시판 목록 (전체/선택 무관 항상 표시)",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "toggle-group"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "px-4 py-2.5 bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700 flex-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "table-columns",
                    "size": "sm",
                    "className": "text-gray-500 dark:text-gray-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-body font-medium"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.selected_boards"
                },
                {
                  "comment": "선택 게시판 개수 배지",
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_global.bulkApplySnapshot?.applyAll === false}}",
                  "props": {
                    "className": "inline-flex items-center justify-center min-w-5 h-5 px-1.5 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 text-xs font-bold rounded-full"
                  },
                  "text": "{{(_global.bulkApplySnapshot?.boardIds ?? []).length}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "p-3 flex flex-wrap gap-1.5 min-h-12"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_global.bulkApplySnapshot?.applyAll !== false}}",
                  "props": {
                    "className": "text-label-subtle italic"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.all_boards"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_global.bulkApplySnapshot?.applyAll === false && !(_global.bulkApplySnapshot?.boardIds ?? []).length}}",
                  "props": {
                    "className": "text-sm text-gray-400 dark:text-gray-500 italic"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.no_boards"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_global.bulkApplySnapshot?.applyAll === false}}",
                  "iteration": {
                    "source": "(_global.bulkApplySnapshot?.boardIds ?? []).map(id => { const opt = ($parent._computed.boardOptions ?? []).find(o => o.value == id); return opt ? opt.label : id; })",
                    "item_var": "boardName"
                  },
                  "props": {
                    "className": "inline-flex items-center gap-1 px-2 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs font-medium rounded-full"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{boardName}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "저장 실패 에러 표시",
          "type": "basic",
          "name": "Div",
          "if": "{{$parent._local.bulkApplySaveError}}",
          "props": {
            "className": "alert-danger text-red-600 dark:text-red-400"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "circle-exclamation",
                "className": "flex-shrink-0",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.save_error"
            }
          ]
        },
        {
          "comment": "일괄 적용 중단(전체 롤백) 안내 - rolled_back 응답 시 모달 미닫힘 + 오류(red) 박스",
          "type": "basic",
          "name": "Div",
          "if": "{{$parent._local.bulkApplyAborted}}",
          "props": {
            "className": "alert-danger"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "circle-exclamation",
                "className": "text-red-600 dark:text-red-400 flex-shrink-0",
                "size": "sm"
              }
            },
            {
              "comment": "권한 실패(board 있음) — 게시판명을 굵게 강조 + suffix 문구",
              "type": "basic",
              "name": "Span",
              "if": "{{$parent._local.bulkApplyAbortedBoard}}",
              "props": {
                "className": "text-red-700 dark:text-red-300"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "font-bold"
                  },
                  "text": "{{$parent._local.bulkApplyAbortedBoard}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.aborted_message_suffix"
                }
              ]
            },
            {
              "comment": "컬럼 등 기타 실패(board null) — generic 문구",
              "type": "basic",
              "name": "Span",
              "if": "{{!$parent._local.bulkApplyAbortedBoard}}",
              "props": {
                "className": "text-red-700 dark:text-red-300"
              },
              "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.aborted_message_generic"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "disabled": "{{$parent._local.isBulkApplying}}",
                "className": "btn btn-secondary disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "closeModal"
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:common.cancel"
                }
              ]
            },
            {
              "id": "bulk_apply_confirm_button",
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "disabled": "{{$parent._local.isBulkApplying || !(_global.bulkApplySnapshot?.fields ?? []).length || (_global.bulkApplySnapshot?.applyAll === false && !(_global.bulkApplySnapshot?.boardIds ?? []).length)}}",
                "className": "flex-center gap-1.5 px-4 py-2 bg-amber-600 dark:bg-amber-700 text-white rounded-lg hover:bg-amber-700 dark:hover:bg-amber-600 font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "comment": "스냅샷은 모달 열기 전(탭 버튼 클릭 시) 이미 _global에 저장됨 - 여기서는 진행 상태 변경 + 직전 롤백 안내 초기화(재시도 대비)",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "isBulkApplying": true,
                        "bulkApplySaveError": false,
                        "bulkApplyAborted": false,
                        "bulkApplyAbortedBoard": null
                      }
                    },
                    {
                      "handler": "apiCall",
                      "auth_required": true,
                      "target": "/api/modules/sirsoft-board/admin/settings",
                      "params": {
                        "method": "PUT",
                        "body": "{{(function() { const snap = _global.bulkApplySnapshot || {}; const tab = snap.tab || 'basic_defaults'; const form = snap.form || {}; if (tab === 'report_policy') { return { _tab: 'report_policy', report_policy: form.report_policy || {} }; } if (tab === 'spam_security') { return { _tab: 'spam_security', spam_security: form.spam_security || {} }; } return { _tab: 'basic_defaults', basic_defaults: form.basic_defaults || {}, notifications: form.notifications || {} }; })()}}"
                      },
                      "onSuccess": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "hasChanges": false
                          }
                        },
                        {
                          "handler": "apiCall",
                          "auth_required": true,
                          "target": "/api/modules/sirsoft-board/admin/settings/bulk-apply",
                          "params": {
                            "method": "POST",
                            "body": "{{(function() { const snap = _global.bulkApplySnapshot || {}; return { fields: snap.fields ?? [], apply_all: snap.applyAll !== false, board_ids: snap.applyAll !== false ? [] : (snap.boardIds ?? []) }; })()}}"
                          },
                          "onSuccess": [
                            {
                              "comment": "성공/롤백 공통 — 진행 상태 해제",
                              "handler": "setState",
                              "params": {
                                "target": "$parent._local",
                                "isBulkApplying": false
                              }
                            },
                            {
                              "comment": "성공(rolled_back=false): 적용 완료 → 상태 초기화 + 스냅샷 정리 + 모달 닫고 success 토스트",
                              "handler": "setState",
                              "if": "{{!response?.data?.rolled_back}}",
                              "params": {
                                "target": "$parent._local",
                                "bulkApplyFields": [],
                                "bulkApplyAll": true,
                                "bulkApplyAborted": false,
                                "bulkApplyAbortedBoard": null
                              }
                            },
                            {
                              "handler": "setState",
                              "if": "{{!response?.data?.rolled_back}}",
                              "params": {
                                "target": "global",
                                "bulkApplySnapshot": null
                              }
                            },
                            {
                              "handler": "closeModal",
                              "if": "{{!response?.data?.rolled_back}}"
                            },
                            {
                              "handler": "toast",
                              "if": "{{!response?.data?.rolled_back}}",
                              "params": {
                                "type": "success",
                                "message": "$t:sirsoft-board.admin.settings.bulk_apply_modal.success|count={{response?.data?.updated_count ?? 0}}"
                              }
                            },
                            {
                              "comment": "롤백(rolled_back=true): 전체 취소됨 → 모달 유지 + 안내 박스 표시(board 유무로 문구 분기) + warning 토스트",
                              "handler": "setState",
                              "if": "{{response?.data?.rolled_back}}",
                              "params": {
                                "target": "$parent._local",
                                "bulkApplyAborted": true,
                                "bulkApplyAbortedBoard": "{{response?.data?.board?.name ?? null}}"
                              }
                            },
                            {
                              "handler": "toast",
                              "if": "{{response?.data?.rolled_back}}",
                              "params": {
                                "type": "error",
                                "message": "$t:sirsoft-board.admin.settings.bulk_apply_modal.aborted_toast"
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "$parent._local",
                                "isBulkApplying": false
                              }
                            },
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "bulkApplySnapshot": null
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "error",
                                "message": "$t:sirsoft-board.admin.settings.bulk_apply_modal.error"
                              }
                            }
                          ]
                        }
                      ],
                      "onError": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "isBulkApplying": false,
                            "bulkApplySaveError": true
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "bulkApplySnapshot": null
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{$parent._local.isBulkApplying}}",
                  "props": {
                    "name": "spinner",
                    "className": "spinner-sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{!$parent._local.isBulkApplying}}",
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.confirm"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{$parent._local.isBulkApplying}}",
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply_modal.processing"
                }
              ]
            }
          ]
        }
      ],
      "props": {
        "className": "flex flex-col gap-4 pt-2"
      }
    }
  ]
}
