{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 > 첨부파일 탭"
  },
  "id": "attachment",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'basic_defaults'}}",
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "id": "section_attachment",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.attachment"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "field_use_file_upload",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-heading flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('use_file_upload')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('use_file_upload') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'use_file_upload') : [...(_local.bulkApplyFields ?? []), 'use_file_upload']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.use_file_upload"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.use_file_upload"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "name": "basic_defaults.use_file_upload",
                        "className": "flex-shrink-0",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_max_file_size",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('max_file_size')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('max_file_size') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'max_file_size') : [...(_local.bulkApplyFields ?? []), 'max_file_size']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.max_file_size"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.max_file_size|min={{_local?.form?._meta?.limits?.max_file_size_min ?? 1}}|max={{_local?.form?._meta?.limits?.max_file_size_max ?? 200}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "basic_defaults.max_file_size",
                            "min": "{{_local?.form?._meta?.limits?.max_file_size_min ?? 1}}",
                            "max": "{{_local?.form?._meta?.limits?.max_file_size_max ?? 200}}",
                            "className": "{{(_local.errors?.['basic_defaults.max_file_size']) ? 'w-32 input-error' : 'w-32'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.['basic_defaults.max_file_size']}}",
                          "props": {
                            "className": "text-xs text-red-600 dark:text-red-400 block mt-1"
                          },
                          "text": "{{(Array.isArray(_local.errors?.['basic_defaults.max_file_size']) ? _local.errors['basic_defaults.max_file_size'][0] : _local.errors?.['basic_defaults.max_file_size']) ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_max_file_count",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('max_file_count')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('max_file_count') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'max_file_count') : [...(_local.bulkApplyFields ?? []), 'max_file_count']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.max_file_count"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.max_file_count|min={{_local?.form?._meta?.limits?.max_file_count_min ?? 1}}|max={{_local?.form?._meta?.limits?.max_file_count_max ?? 20}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "basic_defaults.max_file_count",
                            "min": "{{_local?.form?._meta?.limits?.max_file_count_min ?? 1}}", 
                            "max": "{{_local?.form?._meta?.limits?.max_file_count_max ?? 20}}",
                            "className": "{{(_local.errors?.['basic_defaults.max_file_count']) ? 'w-32 input-error' : 'w-32'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.['basic_defaults.max_file_count']}}",
                          "props": {
                            "className": "text-xs text-red-600 dark:text-red-400 block mt-1"
                          },
                          "text": "{{(Array.isArray(_local.errors?.['basic_defaults.max_file_count']) ? _local.errors['basic_defaults.max_file_count'][0] : _local.errors?.['basic_defaults.max_file_count']) ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_allowed_extensions",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "px-3 py-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium cursor-pointer mb-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('allowed_extensions')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('allowed_extensions') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'allowed_extensions') : [...(_local.bulkApplyFields ?? []), 'allowed_extensions']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.allowed_extensions"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.allowed_extensions"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "TagInput",
                      "props": {
                        "name": "basic_defaults.allowed_extensions",
                        "placeholder": "$t:sirsoft-board.admin.settings.fields.allowed_extensions_placeholder",
                        "creatable": true,
                        "className": "w-full",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
