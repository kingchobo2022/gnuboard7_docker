{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 > 기본 탭 (기본 설정 + 일괄 적용)"
  },
  "id": "basic",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'basic_defaults'}}",
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "comment": "========== 섹션 1: 기본 설정 ==========",
      "id": "section_basic",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.basic"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.basic_description"
        },
        {
          "comment": "========== 페이지 안내 배너 ==========",
          "id": "page_info_banner",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "alert-info"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "circle-info",
                "className": "text-blue-500 dark:text-blue-400 flex-shrink-0 mt-0.5",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-info-soft"
              },
              "text": "$t:sirsoft-board.admin.settings.page_info"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "field_type",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-center gap-2"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Label",
                              "props": {
                                "className": "flex-center gap-2 text-heading cursor-pointer"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Input",
                                  "props": {
                                    "type": "checkbox",
                                    "className": "checkbox flex-shrink-0",
                                    "checked": "{{(_local.bulkApplyFields ?? []).includes('type')}}"
                                  },
                                  "actions": [
                                    {
                                      "type": "change",
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('type') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'type') : [...(_local.bulkApplyFields ?? []), 'type']}}"
                                      }
                                    }
                                  ]
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "text": "$t:sirsoft-board.admin.settings.fields.type"
                                }
                              ]
                            },
                            {
                              "id": "settings_btn_manage_board_types",
                              "type": "basic",
                              "name": "Button",
                              "props": {
                                "type": "button",
                                "variant": "ghost",
                                "size": "sm",
                                "className": "inline-flex items-center gap-1 text-xs rounded-full px-2.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600",
                                "disabled": "{{_computed.isReadOnly}}"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Icon",
                                  "props": {
                                    "name": "gear",
                                    "size": "sm"
                                  }
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "text": "$t:sirsoft-board.admin.board_types.manage"
                                }
                              ],
                              "actions": [
                                {
                                  "type": "click",
                                  "handler": "sequence",
                                  "actions": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "global",
                                        "btFormMode": "add",
                                        "btEditingItem": null,
                                        "btFormSlug": "",
                                        "btFormName": {
                                          "ko": "",
                                          "en": ""
                                        }
                                      }
                                    },
                                    {
                                      "handler": "apiCall",
                                      "auth_required": true,
                                      "target": "/api/modules/sirsoft-board/admin/board-types",
                                      "params": {
                                        "method": "GET"
                                      },
                                      "onSuccess": [
                                        {
                                          "handler": "setState",
                                          "params": {
                                            "target": "global",
                                            "boardTypesList": "{{response.data}}"
                                          }
                                        },
                                        {
                                          "handler": "openModal",
                                          "target": "board_type_manage_modal"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-field-hint pl-6"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.descriptions.type"
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Select",
                      "props": {
                        "name": "basic_defaults.type",
                        "options": "{{board_types?.data?.map(t => ({value: t.slug, label: (t.name[_global.locale ?? $locale ?? 'ko'] ?? t.name.ko ?? t.slug) + ' (' + t.slug + ')'})) ?? []}}",
                        "className": "w-48 flex-shrink-0 text-sm",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_secret_mode",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-heading flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('secret_mode')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('secret_mode') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'secret_mode') : [...(_local.bulkApplyFields ?? []), 'secret_mode']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.secret_mode"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.secret_mode"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Select",
                      "props": {
                        "name": "basic_defaults.secret_mode",
                        "options": [
                          {
                            "value": "disabled",
                            "label": "$t:sirsoft-board.admin.settings.options.secret_mode.disabled"
                          },
                          {
                            "value": "enabled",
                            "label": "$t:sirsoft-board.admin.settings.options.secret_mode.enabled"
                          },
                          {
                            "value": "always",
                            "label": "$t:sirsoft-board.admin.settings.options.secret_mode.always"
                          }
                        ],
                        "className": "w-48 flex-shrink-0 text-sm",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_show_view_count",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-heading flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('show_view_count')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('show_view_count') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'show_view_count') : [...(_local.bulkApplyFields ?? []), 'show_view_count']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.show_view_count"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.show_view_count"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "name": "basic_defaults.show_view_count",
                        "className": "flex-shrink-0",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_use_report",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-heading flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('use_report')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('use_report') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'use_report') : [...(_local.bulkApplyFields ?? []), 'use_report']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.use_report"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.use_report"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "name": "basic_defaults.use_report",
                        "className": "flex-shrink-0",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
