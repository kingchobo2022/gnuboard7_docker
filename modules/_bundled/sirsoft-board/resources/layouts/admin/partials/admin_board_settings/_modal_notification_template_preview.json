{
  "meta": {
    "is_partial": true,
    "description": "게시판 메일 템플릿 미리보기 모달"
  },
  "id": "modal_board_notification_template_preview",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-board.admin.settings.notification_definitions.preview_modal.title",
    "size": "lg"
  },
  "children": [
    {
      "id": "board_preview_content",
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-table-header"
              },
              "text": "$t:sirsoft-board.admin.settings.notification_definitions.preview_modal.subject_label"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-primary text-base font-medium bg-gray-50 dark:bg-gray-900 rounded-md px-3"
              },
              "text": "{{_global.board_notification_template_form_modal?.preview?.subject ?? ''}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-table-header"
              },
              "text": "$t:sirsoft-board.admin.settings.notification_definitions.preview_modal.body_label"
            },
            {
              "type": "composite",
              "name": "HtmlContent",
              "props": {
                "content": "{{_global.board_notification_template_form_modal?.preview?.body ?? ''}}",
                "isHtml": true,
                "className": "prose dark:prose-invert prose-sm max-w-none border border-gray-200 dark:border-gray-700 rounded-md p-4 max-h-[400px] overflow-y-auto bg-white dark:bg-gray-900"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end border-t border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "id": "board_btn_close_preview",
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "text-body px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors"
              },
              "text": "$t:common.close",
              "actions": [
                {
                  "type": "click",
                  "handler": "closeModal",
                  "target": "modal_board_notification_template_preview"
                }
              ]
            }
          ]
        }
      ],
      "props": {
      }
    }
  ]
}
