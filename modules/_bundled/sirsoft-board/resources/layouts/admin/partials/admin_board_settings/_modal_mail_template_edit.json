{
  "meta": {
    "is_partial": true,
    "description": "게시판 메일 템플릿 편집 모달"
  },
  "id": "modal_board_mail_template_edit",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.title",
    "size": "xl",
    "closeOnOverlayClick": false
  },
  "children": [
    {
      "id": "board_edit_form_container",
      "type": "basic",
      "name": "Div",
      "blur_until_loaded": "{{$parent._local.isSaving}}",
      "props": {
        "className": "flex flex-col max-h-[70vh]"
      },
      "classMap": {
        "key": "{{$parent._computed.isReadOnly ? 'readonly' : 'normal'}}",
        "variants": {
          "readonly": "opacity-60",
          "normal": ""
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-1 overflow-y-auto space-y-5 pr-1"
          },
          "children": [
            {
              "id": "board_validation_error_banner",
              "type": "basic",
              "name": "Div",
              "if": "{{$parent._local.templateErrors}}",
              "props": {
                "className": "alert-danger"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "triangle-exclamation",
                        "size": "sm",
                        "className": "text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "H3",
                          "props": {
                            "className": "text-error-strong"
                          },
                          "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.validation_error"
                        },
                        {
                          "type": "basic",
                          "name": "Ul",
                          "if": "{{typeof $parent._local.templateErrors === 'object' && Object.keys($parent._local.templateErrors).length > 0}}",
                          "props": {
                            "className": "mt-2 list-disc list-inside space-y-1"
                          },
                          "iteration": {
                            "source": "Object.entries($parent._local.templateErrors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                            "item_var": "errMsg"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Li",
                              "props": {
                                "className": "text-error-soft"
                              },
                              "text": "{{errMsg}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 mb-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-label-subtle font-medium"
                  },
                  "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.type_label"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary text-sm font-semibold"
                  },
                  "text": "$t:sirsoft-board.admin.settings.mail_templates.types.{{$parent._local.editingTemplate?.type ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-tertiary font-mono px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 rounded"
                  },
                  "text": "{{$parent._local.editingTemplate?.type ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex border-b border-gray-200 dark:border-gray-700"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "{{($parent._local.editLang ?? $locale) === 'ko' ? 'border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'}} px-4 py-2 text-sm font-medium focus:outline-none"
                  },
                  "text": "한국어",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editLang": "ko"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "{{($parent._local.editLang ?? $locale) === 'en' ? 'border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'}} px-4 py-2 text-sm font-medium focus:outline-none"
                  },
                  "text": "English",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editLang": "en"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "board_edit_subject_ko",
              "type": "basic",
              "name": "Div",
              "if": "{{($parent._local.editLang ?? $locale) === 'ko'}}",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.subject"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-required"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "value": "{{$parent._local.editingTemplate?.subject?.ko ?? ''}}",
                        "className": "{{$parent._local.templateErrors?.['subject.ko'] ? 'input-error' : ''}}",
                        "disabled": "{{$parent._computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "editingTemplate.subject.ko": "{{$event.target.value}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{$parent._local.templateErrors?.['subject.ko']}}",
                      "props": {
                        "className": "form-error-xs"
                      },
                      "text": "{{$parent._local.templateErrors?.['subject.ko']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "board_edit_subject_en",
              "type": "basic",
              "name": "Div",
              "if": "{{($parent._local.editLang ?? $locale) === 'en'}}",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.subject"
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "value": "{{$parent._local.editingTemplate?.subject?.en ?? ''}}",
                        "className": "{{$parent._local.templateErrors?.['subject.en'] ? 'input-error' : ''}}",
                        "disabled": "{{$parent._computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "editingTemplate.subject.en": "{{$event.target.value}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{$parent._local.templateErrors?.['subject.en']}}",
                      "props": {
                        "className": "form-error-xs"
                      },
                      "text": "{{$parent._local.templateErrors?.['subject.en']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "board_edit_body_ko",
              "type": "basic",
              "name": "Div",
              "if": "{{($parent._local.editLang ?? $locale) === 'ko'}}",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.body"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-required"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "HtmlEditor",
                      "props": {
                        "content": "{{$parent._local.editingTemplate?.body?.ko ?? ''}}",
                        "isHtml": true,
                        "showHtmlModeToggle": false,
                        "className": "{{$parent._local.templateErrors?.['body.ko'] ? 'min-h-[200px] border border-red-500 rounded-md' : 'min-h-[200px]'}}",
                        "disabled": "{{$parent._computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "editingTemplate.body.ko": "{{$event.target.value}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{$parent._local.templateErrors?.['body.ko']}}",
                      "props": {
                        "className": "form-error-xs"
                      },
                      "text": "{{$parent._local.templateErrors?.['body.ko']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "board_edit_body_en",
              "type": "basic",
              "name": "Div",
              "if": "{{($parent._local.editLang ?? $locale) === 'en'}}",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.body"
                    },
                    {
                      "type": "composite",
                      "name": "HtmlEditor",
                      "props": {
                        "content": "{{$parent._local.editingTemplate?.body?.en ?? ''}}",
                        "isHtml": true,
                        "showHtmlModeToggle": false,
                        "className": "{{$parent._local.templateErrors?.['body.en'] ? 'min-h-[200px] border border-red-500 rounded-md' : 'min-h-[200px]'}}",
                        "disabled": "{{$parent._computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "editingTemplate.body.en": "{{$event.target.value}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{$parent._local.templateErrors?.['body.en']}}",
                      "props": {
                        "className": "form-error-xs"
                      },
                      "text": "{{$parent._local.templateErrors?.['body.en']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "board_edit_is_active_toggle",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-3"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Toggle",
                  "props": {
                    "name": "boardTemplateIsActive",
                    "checked": "{{$parent._local.editingTemplate?.is_active ?? true}}",
                    "disabled": "{{$parent._computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editingTemplate.is_active": "{{$event.target.checked}}"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-body"
                  },
                  "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.is_active_label"
                }
              ]
            },
            {
              "id": "board_edit_variables_info",
              "type": "basic",
              "name": "Div",
              "if": "{{($parent._local.editingTemplate?.variables ?? []).length > 0}}",
              "props": {
                "className": "bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-md p-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "H4",
                  "props": {
                    "className": "text-body font-medium mb-2"
                  },
                  "text": "$t:sirsoft-board.admin.settings.mail_templates.edit_modal.variables_title"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-wrap gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "iteration": {
                        "source": "{{$parent._local.editingTemplate?.variables ?? []}}",
                        "item_var": "v",
                        "index_var": "vi"
                      },
                      "props": {
                        "className": "inline-flex items-center gap-1 text-xs px-2 py-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded text-gray-700 dark:text-gray-300"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{{v.key}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "} - {{v.description ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "board_edit_modal_footer",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "modal-footer-buttons items-center px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg sticky bottom-0"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex gap-2"
              },
              "children": [
                {
                  "id": "board_btn_cancel_edit",
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "text-body px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{$parent._local.isSaving ?? false}}"
                  },
                  "text": "$t:common.cancel",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "closeModal",
                      "target": "modal_board_mail_template_edit"
                    }
                  ]
                },
                {
                  "id": "board_btn_save_template",
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "flex-center gap-2 text-sm px-4 py-2 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{$parent._computed.isReadOnly || $parent._local.isSaving ?? false}}"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{$parent._local.isSaving}}",
                      "props": {
                        "name": "spinner",
                        "className": "animate-spin",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{$parent._local.isSaving ? '$t:common.saving' : '$t:common.save'}}"
                    }
                  ],
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "isSaving": true,
                            "templateErrors": null
                          }
                        },
                        {
                          "handler": "apiCall",
                          "auth_required": true,
                          "target": "{{'/api/modules/sirsoft-board/admin/mail-templates/' + $parent._local.editingTemplate?.id}}",
                          "params": {
                            "method": "PUT",
                            "body": "{{(function() { const tpl = $parent._local.editingTemplate ?? {}; return { subject: tpl.subject ?? {}, body: tpl.body ?? {}, is_active: tpl.is_active ?? true }; })()}}"
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "$parent._local",
                                "isSaving": false,
                                "templateErrors": null,
                                "editingTemplate": null
                              }
                            },
                            {
                              "handler": "closeModal",
                              "target": "modal_board_mail_template_edit"
                            },
                            {
                              "handler": "navigate",
                              "params": {
                                "path": "/admin/boards/settings",
                                "replace": true,
                                "mergeQuery": true,
                                "query": {}
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "message": "$t:sirsoft-board.admin.settings.mail_templates.save_success",
                                "type": "success"
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "$parent._local",
                                "isSaving": false,
                                "templateErrors": "{{error.errors}}"
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "message": "$t:sirsoft-board.admin.settings.mail_templates.save_error",
                                "type": "error"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
