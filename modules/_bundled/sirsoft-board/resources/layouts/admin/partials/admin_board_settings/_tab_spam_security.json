{
  "meta": {
    "is_partial": true,
    "description": "게시판 환경설정 스팸/보안 탭 콘텐츠"
  },
  "id": "tab_content_spam_security",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'spam_security'}}",
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "comment": "========== 섹션: 쿨다운 ==========",
          "id": "section_cooldown",
          "type": "layout",
          "name": "SectionLayout",
          "props": {
            "className": "admin-card"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "card-title"
              },
              "text": "$t:sirsoft-board.admin.settings.sections.spam_security"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "row-stack"
              },
              "children": [
                {
                  "id": "field_post_cooldown_seconds",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.post_cooldown_seconds"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "spam_security.post_cooldown_seconds",
                        "min": 0,
                        "max": 3600,
                        "className": "{{(_local.errors?.['spam_security.post_cooldown_seconds']) ? 'input-error' : ''}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['spam_security.post_cooldown_seconds']}}",
                      "props": {
                        "className": "text-xs text-red-600 dark:text-red-400 block"
                      },
                      "text": "{{(Array.isArray(_local.errors?.['spam_security.post_cooldown_seconds']) ? _local.errors['spam_security.post_cooldown_seconds'][0] : _local.errors?.['spam_security.post_cooldown_seconds']) ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-tertiary block"
                      },
                      "text": "$t:sirsoft-board.admin.settings.fields.post_cooldown_seconds_hint"
                    }
                  ]
                },
                {
                  "id": "field_comment_cooldown_seconds",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.comment_cooldown_seconds"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "spam_security.comment_cooldown_seconds",
                        "min": 0,
                        "max": 3600,
                        "className": "{{(_local.errors?.['spam_security.comment_cooldown_seconds']) ? 'input-error' : ''}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['spam_security.comment_cooldown_seconds']}}",
                      "props": {
                        "className": "text-xs text-red-600 dark:text-red-400 block"
                      },
                      "text": "{{(Array.isArray(_local.errors?.['spam_security.comment_cooldown_seconds']) ? _local.errors['spam_security.comment_cooldown_seconds'][0] : _local.errors?.['spam_security.comment_cooldown_seconds']) ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-tertiary block"
                      },
                      "text": "$t:sirsoft-board.admin.settings.fields.comment_cooldown_seconds_hint"
                    }
                  ]
                },
                {
                  "id": "field_view_count_cache_ttl",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "form-label"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.view_count_cache_ttl"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "spam_security.view_count_cache_ttl",
                            "min": 60,
                            "max": 604800,
                            "className": "{{(_local.errors?.['spam_security.view_count_cache_ttl']) ? 'input-error' : ''}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.['spam_security.view_count_cache_ttl']}}",
                          "props": {
                            "className": "text-xs text-red-600 dark:text-red-400 block"
                          },
                          "text": "{{(Array.isArray(_local.errors?.['spam_security.view_count_cache_ttl']) ? _local.errors['spam_security.view_count_cache_ttl'][0] : _local.errors?.['spam_security.view_count_cache_ttl']) ?? ''}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-tertiary block"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.view_count_cache_ttl_hint"
                        }
                      ],
                      "props": {
                      }
                    }
                  ],
                  "props": {
                    "className": ""
                  }
                }
              ]
            },
            {
              "id": "spam_security_identifier_info",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "alert-info"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "circle-info",
                        "className": "text-blue-600 dark:text-blue-400 flex-shrink-0",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-info-soft"
                      },
                      "text": "$t:sirsoft-board.admin.settings.fields.spam_security_identifier_info"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "========== 섹션: 캐시 초기화 ==========",
          "id": "section_cache",
          "type": "layout",
          "name": "SectionLayout",
          "props": {
            "className": "admin-card"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-between"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "H3",
                      "text": "$t:sirsoft-board.admin.settings.fields.clear_cache"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "text": "$t:sirsoft-board.admin.settings.fields.clear_cache_description"
                    }
                  ],
                  "props": {
                    "className": "section-header"
                  }
                },
                {
                  "id": "clear_cache_button",
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "disabled": "{{_computed.isReadOnly || _local.isClearingCache}}",
                    "className": "flex-center gap-1.5 px-4 py-2 bg-red-600 dark:bg-red-700 text-white rounded-lg hover:bg-red-700 dark:hover:bg-red-600 font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isClearingCache": true
                          }
                        },
                        {
                          "handler": "apiCall",
                          "auth_required": true,
                          "target": "/api/modules/sirsoft-board/admin/settings/clear-cache",
                          "params": {
                            "method": "POST"
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isClearingCache": false
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "success",
                                "message": "$t:sirsoft-board.admin.settings.fields.clear_cache_success"
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isClearingCache": false
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "error",
                                "message": "$t:sirsoft-board.admin.settings.fields.clear_cache_error"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{_local.isClearingCache}}",
                      "props": {
                        "name": "spinner",
                        "className": "animate-spin",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{!_local.isClearingCache}}",
                      "props": {
                        "name": "trash-can",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.settings.fields.clear_cache"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "props": {
      }
    }
  ]
}
