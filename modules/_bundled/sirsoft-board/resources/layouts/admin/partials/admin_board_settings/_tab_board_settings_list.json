{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 > 목록 탭"
  },
  "id": "list",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'basic_defaults'}}",
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "id": "section_list",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.list"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "field_order_by",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('order_by')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('order_by') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'order_by') : [...(_local.bulkApplyFields ?? []), 'order_by']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.order_by"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.order_by"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Select",
                      "props": {
                        "name": "basic_defaults.order_by",
                        "options": [
                          {
                            "value": "created_at",
                            "label": "$t:sirsoft-board.admin.settings.options.order_by.created_at"
                          },
                          {
                            "value": "view_count",
                            "label": "$t:sirsoft-board.admin.settings.options.order_by.view_count"
                          },
                          {
                            "value": "title",
                            "label": "$t:sirsoft-board.admin.settings.options.order_by.title"
                          },
                          {
                            "value": "author",
                            "label": "$t:sirsoft-board.admin.settings.options.order_by.author"
                          }
                        ],
                        "className": "w-48 flex-shrink-0 text-sm",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_order_direction",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('order_direction')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('order_direction') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'order_direction') : [...(_local.bulkApplyFields ?? []), 'order_direction']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.order_direction"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.order_direction"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Select",
                      "props": {
                        "name": "basic_defaults.order_direction",
                        "options": [
                          {
                            "value": "DESC",
                            "label": "$t:sirsoft-board.admin.settings.options.order_direction.DESC"
                          },
                          {
                            "value": "ASC",
                            "label": "$t:sirsoft-board.admin.settings.options.order_direction.ASC"
                          }
                        ],
                        "className": "w-48 flex-shrink-0 text-sm",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_per_page",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('per_page')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('per_page') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'per_page') : [...(_local.bulkApplyFields ?? []), 'per_page']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.per_page"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.per_page|min={{_local?.form?._meta?.limits?.per_page_min ?? 5}}|max={{_local?.form?._meta?.limits?.per_page_max ?? 100}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "basic_defaults.per_page",
                            "min": "{{_local?.form?._meta?.limits?.per_page_min ?? 5}}",
                            "max": "{{_local?.form?._meta?.limits?.per_page_max ?? 100}}",
                            "className": "{{(_local.errors?.['basic_defaults.per_page']) ? 'w-32 input-error' : 'w-32'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.['basic_defaults.per_page']}}",
                          "props": {
                            "className": "text-xs text-red-600 dark:text-red-400 block mt-1"
                          },
                          "text": "{{(Array.isArray(_local.errors?.['basic_defaults.per_page']) ? _local.errors['basic_defaults.per_page'][0] : _local.errors?.['basic_defaults.per_page']) ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_per_page_mobile",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('per_page_mobile')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('per_page_mobile') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'per_page_mobile') : [...(_local.bulkApplyFields ?? []), 'per_page_mobile']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.per_page_mobile"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.per_page_mobile|min={{_local?.form?._meta?.limits?.per_page_min ?? 5}}|max={{_local?.form?._meta?.limits?.per_page_max ?? 100}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "basic_defaults.per_page_mobile",
                            "min": "{{_local?.form?._meta?.limits?.per_page_min ?? 5}}",
                            "max": "{{_local?.form?._meta?.limits?.per_page_max ?? 100}}",
                            "className": "{{(_local.errors?.['basic_defaults.per_page_mobile']) ? 'w-32 input-error' : 'w-32'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.['basic_defaults.per_page_mobile']}}",
                          "props": {
                            "className": "text-xs text-red-600 dark:text-red-400 block mt-1"
                          },
                          "text": "{{(Array.isArray(_local.errors?.['basic_defaults.per_page_mobile']) ? _local.errors['basic_defaults.per_page_mobile'][0] : _local.errors?.['basic_defaults.per_page_mobile']) ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
