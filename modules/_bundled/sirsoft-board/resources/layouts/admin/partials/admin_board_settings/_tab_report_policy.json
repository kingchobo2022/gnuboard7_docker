                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "if": "{{_local.errors?.['report_policy.rejection_limit_days']}}",
                                  "props": {
                                    "className": "text-xs text-red-600 dark:text-red-400 block"
                                  },
                                  "text": "{{(Array.isArray(_local.errors?.['report_policy.rejection_limit_days']) ? _local.errors['report_policy.rejection_limit_days'][0] : _local.errors?.['report_policy.rejection_limit_days']) ?? ''}}"
                                }
