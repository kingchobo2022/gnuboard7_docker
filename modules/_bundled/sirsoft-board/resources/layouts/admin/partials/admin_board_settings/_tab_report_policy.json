                          "props": {
                            "className": "block text-sm font-semibold text-gray-800 dark:text-gray-200"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.report_manage_roles"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
