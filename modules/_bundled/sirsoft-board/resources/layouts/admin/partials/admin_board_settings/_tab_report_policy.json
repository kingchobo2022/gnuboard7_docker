        {
          "comment": "========== 카드 4: 신고 처리 알림 ==========",
          "id": "section_report_notification",
          "type": "layout",
          "name": "SectionLayout",
          "props": {
            "className": "admin-card"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "card-title"
              },
              "text": "$t:sirsoft-board.admin.settings.sections.report_notification"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "card-description"
              },
              "text": "$t:sirsoft-board.admin.settings.sections.report_notification_description"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "card-stack"
              },
              "children": [
                {
                  "comment": "--- 신고 접수 관리자 알림 ---",
                  "id": "field_notify_admin_on_report",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "option-card"
                  },
                  "children": [
                    {
                      "comment": "헤더 행 (활성화 토글 제거 — 알림 정의 활성화는 알림 설정 메뉴에서 관리). padding/border 은 option-card 자산이 책임",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-start gap-4"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-1 min-w-0"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "block text-heading"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "block text-tertiary mt-0.5"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_description"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "comment": "하위 옵션 (토글 제거로 항상 표시). option-card 자산이 padding + border-t 책임",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "space-y-4"
                      },
                      "children": [
                        {
                          "id": "field_notify_admin_on_report_scope",
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "row-stack.5"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Label",
                              "props": {
                                "className": "text-tertiary"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_scope"
                            },
                            {
                              "type": "composite",
                              "name": "RadioGroup",
                              "props": {
                                "name": "report_policy.notify_admin_on_report_scope",
                                "options": [
                                  {
                                    "value": "per_case",
                                    "label": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_scope_per_case"
                                  },
                                  {
                                    "value": "per_report",
                                    "label": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_scope_per_report"
                                  }
                                ],
                                "inline": true,
                                "size": "md",
                                "disabled": "{{_computed.isReadOnly}}"
                              }
                            }
                          ]
                        },
                        {
                          "id": "field_notify_admin_on_report_channels",
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "row-stack.5"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Label",
                              "props": {
                                "className": "text-tertiary"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.report_notification_template_status_title"
                            },
                            {
                              "id": "report_received_admin_template_status",
                              "type": "basic",
                              "name": "Div",
                              "props": { "className": "space-y-2" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "iteration": {
                                    "source": "(((boardNotificationDefinitions?.data?.data ?? []).find(d => d.type === 'report_received_admin')?.templates) ?? [])",
                                    "item_var": "tpl",
                                    "index_var": "tplIndex"
                                  },
                                  "props": { "className": "flex items-center justify-between gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-700/40" },
                                  "children": [
                                    {
                                      "type": "basic",
                                      "name": "Div",
                                      "props": { "className": "flex items-center gap-2 min-w-0" },
                                      "children": [
                                        { "type": "basic", "name": "Icon", "props": { "name": "{{tpl.channel === 'mail' ? 'envelope' : 'bell'}}", "size": "sm", "className": "text-gray-400 dark:text-gray-500 flex-shrink-0" } },
                                        {
                                          "type": "basic",
                                          "name": "Div",
                                          "props": { "className": "min-w-0" },
                                          "children": [
                                            { "type": "basic", "name": "Span", "props": { "className": "block text-xs font-medium text-gray-500 dark:text-gray-400" }, "text": "{{tpl.channel === 'mail' ? $t('sirsoft-board.admin.settings.fields.notification_channels.mail') : (tpl.channel === 'database' ? $t('sirsoft-board.admin.settings.fields.notification_channels.database') : tpl.channel)}}" },
                                            { "type": "basic", "name": "Span", "props": { "className": "block text-sm text-gray-800 dark:text-gray-200 truncate" }, "text": "{{tpl.subject?.[$locale] ?? tpl.subject?.ko ?? $t('sirsoft-board.admin.settings.fields.report_notification_template_status_empty')}}" }
                                          ]
                                        }
