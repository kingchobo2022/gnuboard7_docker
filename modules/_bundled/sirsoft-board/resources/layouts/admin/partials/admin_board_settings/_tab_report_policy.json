{
  "meta": {
    "is_partial": true,
    "description": "게시판 환경설정 신고 정책 탭 콘텐츠"
  },
  "id": "tab_content_report_policy",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'report_policy'}}",
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "comment": "========== 카드 1: 자동 블라인드 처리 ==========",
          "id": "section_auto_hide",
          "type": "layout",
          "name": "SectionLayout",
          "props": {
            "className": "admin-card"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "card-title"
              },
              "text": "$t:sirsoft-board.admin.settings.sections.auto_hide"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "card-description"
              },
              "text": "$t:sirsoft-board.admin.settings.sections.auto_hide_description"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "row-stack"
              },
              "children": [
                {
                  "id": "field_auto_hide_threshold",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_threshold"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "report_policy.auto_hide_threshold",
                        "min": 1,
                        "max": 100,
                        "className": "{{(_local.errors?.['report_policy.auto_hide_threshold']) ? 'input-error' : ''}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['report_policy.auto_hide_threshold']}}",
                      "props": {
                        "className": "text-xs text-red-600 dark:text-red-400 block"
                      },
                      "text": "{{(Array.isArray(_local.errors?.['report_policy.auto_hide_threshold']) ? _local.errors['report_policy.auto_hide_threshold'][0] : _local.errors?.['report_policy.auto_hide_threshold']) ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-tertiary block"
                      },
                      "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_threshold_hint"
                    }
                  ]
                },
                {
                  "id": "field_auto_hide_target",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_target"
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Select",
                      "props": {
                        "name": "report_policy.auto_hide_target",
                        "options": [
                          {
                            "value": "post",
                            "label": "$t:sirsoft-board.admin.settings.options.auto_hide_target.post"
                          },
                          {
                            "value": "comment",
                            "label": "$t:sirsoft-board.admin.settings.options.auto_hide_target.comment"
                          },
                          {
                            "value": "both",
                            "label": "$t:sirsoft-board.admin.settings.options.auto_hide_target.both"
                          }
                        ],
                        "className": "w-full text-sm",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-tertiary block"
                      },
                      "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_target_hint"
                    }
                  ]
                }
              ]
            }
          ]
        },
