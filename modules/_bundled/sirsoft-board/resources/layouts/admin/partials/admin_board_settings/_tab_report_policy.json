                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-tertiary block"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.report_cooldown_seconds_hint"
                        }
                      ],
                      "props": {
                      }
                    }
                  ],
                  "props": {
                    "className": ""
                  }
                }
              ]
