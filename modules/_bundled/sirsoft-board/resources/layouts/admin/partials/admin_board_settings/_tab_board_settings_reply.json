{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 > 답변글 탭"
  },
  "id": "reply",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'basic_defaults'}}",
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "id": "section_reply",
          "type": "layout",
          "name": "SectionLayout",
          "props": {
            "className": "admin-card"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "card-title"
              },
              "text": "$t:sirsoft-board.admin.settings.sections.reply"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "row-stack"
              },
              "children": [
                {
                  "id": "field_use_reply",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": ""
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-4"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "flex-start gap-2 text-heading flex-1 cursor-pointer"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "checkbox",
                                "className": "checkbox-aligned",
                                "checked": "{{(_local.bulkApplyFields ?? []).includes('use_reply')}}"
                              },
                              "actions": [
                                {
                                  "type": "change",
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('use_reply') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'use_reply') : [...(_local.bulkApplyFields ?? []), 'use_reply']}}"
                                  }
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "text": "$t:sirsoft-board.admin.settings.fields.use_reply"
                                },
                                {
                                  "type": "basic",
                                  "name": "P",
                                  "props": {
                                    "className": "text-field-hint"
                                  },
                                  "text": "$t:sirsoft-board.admin.settings.fields.descriptions.use_reply"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "composite",
                          "name": "Toggle",
                          "props": {
                            "name": "basic_defaults.use_reply",
                            "className": "flex-shrink-0",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "field_max_reply_depth",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": ""
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-4"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "flex-start gap-2 text-body font-medium flex-1 cursor-pointer"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "checkbox",
                                "className": "checkbox-aligned",
                                "checked": "{{(_local.bulkApplyFields ?? []).includes('max_reply_depth')}}"
                              },
                              "actions": [
                                {
                                  "type": "change",
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('max_reply_depth') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'max_reply_depth') : [...(_local.bulkApplyFields ?? []), 'max_reply_depth']}}"
                                  }
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "text": "$t:sirsoft-board.admin.settings.fields.max_reply_depth"
                                },
                                {
                                  "type": "basic",
                                  "name": "P",
                                  "props": {
                                    "className": "text-field-hint"
                                  },
                                  "text": "$t:sirsoft-board.admin.settings.fields.descriptions.max_reply_depth|min={{_local?.form?._meta?.limits?.max_reply_depth_min ?? 1}}|max={{_local?.form?._meta?.limits?.max_reply_depth_max ?? 10}}"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-shrink-0"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Input",
                              "props": {
                                "type": "number",
                                "name": "basic_defaults.max_reply_depth",
                                "min": "{{_local?.form?._meta?.limits?.max_reply_depth_min ?? 1}}",
                                "max": "{{_local?.form?._meta?.limits?.max_reply_depth_max ?? 10}}"  ,
                                "className": "{{(_local.errors?.['basic_defaults.max_reply_depth']) ? 'w-32 input-error' : 'w-32'}}",
                                "disabled": "{{_computed.isReadOnly}}"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{_local.errors?.['basic_defaults.max_reply_depth']}}",
                              "props": {
                                "className": "text-xs text-red-600 dark:text-red-400 block mt-1"
                              },
                              "text": "{{(Array.isArray(_local.errors?.['basic_defaults.max_reply_depth']) ? _local.errors['basic_defaults.max_reply_depth'][0] : _local.errors?.['basic_defaults.max_reply_depth']) ?? ''}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
