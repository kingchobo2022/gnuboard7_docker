{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 SEO 탭 콘텐츠"
  },
  "id": "tab_content_seo",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'seo'}}",
  "props": {},
  "children": [
    {
      "id": "meta_settings_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "section-header"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.title"
        },
        {
          "type": "basic",
          "name": "P",
          "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.description"
        }
      ]
    },
    {
      "id": "boards_page_card",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.seo.boards_page.title"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "field_boards_title",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.meta_title"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "seo.meta_boards_title",
                    "placeholder": "$t:sirsoft-board.admin.settings.seo.boards_page.title_placeholder",
                    "className": "{{_local.errors?.['seo.meta_boards_title'] ? 'input input-error' : 'input'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['seo.meta_boards_title']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['seo.meta_boards_title']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.available_variables: {site_name}"
                }
              ]
            },
            {
              "id": "field_boards_description",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.meta_description"
                },
                {
                  "type": "basic",
                  "name": "Textarea",
                  "props": {
                    "name": "seo.meta_boards_description",
                    "rows": 3,
                    "className": "{{_local.errors?.['seo.meta_boards_description'] ? 'input-error resize-none' : ' resize-none'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['seo.meta_boards_description']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['seo.meta_boards_description']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.available_variables: {site_name}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "board_page_card",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.seo.board_page.title"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "field_board_title",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.meta_title"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "seo.meta_board_title",
                    "placeholder": "$t:sirsoft-board.admin.settings.seo.board_page.title_placeholder",
                    "className": "{{_local.errors?.['seo.meta_board_title'] ? 'input input-error' : 'input'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['seo.meta_board_title']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['seo.meta_board_title']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.available_variables: {site_name}, {board_name}"
                }
              ]
            },
            {
              "id": "field_board_description",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.meta_description"
                },
                {
                  "type": "basic",
                  "name": "Textarea",
                  "props": {
                    "name": "seo.meta_board_description",
                    "rows": 3,
                    "className": "{{_local.errors?.['seo.meta_board_description'] ? 'input-error resize-none' : ' resize-none'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['seo.meta_board_description']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['seo.meta_board_description']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.available_variables: {site_name}, {board_name}, {board_description}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "post_page_card",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.seo.post_page.title"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "field_post_title",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.meta_title"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "seo.meta_post_title",
                    "placeholder": "$t:sirsoft-board.admin.settings.seo.post_page.title_placeholder",
                    "className": "{{_local.errors?.['seo.meta_post_title'] ? 'input input-error' : 'input'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['seo.meta_post_title']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['seo.meta_post_title']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.available_variables: {site_name}, {board_name}, {post_title}"
                }
              ]
            },
            {
              "id": "field_post_description",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.meta_description"
                },
                {
                  "type": "basic",
                  "name": "Textarea",
                  "props": {
                    "name": "seo.meta_post_description",
                    "rows": 3,
                    "className": "{{_local.errors?.['seo.meta_post_description'] ? 'input-error resize-none' : ' resize-none'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['seo.meta_post_description']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['seo.meta_post_description']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "form-hint"
                  },
                  "text": "$t:sirsoft-board.admin.settings.seo.meta_settings.available_variables: {site_name}, {board_name}, {post_title}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "seo_friendly_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "id": "seo_friendly_title",
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.title"
        },
        {
          "id": "seo_friendly_description",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.description"
        },
        {
          "id": "seo_friendly_content",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label"
              },
              "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.provide_pages"
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex-center gap-2 cursor-pointer"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "name": "seo.seo_boards",
                        "className": "checkbox"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-secondary"
                      },
                      "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.boards"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex-center gap-2 cursor-pointer"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "name": "seo.seo_board",
                        "className": "checkbox"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-secondary"
                      },
                      "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.board"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex-center gap-2 cursor-pointer"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "name": "seo.seo_post_detail",
                        "className": "checkbox"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-secondary"
                      },
                      "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.post_detail"
                    }
                  ]
                }
              ],
              "props": {}
            },
            {
              "id": "cache_section",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.cache_management"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.cache_description"
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "btn btn-danger",
                        "disabled": "{{_local.clearingCache ?? false}}"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "if": "{{_local.clearingCache ?? false}}",
                          "props": {
                            "name": "circle-notch",
                            "className": "fa-spin mr-2"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache"
                        }
                      ],
                      "actions": [
                        {
                          "type": "click",
                          "handler": "sequence",
                          "actions": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "clearingCache": true
                              }
                            },
                            {
                              "handler": "apiCall",
                              "auth_required": true,
                              "target": "/api/admin/seo/clear-cache",
                              "params": {
                                "method": "POST",
                                "body": {
                                  "layout": "board/boards"
                                }
                              },
                              "onSuccess": {
                                "handler": "apiCall",
                                "auth_required": true,
                                "target": "/api/admin/seo/clear-cache",
                                "params": {
                                  "method": "POST",
                                  "body": {
                                    "layout": "board/index"
                                  }
                                },
                                "onSuccess": {
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "/api/admin/seo/clear-cache",
                                  "params": {
                                    "method": "POST",
                                    "body": {
                                      "layout": "board/show"
                                    }
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "clearingCache": false
                                      }
                                    },
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "type": "success",
                                        "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_success"
                                      }
                                    }
                                  ],
                                  "onError": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "clearingCache": false
                                      }
                                    },
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "type": "error",
                                        "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_error"
                                      }
                                    }
                                  ]
                                },
                                "onError": [
                                  {
                                    "handler": "setState",
                                    "params": {
                                      "target": "local",
                                      "clearingCache": false
                                    }
                                  },
                                  {
                                    "handler": "toast",
                                    "params": {
                                      "type": "error",
                                      "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_error"
                                    }
                                  }
                                ]
                              },
                              "onError": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "clearingCache": false
                                  }
                                },
                                {
                                  "handler": "toast",
                                  "params": {
                                    "type": "error",
                                    "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_error"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "props": {}
                }
              ]
            }
          ],
          "props": {
            "className": "row-stack"
          }
        }
      ]
    }
  ]
}
