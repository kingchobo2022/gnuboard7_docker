                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "checkbox",
                            "className": "checkbox-aligned",
                            "checked": "{{(_local.bulkApplyFields ?? []).includes('max_comment_depth')}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('max_comment_depth') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'max_comment_depth') : [...(_local.bulkApplyFields ?? []), 'max_comment_depth']}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.settings.fields.max_comment_depth"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.max_comment_depth|min={{_local?.form?._meta?.limits?.max_comment_depth_min ?? 0}}|max={{_local?.form?._meta?.limits?.max_comment_depth_max ?? 10}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "basic_defaults.max_comment_depth",
                            "min": "{{_local?.form?._meta?.limits?.max_comment_depth_min ?? 0}}",
                            "max": "{{_local?.form?._meta?.limits?.max_comment_depth_max ?? 10}}",
                            "className": "{{(_local.errors?.['basic_defaults.max_comment_depth']) ? 'w-32 input-error' : 'w-32'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.['basic_defaults.max_comment_depth']}}",
                          "props": {
                            "className": "text-xs text-red-600 dark:text-red-400 block mt-1"
                          },
                          "text": "{{(Array.isArray(_local.errors?.['basic_defaults.max_comment_depth']) ? _local.errors['basic_defaults.max_comment_depth'][0] : _local.errors?.['basic_defaults.max_comment_depth']) ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
