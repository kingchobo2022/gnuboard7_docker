                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-field-hint"
                              },
                              "text": "$t:sirsoft-board.admin.settings.fields.descriptions.comment_order"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Select",
                      "props": {
                        "name": "basic_defaults.comment_order",
                        "options": [
                          {
                            "value": "ASC",
                            "label": "$t:sirsoft-board.admin.settings.options.comment_order.ASC"
                          },
                          {
                            "value": "DESC",
                            "label": "$t:sirsoft-board.admin.settings.options.comment_order.DESC"
                          }
                        ],
                        "className": "w-48 flex-shrink-0 text-sm",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
