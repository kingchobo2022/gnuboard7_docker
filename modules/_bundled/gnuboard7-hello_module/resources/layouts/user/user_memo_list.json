{
    "version": "1.0.0",
    "layout_name": "user_memo_list",
    "extends": "_user_base",
    "meta": {
        "title": "$t:gnuboard7-hello_module.user.memos.index.title"
    },
    "data_sources": [
        {
            "id": "memos",
            "label_key": "$t:gnuboard7-hello_module.editor.data_source.memos",
            "type": "api",
            "endpoint": "/api/modules/gnuboard7-hello_module/memos",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": false,
            "params": {
                "page": "{{query.page}}",
                "per_page": "{{query.per_page ?? 10}}"
            },
            "fallback": {
                "data": {
                    "data": [],
                    "meta": {
                        "current_page": 1,
                        "last_page": 1,
                        "per_page": 10,
                        "total": 0
                    }
                }
            }
        }
    ],
    "slots": {
        "content": [
            {
                "id": "user_memo_wrapper",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "max-w-3xl mx-auto p-6"
                },
                "children": [
                    {
                        "id": "user_memo_title",
                        "type": "basic",
                        "name": "H1",
                        "props": {
                            "className": "text-page-heading mb-6"
                        },
                        "text": "$t:gnuboard7-hello_module.user.memos.index.title"
                    },
                    {
                        "id": "user_memo_items",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "space-y-3"
                        },
                        "iteration": {
                            "data": "{{memos?.data?.data ?? []}}",
                            "item_var": "memo",
                            "index_var": "idx"
                        },
                        "children": [
                            {
                                "id": "user_memo_item",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "p-4 bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "H2",
                                        "props": {
                                            "className": "section-heading"
                                        },
                                        "text": "{{memo.title ?? ''}}"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "props": {
                                            "className": "mt-2 text-sm text-gray-600 dark:text-gray-300"
                                        },
                                        "text": "{{memo.content ?? ''}}"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
