{
    "version": "1.0.0",
    "routes": [
        {
            "path": "*/admin/pages",
            "layout": "admin_page_list",
            "auth_required": true,
            "meta": {
                "title": "$t:sirsoft-page.admin.page.page_title"
            }
        },
        {
            "path": "*/admin/pages/create",
            "layout": "admin_page_form",
            "auth_required": true,
            "meta": {
                "title": "$t:sirsoft-page.admin.page.form.page_title_create"
            }
        },
        {
            "path": "*/admin/pages/:id/edit",
            "layout": "admin_page_form",
            "auth_required": true,
            "meta": {
                "title": "$t:sirsoft-page.admin.page.form.page_title_edit"
            }
        },
        {
            "path": "*/admin/pages/:id",
            "layout": "admin_page_detail",
            "auth_required": true,
            "meta": {
                "title": "$t:sirsoft-page.admin.page.detail.page_title"
            }
        }
    ]
}