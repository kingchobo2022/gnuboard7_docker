{
  "version": "1.0.0",
  "layout_name": "admin_ecommerce_brand_index",
  "permissions": [
    "sirsoft-ecommerce.brands.read"
  ],
  "extends": "_admin_base",
  "meta": {
    "title": "$t:sirsoft-ecommerce.admin.brand.title",
    "description": "$t:sirsoft-ecommerce.admin.brand.description"
  },
  "state": {
    "selectedBrandId": null,
    "selectedBrand": null,
    "panelMode": "view",
    "deleteModal": {
      "isOpen": false,
      "brandId": null,
      "brandName": "",
      "productsCount": 0
    },
    "editingModal": {
      "isOpen": false
    }
  },
  "transition_overlay": {
    "wait_for": [
      "brands"
    ]
  },
  "data_sources": [
    {
      "id": "brands",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.brands",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-ecommerce/admin/brands",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "cache": false,
      "refetchOnMount": true,
      "params": {
        "sort": "{{query.sort}}",
        "search": "{{query.search}}"
      },
      "errorHandling": {
        "403": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        },
        "default": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      },
      "initLocal": {
        "form": {
          "name": {
            "ko": "",
            "en": ""
          }
        }
      }
    }
  ],
  "slots": {
    "content": [
      {
        "id": "brand_page_content",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "admin-page-content"
        },
        "responsive": {
          "portable": {
            "props": {
              "className": "admin-page-content-compact"
            }
          }
        },
        "children": [
          {
            "id": "page_header",
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "flex-start justify-between gap-4 mb-6"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "row-stack mb-6"
                }
              }
            },
            "children": [
              {
                "id": "page_header_left",
                "type": "basic",
                "name": "Div",
                "children": [
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "page-title mb-1"
                    },
                    "text": "$t:sirsoft-ecommerce.admin.brand.title"
                  },
                  {
                    "type": "basic",
                    "name": "P",
                    "props": {
                      "className": "text-secondary text-sm"
                    },
                    "text": "$t:sirsoft-ecommerce.admin.brand.description"
                  }
                ]
              },
              {
                "id": "page_header_actions",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex-center gap-2 flex-shrink-0"
                },
                "children": [
                  {
                    "id": "refresh_button",
                    "type": "basic",
                    "name": "Button",
                    "props": {
                      "className": "btn-icon",
                      "aria-label": "$t:sirsoft-ecommerce.common.refresh"
                    },
                    "actions": [
                      {
                        "type": "click",
                        "handler": "navigate",
                        "params": {
                          "path": "/admin/ecommerce/brands",
                          "mergeQuery": false
                        }
                      }
                    ],
                    "children": [
                      {
                        "id": "refresh_icon",
                        "type": "basic",
                        "name": "Icon",
                        "props": {
                          "name": "refresh",
                          "className": "w-5 h-5"
                        }
                      }
                    ]
                  },
                  {
                    "id": "add_brand_button",
                    "type": "basic",
                    "name": "Button",
                    "props": {
                      "disabled": "{{brands?.data?.abilities?.can_create !== true}}",
                      "className": "flex-center gap-1.5 px-3 py-1.5 text-sm bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    },
                    "actions": [
                      {
                        "type": "click",
                        "handler": "sequence",
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "global",
                              "selectedBrandId": null,
                              "selectedBrand": null,
                              "panelMode": "create"
                            }
                          },
                          {
                            "handler": "setState",
                            "params": {
                              "target": "local",
                              "form": null,
                              "errors": null,
                              "isSaving": false
                            }
                          },
                          {
                            "handler": "setState",
                            "params": {
                              "target": "local",
                              "form": {
                                "name": {
                                  "ko": "",
                                  "en": ""
                                },
                                "is_active": true
                              }
                            }
                          }
                        ]
                      }
                    ],
                    "children": [
                      {
                        "type": "basic",
                        "name": "Icon",
                        "props": {
                          "name": "plus",
                          "className": "w-4 h-4"
                        }
                      },
                      {
                        "type": "basic",
                        "name": "Span",
                        "text": "$t:sirsoft-ecommerce.admin.brand.list.add"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "panel_layout",
            "type": "basic",
            "name": "Div",
            "blur_until_loaded": true,
            "props": {
              "className": "grid-cols-1-lg-3"
            },
            "children": [
              {
                "id": "left_panel",
                "partial": "partials/admin_ecommerce_brand_index/_panel_brand_list.json"
              },
              {
                "id": "right_panel",
                "partial": "partials/admin_ecommerce_brand_index/_panel_detail.json"
              }
            ]
          }
        ]
      }
    ]
  },
  "modals": [
    {
      "partial": "partials/admin_ecommerce_brand_index/_modal_delete_confirm.json"
    },
    {
      "partial": "partials/admin_ecommerce_brand_index/_modal_editing_confirm.json"
    }
  ]
}
