{
    "meta": {
        "is_partial": true,
        "description": "Product Form - SEO Settings Section"
    },
    "id": "seo",
    "type": "basic",
    "name": "Div",
    "props": {
        "className": "admin-card-accordion"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": {
                "className": "card-header"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                        "name": "search",
                        "className": "text-gray-500 dark:text-gray-400"
                    }
                },
                {
                    "type": "basic",
                    "name": "Span",
                    "props": {
                        "className": "card-title"
                    },
                    "text": "$t:sirsoft-ecommerce.admin.product.sections.seo"
                },
                {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                        "name": "chevron-down",
                        "className": "admin-card-accordion-icon transition-transform duration-200 {{_local.ui.seoExpanded !== false ? 'rotate-180' : ''}}"
                    }
                }
            ],
            "actions": [
                {
                    "type": "click",
                    "handler": "setState",
                    "params": {
                        "target": "local",
                        "ui.seoExpanded": "{{!_local.ui.seoExpanded}}"
                    }
                }
            ]
        },
        {
            "id": "seo_body",
            "type": "basic",
            "name": "Div",
            "if": "{{_local.ui.seoExpanded !== false}}",
            "props": {
                "className": "row-stack"
            },
            "children": [
                {
                    "id": "field_meta_title",
                    "type": "basic",
                    "name": "Div",
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Label",
                                    "props": {
                                        "className": "form-label"
                                    },
                                    "text": "$t:sirsoft-ecommerce.admin.product.fields.meta_title"
                                },
                                {
                                    "id": "meta_title_synced",
                                    "if": "{{_local.form.seo_sync_title}}",
                                    "type": "composite",
                                    "name": "Input",
                                    "props": {
                                        "value": "{{$localized(_local.form.name) || ''}}",
                                        "disabled": true,
                                        "maxLength": 70,
                                        "className": "rounded-md"
                                    }
                                },
                                {
                                    "id": "meta_title_custom",
                                    "if": "{{!_local.form.seo_sync_title}}",
                                    "type": "composite",
                                    "name": "MultilingualInput",
                                    "props": {
                                        "name": "meta_title",
                                        "layout": "tabs",
                                        "inputType": "text",
                                        "placeholder": "$t:sirsoft-ecommerce.admin.product.placeholders.meta_title",
                                        "maxLength": 70,
                                        "error": "{{_local.errors?.meta_title?.[0] ?? _local.errors?.['meta_title.ko']?.[0] ?? ''}}",
                                        "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_local.errors?.meta_title}}",
                                    "props": {
                                        "className": "form-error-xs"
                                    },
                                    "text": "{{_local.errors?.meta_title?.[0]}}"
                                },
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": {
                                        "className": "flex-between text-xs"
                                    },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Span",
                                            "props": {
                                                "className": "text-gray-500 dark:text-gray-400"
                                            },
                                            "text": "$t:sirsoft-ecommerce.admin.product.seo.title_hint"
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Span",
                                            "props": {
                                                "className": "text-gray-400 dark:text-gray-500"
                                            },
                                            "text": "{{_local.form.seo_sync_title ? ($localized(_local.form.name) || '').length : ($localized(_local.form.meta_title) || '').length}}/70"
                                        }
                                    ]
                                },
                                {
                                    "id": "seo_sync_title_checkbox",
                                    "type": "basic",
                                    "name": "Label",
                                    "props": {
                                        "className": "flex-center gap-2 cursor-pointer"
                                    },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Checkbox",
                                            "props": {
                                                "checked": "{{_local.form.seo_sync_title}}",
                                                "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                                            },
                                            "actions": [
                                                {
                                                    "type": "change",
                                                    "handler": "sequence",
                                                    "params": {
                                                        "actions": [
                                                            {
                                                                "handler": "setState",
                                                                "params": {
                                                                    "target": "local",
                                                                    "form.seo_sync_title": "{{!_local.form.seo_sync_title}}",
                                                                    "hasChanges": "{{!!route?.itemCode}}"
                                                                }
                                                            },
                                                            {
                                                                "handler": "setState",
                                                                "condition": "{{!_local.form.seo_sync_title}}",
                                                                "params": {
                                                                    "target": "local",
                                                                    "form.meta_title": "{{_local.form.name}}"
                                                                }
                                                            }
                                                        ]
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Span",
                                            "props": {
                                                "className": "text-body"
                                            },
                                            "text": "$t:sirsoft-ecommerce.admin.product.seo.sync_title"
                                        }
                                    ]
                                }
                            ],
                            "props": {}
                        }
                    ]
                },
                {
                    "id": "field_meta_description",
                    "type": "basic",
                    "name": "Div",
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Label",
                                    "props": {
                                        "className": "form-label"
                                    },
                                    "text": "$t:sirsoft-ecommerce.admin.product.fields.meta_description"
                                },
                                {
                                    "id": "meta_desc_synced",
                                    "if": "{{_local.form.seo_sync_description}}",
                                    "type": "composite",
                                    "name": "Textarea",
                                    "props": {
                                        "value": "{{($localized(_local.form.description) || '').substring(0, 160)}}",
                                        "disabled": true,
                                        "rows": 3,
                                        "maxLength": 160,
                                        "className": "w-full rounded-md bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-600 px-3"
                                    }
                                },
                                {
                                    "id": "meta_desc_custom",
                                    "if": "{{!_local.form.seo_sync_description}}",
                                    "type": "composite",
                                    "name": "MultilingualInput",
                                    "props": {
                                        "name": "meta_description",
                                        "layout": "tabs",
                                        "inputType": "textarea",
                                        "rows": 3,
                                        "placeholder": "$t:sirsoft-ecommerce.admin.product.placeholders.meta_description",
                                        "maxLength": 160,
                                        "error": "{{_local.errors?.meta_description?.[0] ?? _local.errors?.['meta_description.ko']?.[0] ?? ''}}",
                                        "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_local.errors?.meta_description}}",
                                    "props": {
                                        "className": "form-error-xs"
                                    },
                                    "text": "{{_local.errors?.meta_description?.[0]}}"
                                },
                                {
                                    "type": "basic",
                                    "name": "P",
                                    "props": {
                                        "className": "text-hint text-right"
                                    },
                                    "text": "{{_local.form.seo_sync_description ? ($localized(_local.form.description) || '').substring(0, 160).length : ($localized(_local.form.meta_description) || '').length}}/160"
                                },
                                {
                                    "id": "seo_sync_description_checkbox",
                                    "type": "basic",
                                    "name": "Label",
                                    "props": {
                                        "className": "flex-center gap-2 cursor-pointer"
                                    },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Checkbox",
                                            "props": {
                                                "checked": "{{_local.form.seo_sync_description}}",
                                                "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                                            },
                                            "actions": [
                                                {
                                                    "type": "change",
                                                    "handler": "sequence",
                                                    "params": {
                                                        "actions": [
                                                            {
                                                                "handler": "setState",
                                                                "params": {
                                                                    "target": "local",
                                                                    "form.seo_sync_description": "{{!_local.form.seo_sync_description}}",
                                                                    "hasChanges": "{{!!route?.itemCode}}"
                                                                }
                                                            },
                                                            {
                                                                "handler": "setState",
                                                                "condition": "{{!_local.form.seo_sync_description}}",
                                                                "params": {
                                                                    "target": "local",
                                                                    "form.meta_description": "{{_local.form.description}}"
                                                                }
                                                            }
                                                        ]
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Span",
                                            "props": {
                                                "className": "text-body"
                                            },
                                            "text": "$t:sirsoft-ecommerce.admin.product.seo.sync_description"
                                        }
                                    ]
                                }
                            ],
                            "props": {}
                        }
                    ]
                },
                {
                    "id": "field_meta_keywords",
                    "type": "basic",
                    "name": "Div",
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Label",
                                    "props": {
                                        "className": "form-label"
                                    },
                                    "text": "$t:sirsoft-ecommerce.admin.product.fields.meta_keywords"
                                },
                                {
                                    "type": "composite",
                                    "name": "TagInput",
                                    "props": {
                                        "name": "meta_keywords",
                                        "placeholder": "$t:sirsoft-ecommerce.admin.product.placeholders.meta_keywords",
                                        "maxItems": 10,
                                        "creatable": true,
                                        "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                                    },
                                    "actions": [
                                        {
                                            "type": "change",
                                            "handler": "setState",
                                            "params": {
                                                "target": "local",
                                                "hasChanges": "{{!!route?.itemCode}}"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "type": "basic",
                                    "name": "P",
                                    "props": {
                                        "className": "text-tertiary"
                                    },
                                    "text": "$t:sirsoft-ecommerce.admin.product.seo.keywords_hint"
                                }
                            ],
                            "props": {}
                        }
                    ]
                },
                {
                    "id": "field_og_image",
                    "type": "basic",
                    "name": "Label",
                    "props": {
                        "className": "flex-center gap-2 cursor-pointer"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Checkbox",
                            "props": {
                                "checked": "{{_local.form.use_main_image_for_og ?? true}}",
                                "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                            },
                            "actions": [
                                {
                                    "type": "change",
                                    "handler": "setState",
                                    "params": {
                                        "target": "local",
                                        "form.use_main_image_for_og": "{{!(_local.form.use_main_image_for_og ?? true)}}",
                                        "hasChanges": "{{!!route?.itemCode}}"
                                    }
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Span",
                            "props": {
                                "className": "text-body"
                            },
                            "text": "$t:sirsoft-ecommerce.admin.product.fields.use_main_image_for_og"
                        }
                    ]
                },
                {
                    "id": "seo_preview",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "toggle-group"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                                "className": "p-3 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700"
                            },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": {
                                        "className": "text-body font-medium"
                                    },
                                    "text": "$t:sirsoft-ecommerce.admin.product.seo.preview"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                                "className": "p-4 bg-white dark:bg-gray-900 flex gap-4"
                            },
                            "children": [
                                {
                                    "id": "seo_preview_image",
                                    "if": "{{!!_local.form.images?.[0]?.download_url}}",
                                    "type": "basic",
                                    "name": "Img",
                                    "props": {
                                        "src": "{{_local.form.images?.[0]?.download_url}}",
                                        "alt": "OG Image",
                                        "className": "w-20 h-20 rounded object-cover flex-shrink-0"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": {
                                        "className": "flex-1 min-w-0"
                                    },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": {
                                                "className": "text-blue-600 dark:text-blue-400 text-lg hover:underline cursor-pointer truncate"
                                            },
                                            "text": "{{$localized(_local.form.meta_title) || $localized(_local.form.name) || '$t:sirsoft-ecommerce.admin.product.seo.untitled'}}"
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": {
                                                "className": "text-green-700 dark:text-green-500 text-sm mt-1 truncate"
                                            },
                                            "text": "{{_global.site_url ?? 'https://example.com'}}/products/{{_local.form.product_code || 'product-code'}}"
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": {
                                                "className": "text-secondary text-sm mt-1 line-clamp-2"
                                            },
                                            "text": "{{$localized(_local.form.meta_description) || $localized(_local.form.short_description) || $localized(_local.form.description) || '$t:sirsoft-ecommerce.admin.product.seo.no_description'}}"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
