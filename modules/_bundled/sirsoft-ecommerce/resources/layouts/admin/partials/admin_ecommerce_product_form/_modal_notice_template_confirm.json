{
  "meta": {
    "is_partial": true,
    "description": "Product Form - Notice Template Change Confirmation Modal"
  },
  "id": "notice_template_confirm_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.product.notice.confirm_change_title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "alert-warning"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "w-5 h-5 text-amber-500 shrink-0 mt-0.5"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm font-medium text-warning-soft"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product.notice.confirm_change_warning"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-warning-soft"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product.notice.confirm_change_description"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "btn btn-outline"
              },
              "text": "$t:sirsoft-ecommerce.common.cancel",
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "params": {
                    "actions": [
                      {
                        "handler": "setState",
                        "params": {
                          "target": "global",
                          "pendingNoticeTemplateId": null
                        }
                      },
                      {
                        "handler": "closeModal"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "btn btn-warning"
              },
              "text": "$t:sirsoft-ecommerce.admin.product.notice.confirm_change_button",
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "params": {
                    "actions": [
                      {
                        "handler": "closeModal"
                      },
                      {
                        "handler": "sirsoft-ecommerce.selectNoticeTemplate",
                        "params": {
                          "templateId": "{{_global.pendingNoticeTemplateId}}"
                        }
                      },
                      {
                        "handler": "setState",
                        "params": {
                          "target": "global",
                          "pendingNoticeTemplateId": null
                        }
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ],
      "props": {
      }
    }
  ]
}
