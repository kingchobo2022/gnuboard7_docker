{
    "meta": {
        "is_partial": true,
        "description": "Product Form - Description Section"
    },
    "id": "description",
    "type": "basic",
    "name": "Div",
    "props": {
        "className": "admin-card-accordion"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": {
                "className": "card-header"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                        "name": "file-lines",
                        "className": "text-gray-500 dark:text-gray-400"
                    }
                },
                {
                    "type": "basic",
                    "name": "Span",
                    "props": {
                        "className": "card-title"
                    },
                    "text": "$t:sirsoft-ecommerce.admin.product.sections.description"
                },
                {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                        "name": "chevron-down",
                        "className": "admin-card-accordion-icon transition-transform duration-200 {{_local.ui.descriptionExpanded !== false ? 'rotate-180' : ''}}"
                    }
                }
            ],
            "actions": [
                {
                    "type": "click",
                    "handler": "setState",
                    "params": {
                        "target": "local",
                        "ui.descriptionExpanded": "{{!_local.ui.descriptionExpanded}}"
                    }
                }
            ]
        },
        {
            "id": "description_body",
            "type": "basic",
            "name": "Div",
            "if": "{{_local.ui.descriptionExpanded !== false}}",
            "props": {
                "className": "row-stack"
            },
            "children": [
                {
                    "id": "description_editor_wrapper",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "{{_local.errors?.description ? 'border border-red-500 dark:border-red-500 rounded-lg overflow-hidden' : ''}}"
                    },
                    "children": [
                        {
                            "id": "description_editor",
                            "type": "extension_point",
                            "name": "html_editor",
                            "props": {
                                "name": "description",
                                "multilingual": true,
                                "value": "{{_local.form?.description ?? ''}}",
                                "rows": 15,
                                "placeholder": "$t:sirsoft-ecommerce.admin.product.placeholders.description",
                                "label": "$t:sirsoft-ecommerce.admin.product.fields.description",
                                "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}",
                                "showHtmlModeToggle": true,
                                "isHtml": "{{(_local.form?.description_mode ?? 'text') === 'html'}}"
                            },
                            "default": [
                                {
                                    "type": "composite",
                                    "name": "HtmlEditor",
                                    "props": {
                                        "name": "description",
                                        "multilingual": true,
                                        "value": "{{_local.form?.description ?? ''}}",
                                        "rows": 15,
                                        "placeholder": "$t:sirsoft-ecommerce.admin.product.placeholders.description",
                                        "label": "$t:sirsoft-ecommerce.admin.product.fields.description",
                                        "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}",
                                        "showHtmlModeToggle": true,
                                        "isHtml": "{{(_local.form?.description_mode ?? 'text') === 'html'}}"
                                    },
                                    "actions": [
                                        {
                                            "event": "onChange",
                                            "type": "change",
                                            "handler": "setState",
                                            "params": {
                                                "target": "local",
                                                "form.description": "{{$event.target.value}}",
                                                "hasChanges": true
                                            }
                                        },
                                        {
                                            "event": "onIsHtmlChange",
                                            "type": "change",
                                            "handler": "setState",
                                            "params": {
                                                "target": "local",
                                                "form.description_mode": "{{$args[0].target.checked ? 'html' : 'text'}}",
                                                "hasChanges": true
                                            }
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Span",
                    "if": "{{_local.errors?.description || _local.errors?.['description.ko']}}",
                    "props": {
                        "className": "form-error-xs mt-1"
                    },
                    "text": "{{_local.errors?.description?.[0] ?? _local.errors?.['description.ko']?.[0]}}"
                }
            ]
        }
    ]
}
