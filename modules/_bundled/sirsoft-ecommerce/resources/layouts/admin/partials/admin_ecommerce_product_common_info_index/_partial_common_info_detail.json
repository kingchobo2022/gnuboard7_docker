{
  "meta": {
    "is_partial": true,
    "description": "Common Info Detail View Partial"
  },
  "id": "common_info_detail_view",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "children": [
    {
      "id": "detail_card_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-start justify-between gap-4 mb-6"
      },
      "responsive": {
        "portable": {
          "props": {
            "className": "row-stack mb-6"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 mb-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-secondary"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.common_info.detail.name"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-base font-medium text-primary"
                  },
                  "text": "일반 상품 안내"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-4 mb-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-secondary"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.common_info.detail.status"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "badge badge-gray"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.common_info.detail.default"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "badge badge-green"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.common_info.detail.active"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-4 text-sm text-secondary"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.common_info.detail.created_at"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "ml-2 text-primary"
                      },
                      "text": "2024-01-15 14:30:00"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.common_info.detail.updated_at"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "ml-2 text-primary"
                      },
                      "text": "2024-01-20 10:20:00"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "btn btn-outline"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.detail.copy"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "btn btn-outline"
              },
              "text": "$t:sirsoft-ecommerce.common.edit",
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "viewMode": "edit"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "btn btn-danger text-sm"
              },
              "text": "$t:sirsoft-ecommerce.common.delete",
              "actions": [
                {
                  "type": "click",
                  "handler": "openModal",
                  "target": "modal_delete_confirm"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "section_language_tabs",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mb-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2 mb-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "globe",
                "className": "w-4 h-4 text-gray-400 dark:text-gray-500"
              }
            },
            {
              "type": "basic",
              "name": "Button",
              "iteration": {
                "source": "$locales",
                "item_var": "loc"
              },
              "props": {
                "type": "button",
                "className": "{{(_local.activeLanguageTab ?? $locale) === loc ? 'btn btn-primary text-sm' : 'btn btn-secondary text-sm'}}"
              },
              "text": "{{_global.appConfig?.localeNames?.[loc] ?? loc}}",
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "activeLanguageTab": "{{loc}}"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "content_display",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "border border-gray-200 dark:border-gray-700 rounded-lg p-4 min-h-64 bg-gray-50 dark:bg-gray-800"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-secondary text-center py-8"
          },
          "text": "$t:sirsoft-ecommerce.admin.common_info.detail.content_placeholder"
        }
      ]
    }
  ]
}
