{
  "meta": {
    "is_partial": true,
    "description": "Common Info Form Panel - Create/Edit/Copy Mode"
  },
  "id": "form_panel",
  "type": "basic",
  "name": "Div",
  "if": "{{_global.panelMode === 'create' || _global.panelMode === 'edit' || _global.panelMode === 'copy'}}",
  "onComponentEvent": [
    {
      "event": "common_info:init_copy_form",
      "handler": "setState",
      "params": {
        "target": "local",
        "form": {
          "name": "{{_eventData.name}}",
          "content": "{{_eventData.content}}",
          "content_mode": "{{_eventData.content_mode}}",
          "is_default": "{{_eventData.is_default}}",
          "is_active": "{{_eventData.is_active}}"
        },
        "errors": null,
        "isSaving": false,
        "showPreview": false
      }
    }
  ],
  "children": [
    {
      "id": "form_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 panel-header flex-between"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-heading"
          },
          "text": "{{_global.panelMode === 'create' ? '$t:sirsoft-ecommerce.admin.common_info.form.title_add' : (_global.panelMode === 'copy' ? '$t:sirsoft-ecommerce.admin.common_info.form.title_copy' : '$t:sirsoft-ecommerce.admin.common_info.form.title_edit')}}"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "px-3 py-1.5 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "panelMode": "view"
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form": null,
                        "errors": null,
                        "isSaving": false,
                        "showPreview": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form": {
                          "name": {
                            "ko": "",
                            "en": ""
                          },
                          "content": {
                            "ko": "",
                            "en": ""
                          },
                          "content_mode": "text",
                          "is_default": false,
                          "is_active": true
                        }
                      }
                    }
                  ]
                }
              ],
              "text": "$t:sirsoft-ecommerce.admin.common_info.button.cancel"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "px-3 py-1.5 text-sm bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                "disabled": "{{_local.isSaving || (_global.panelMode === 'edit' && _global.selectedItem?.abilities?.can_update !== true)}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isSaving": true,
                        "errors": null
                      }
                    },
                    {
                      "handler": "apiCall",
                      "auth_required": true,
                      "target": "{{_global.panelMode === 'edit' ? '/api/modules/sirsoft-ecommerce/admin/product-common-infos/' + _global.selectedId : '/api/modules/sirsoft-ecommerce/admin/product-common-infos'}}",
                      "params": {
                        "method": "{{_global.panelMode === 'edit' ? 'PUT' : 'POST'}}",
                        "body": {
                          "name": "{{_local.form.name}}",
                          "content": "{{_local.form.content}}",
                          "content_mode": "{{_local.form.content_mode}}",
                          "is_default": "{{_local.form.is_default}}",
                          "is_active": "{{_local.form.is_active}}"
                        }
                      },
                      "onSuccess": [
                        {
                          "handler": "refetchDataSource",
                          "params": {
                            "dataSourceId": "commonInfos"
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "selectedId": "{{response.data.id}}",
                            "selectedItem": "{{response.data}}",
                            "panelMode": "view"
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form": null,
                            "isSaving": false
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form": {
                              "name": {
                                "ko": "",
                                "en": ""
                              },
                              "content": {
                                "ko": "",
                                "en": ""
                              },
                              "content_mode": "text",
                              "is_default": false,
                              "is_active": true
                            }
                          }
                        },
                        {
                          "handler": "toast",
                          "params": {
                            "type": "success",
                            "message": "{{response.message}}"
                          }
                        }
                      ],
                      "onError": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isSaving": false,
                            "errors": "{{error.errors}}"
                          }
                        },
                        {
                          "handler": "toast",
                          "params": {
                            "type": "error",
                            "message": "{{error.message}}"
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "text": "$t:sirsoft-ecommerce.admin.common_info.button.save"
            }
          ]
        }
      ]
    },
    {
      "id": "form_content",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "p-4 max-h-[calc(100vh-200px)] overflow-y-auto"
      },
      "children": [
        {
          "id": "name_field",
          "type": "basic",
          "name": "Div",
          "dataKey": "form",
          "props": {
            "className": "mb-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-ecommerce.admin.common_info.form.name"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-required"
                  },
                  "text": "*"
                }
              ]
            },
            {
              "type": "composite",
              "name": "MultilingualInput",
              "props": {
                "name": "name",
                "placeholder": "$t:sirsoft-ecommerce.admin.common_info.form.name_placeholder",
                "error": "{{_local.errors?.name}}",
                "layout": "tabs",
                "disabled": "{{_global.panelMode === 'edit' && _global.selectedItem?.abilities?.can_update !== true}}"
              }
            }
          ]
        },
        {
          "id": "content_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-200 dark:border-gray-700 pt-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "text-label-subtle block font-medium mb-3"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.form.content_section"
            },
            {
              "id": "content_editor",
              "type": "extension_point",
              "name": "html_editor",
              "if": "{{_global.panelMode === 'create' || (_local.form.content !== undefined && !Array.isArray(_local.form.content))}}",
              "props": {
                "name": "content",
                "multilingual": true,
                "value": "{{_local.form?.content ?? ''}}",
                "placeholder": "$t:sirsoft-ecommerce.admin.common_info.form.placeholder_html",
                "rows": 10,
                "disabled": "{{_global.panelMode === 'edit' && _global.selectedItem?.abilities?.can_update !== true}}",
                "showHtmlModeToggle": true,
                "isHtml": "{{(_local.form?.content_mode ?? 'text') === 'html'}}"
              },
              "default": [
                {
                  "type": "composite",
                  "name": "HtmlEditor",
                  "props": {
                    "name": "content",
                    "multilingual": true,
                    "value": "{{_local.form?.content ?? ''}}",
                    "placeholder": "$t:sirsoft-ecommerce.admin.common_info.form.placeholder_html",
                    "rows": 10,
                    "disabled": "{{_global.panelMode === 'edit' && _global.selectedItem?.abilities?.can_update !== true}}",
                    "showHtmlModeToggle": true,
                    "isHtml": "{{(_local.form?.content_mode ?? 'text') === 'html'}}"
                  },
                  "actions": [
                    {
                      "event": "onChange",
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form.content": "{{$event.target.value}}",
                        "form.content_mode": "html"
                      }
                    },
                    {
                      "event": "onIsHtmlChange",
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form.content_mode": "{{$args[0].target.checked ? 'html' : 'text'}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "status_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-200 dark:border-gray-700 pt-4 mt-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "text-label-subtle block font-medium mb-3"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.form.status_section"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid grid-cols-2 gap-6"
              },
              "children": [
                {
                  "id": "default_setting_col",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-3"
                  },
                  "children": [
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "checked": "{{_local.form.is_default}}",
                        "disabled": "{{_global.panelMode === 'edit' && _global.selectedItem?.abilities?.can_update !== true}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "sequence",
                          "actions": [
                            {
                              "handler": "switch",
                              "params": {
                                "value": "{{$event && !_local.form.is_default}}"
                              },
                              "cases": {
                                "true": {
                                  "handler": "sequence",
                                  "actions": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "defaultModal": {
                                          "isOpen": true
                                        }
                                      }
                                    },
                                    {
                                      "handler": "openModal",
                                      "target": "default_confirm_modal"
                                    }
                                  ]
                                },
                                "false": {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "form.is_default": "{{$event}}"
                                  }
                                }
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-body"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.common_info.form.status_default"
                    }
                  ]
                },
                {
                  "id": "active_setting_col",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-3"
                  },
                  "children": [
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "checked": "{{_local.form.is_active}}",
                        "disabled": "{{_global.panelMode === 'edit' && _global.selectedItem?.abilities?.can_update !== true}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form.is_active": "{{$event}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-body"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.common_info.form.status_active"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
