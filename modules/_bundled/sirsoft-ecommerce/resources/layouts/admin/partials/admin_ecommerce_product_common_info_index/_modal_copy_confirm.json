{
  "meta": {
    "is_partial": true,
    "description": "Common Info Copy Confirm Modal"
  },
  "id": "copy_confirm_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.common_info.modal.copy.title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-body text-center"
      },
      "text": "$t:sirsoft-ecommerce.admin.common_info.modal.copy.message|name={{$localized(_global.selectedItem?.name)}}"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700"
          },
          "text": "$t:sirsoft-ecommerce.admin.common_info.button.cancel",
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 text-sm bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100"
          },
          "text": "$t:sirsoft-ecommerce.admin.common_info.modal.copy.confirm",
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "panelMode": "copy"
                  }
                },
                {
                  "handler": "closeModal"
                },
                {
                  "handler": "emitEvent",
                  "params": {
                    "event": "common_info:init_copy_form",
                    "data": {
                      "name": "{{_global.selectedItem.name}}",
                      "content": "{{_global.selectedItem.content}}",
                      "content_mode": "{{_global.selectedItem.content_mode}}",
                      "is_default": false,
                      "is_active": "{{_global.selectedItem.is_active}}"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
