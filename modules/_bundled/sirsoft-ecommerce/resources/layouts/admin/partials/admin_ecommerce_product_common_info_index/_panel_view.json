{
  "meta": {
    "is_partial": true,
    "description": "Common Info View Panel - Read-only Details with Language Tabs"
  },
  "id": "view_panel",
  "type": "basic",
  "name": "Div",
  "if": "{{_global.selectedId && _global.panelMode === 'view'}}",
  "children": [
    {
      "id": "view_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 panel-header"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-heading"
          },
          "text": "$t:sirsoft-ecommerce.admin.common_info.detail.title"
        }
      ]
    },
    {
      "id": "view_content",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "p-4"
      },
      "children": [
        {
          "id": "info_name_display",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mb-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-tertiary mb-1"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.detail.name"
            },
            {
              "type": "basic",
              "name": "H2",
              "props": {
                "className": "section-heading"
              },
              "text": "{{$localized(_global.selectedItem?.name)}}"
            }
          ]
        },
        {
          "id": "status_badges",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2 mb-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-tertiary mr-2"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.detail.status"
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_global.selectedItem?.is_default}}",
              "props": {
                "className": "text-secondary px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.detail.default"
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_global.selectedItem?.is_active}}",
              "props": {
                "className": "px-2 py-0.5 text-xs bg-green-100 dark:bg-green-900/20 text-green-600 dark:text-green-400 rounded"
              },
              "text": "$t:sirsoft-ecommerce.admin.common_info.detail.active"
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{!_global.selectedItem?.is_active}}",
              "props": {
                "className": "text-secondary px-2 py-0.5 text-xs bg-gray-100 dark:bg-gray-700 rounded"
              },
              "text": "$t:sirsoft-ecommerce.common.inactive"
            }
          ]
        },
        {
          "id": "dates_display",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid-2col mb-6 text-sm"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-tertiary mb-1"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.common_info.detail.created_at"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-primary"
                  },
                  "text": "{{_global.selectedItem?.created_at | datetime('YYYY-MM-DD HH:mm:ss')}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-tertiary mb-1"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.common_info.detail.updated_at"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-primary"
                  },
                  "text": "{{_global.selectedItem?.updated_at | datetime('YYYY-MM-DD HH:mm:ss')}}"
                }
              ]
            }
          ]
        },
        {
          "id": "content_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-200 dark:border-gray-700 pt-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 mb-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "globe",
                    "className": "w-4 h-4 text-gray-500 dark:text-gray-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-heading"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.common_info.detail.content"
                }
              ]
            },
            {
              "id": "language_tabs",
              "type": "composite",
              "name": "TabNavigation",
              "props": {
                "tabs": "{{($locales ?? []).map(l => ({ id: l, label: _global.appConfig?.localeNames?.[l] ?? l }))}}",
                "activeTabId": "{{_local.viewLocale ?? $locale}}",
                "variant": "underline",
                "className": "mb-4"
              },
              "actions": [
                {
                  "event": "onTabChange",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "viewLocale": "{{$args[0]}}"
                  }
                }
              ]
            },
            {
              "id": "content_display",
              "type": "extension_point",
              "name": "html_content",
              "props": {
                "content": "{{_global.selectedItem?.content?.[_local.viewLocale ?? $locale] ?? ''}}",
                "isHtml": "{{(_global.selectedItem?.content_mode ?? 'text') === 'html'}}",
                "className": "p-4 bg-gray-50 dark:bg-gray-900 rounded-lg min-h-[200px] prose prose-sm dark:prose-invert max-w-none text-gray-900 dark:text-gray-100"
              },
              "default": [
                {
                  "type": "composite",
                  "name": "HtmlContent",
                  "props": {
                    "content": "{{_global.selectedItem?.content?.[_local.viewLocale ?? $locale] ?? ''}}",
                    "isHtml": "{{(_global.selectedItem?.content_mode ?? 'text') === 'html'}}",
                    "className": "p-4 bg-gray-50 dark:bg-gray-900 rounded-lg min-h-[200px] prose prose-sm dark:prose-invert max-w-none text-gray-900 dark:text-gray-100"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "view_footer",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 py-4 border-t border-gray-200 dark:border-gray-700"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_global.selectedItem?.abilities?.can_update !== true}}",
                "className": "flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 text-body rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "openModal",
                  "target": "copy_confirm_modal"
                }
              ],
              "text": "$t:sirsoft-ecommerce.admin.common_info.detail.copy"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_global.selectedItem?.abilities?.can_update !== true}}",
                "className": "flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 text-body rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "openModal",
                  "target": "modal_set_default_confirm"
                }
              ],
              "text": "$t:sirsoft-ecommerce.admin.common_info.button.set_default"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_global.selectedItem?.abilities?.can_update !== true}}",
                "className": "flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 text-body rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form": "{{_global.selectedItem}}",
                        "isSaving": false,
                        "errors": null,
                        "showPreview": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "panelMode": "edit"
                      }
                    }
                  ]
                }
              ],
              "text": "$t:sirsoft-ecommerce.admin.common_info.button.edit"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "flex-1 px-4 py-2 text-red-600 dark:text-red-400 border border-red-300 dark:border-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors text-sm disabled:opacity-50 disabled:cursor-not-allowed",
                "disabled": "{{_global.selectedItem?.abilities?.can_delete !== true}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "deleteModal": {
                          "itemId": "{{_global.selectedId}}",
                          "itemName": "{{$localized(_global.selectedItem?.name)}}"
                        }
                      }
                    },
                    {
                      "handler": "openModal",
                      "target": "delete_confirm_modal"
                    }
                  ]
                }
              ],
              "text": "$t:sirsoft-ecommerce.admin.common_info.button.delete"
            }
          ]
        }
      ]
    }
  ]
}
