{
  "meta": {
    "is_partial": true,
    "description": "Order Detail - Payment Info Tab"
  },
  "id": "section_payment_info",
  "type": "basic",
  "name": "Div",
  "props": {
    "data-section-id": "payment_info"
  },
  "children": [
    {
      "id": "payment_info_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H2",
          "props": {
            "className": "text-lg font-bold text-gray-900 dark:text-gray-100 mb-6"
          },
          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.title"
        },
        {
          "id": "payment_cards",
          "type": "basic",
          "name": "Div",
          "iteration": {
            "source": "{{order.data?.payments ?? []}}",
            "item_var": "payment",
            "index_var": "payIdx"
          },
          "props": {
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "border border-gray-200 dark:border-gray-700 rounded-lg p-5"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-between mb-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-3"
                      },
                      "children": [
                        {
                          "type": "composite",
                          "name": "Badge",
                          "props": {
                            "variant": "outline"
                          },
                          "text": "{{payment.payment_type_label}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-semibold text-gray-900 dark:text-gray-100"
                          },
                          "text": "{{payment.payment_number}}"
                        }
                      ]
                    },
                    {
                      "type": "composite",
                      "name": "Badge",
                      "props": {
                        "variant": "{{payment.payment_status_variant}}"
                      },
                      "text": "{{payment.payment_status_label}}"
                    }
                  ]
                },
                {
                  "comment": "무통장 입금확인 버튼 — 무통장(dbank) + 결제정보 자체가 미입금(payment_status=ready/waiting_deposit)인 결제건만 노출. order_status 가 아닌 payment 단위 상태로 판정해야 함(버튼이 payments 반복 내 결제카드 단위로 그려지고, order_status 가 다른 경로로 먼저 결제완료로 전이돼도 미입금 결제는 입금확인이 필요하므로).",
                  "type": "basic",
                  "name": "Div",
                  "if": "{{payment.payment_method === 'dbank' && (payment.payment_status === 'ready' || payment.payment_status === 'waiting_deposit')}}",
                  "props": {
                    "className": "mb-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "flex-center gap-2 px-4 py-2 text-sm bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "sirsoft-ecommerce.openConfirmDepositModal"
                        }
                      ],
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "circle-check",
                            "size": "sm"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.confirm_deposit.confirm"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Hr",
                  "props": {
                    "className": "border-gray-100 dark:border-gray-800 mb-4"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "row-stack"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "grid-2col-responsive"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-tertiary block"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.payment_method"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm font-semibold text-gray-900 dark:text-gray-100 block"
                              },
                              "text": "{{payment.payment_method_label}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{payment.account_info}}",
                              "props": {
                                "className": "text-tertiary block"
                              },
                              "text": "{{payment.account_info}}"
                            },
                            {
                              "comment": "결제 통화(order_currency) — 유저가 선택·결제한 통화. base 통화와 다를 때 함께 표기.",
                              "type": "basic",
                              "name": "Span",
                              "if": "{{payment.is_cross_currency}}",
                              "props": {
                                "className": "text-tertiary block"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.payment_currency|currency={{payment.payment_currency}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-tertiary block"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.payment_request_date"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm text-gray-900 dark:text-gray-100 block"
                              },
                              "text": "{{payment.requested_at_formatted}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "grid-2col-responsive"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{payment.paid_at_formatted}}",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-tertiary block"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.payment_date"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm text-gray-900 dark:text-gray-100 block"
                              },
                              "text": "{{payment.paid_at_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{payment.due_date_formatted}}",
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-tertiary block"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.due_date"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm text-red-600 dark:text-red-400 font-medium block"
                              },
                              "text": "{{payment.due_date_formatted}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Hr",
                  "props": {
                    "className": "border-gray-100 dark:border-gray-800 mb-4"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-secondary"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.order_amount"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-900 dark:text-gray-100"
                          },
                          "text": "{{order.data?.subtotal_amount_formatted}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-secondary"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.shipping_fee"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-900 dark:text-gray-100"
                          },
                          "text": "{{order.data?.total_shipping_amount_formatted}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "if": "{{order.data?.total_discount_amount > 0}}",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex justify-between text-sm"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-red-600 dark:text-red-400 font-medium"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.total_discount"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-red-600 dark:text-red-400"
                              },
                              "text": "-{{order.data?.total_discount_amount_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{order.data?.total_product_coupon_discount_amount > 0}}",
                          "props": {
                            "className": "flex justify-between text-xs pl-4"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.coupon"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "-{{order.data?.total_product_coupon_discount_amount_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{order.data?.total_code_discount_amount > 0}}",
                          "props": {
                            "className": "flex justify-between text-xs pl-4"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.discount_code"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "-{{order.data?.total_code_discount_amount_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{payment.event_discount_amount > 0}}",
                          "props": {
                            "className": "flex justify-between text-xs pl-4"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.event"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "-{{payment.event_discount_amount_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{payment.referral_discount_amount > 0}}",
                          "props": {
                            "className": "flex justify-between text-xs pl-4"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.referral"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-400"
                              },
                              "text": "-{{payment.referral_discount_amount_formatted}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "if": "{{order.data?.total_points_used_amount > 0}}",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-purple-600 dark:text-purple-400"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.mileage_used"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-purple-600 dark:text-purple-400"
                          },
                          "text": "-{{order.data?.total_points_used_amount_formatted}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "if": "{{order.data?.total_deposit_used_amount > 0}}",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-green-600 dark:text-green-400"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.deposit_used"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-green-600 dark:text-green-400"
                          },
                          "text": "-{{order.data?.total_deposit_used_amount_formatted}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex justify-between text-sm font-bold border-t border-gray-200 dark:border-gray-700"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-900 dark:text-gray-100"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.final_amount"
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "text-right"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-900 dark:text-gray-100 block"
                              },
                              "text": "{{order.data?.total_paid_amount_formatted}}"
                            },
                            {
                              "comment": "결제 통화 실청구액 — base≠결제 통화일 때 병기(유저가 실제 결제한 통화/금액)",
                              "type": "basic",
                              "name": "Span",
                              "if": "{{payment.is_cross_currency}}",
                              "props": {
                                "className": "text-hint block font-normal"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.charged_in_payment_currency|currency={{payment.payment_currency}}|amount={{payment.paid_amount_formatted}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "comment": "취소/환불 요약 — 취소·환불 금액은 주문(Order) 레벨 집계(total_cancelled/refunded_amount, total_refunded_points_amount)가 SSoT. 결제(payment) 레벨에는 환불 마일리지/환불액 합계가 없으므로 order.data 를 바인딩한다. 개별 환불 레코드의 상태는 환불 탭(claim_history)에서 표시.",
                      "name": "Div",
                      "if": "{{(order.data?.total_cancelled_amount ?? 0) > 0 || (order.data?.total_refunded_amount ?? 0) > 0 || (order.data?.total_refunded_points_amount ?? 0) > 0}}",
                      "props": {
                        "className": "space-y-2 border-t border-red-200 dark:border-red-800"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{(order.data?.total_cancelled_amount ?? 0) > 0}}",
                          "props": {
                            "className": "flex justify-between text-sm"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-red-600 dark:text-red-400 font-medium"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.cancelled_amount"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-red-600 dark:text-red-400 font-medium"
                              },
                              "text": "-{{order.data?.total_cancelled_amount_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{(order.data?.total_refunded_amount ?? 0) > 0}}",
                          "props": {
                            "className": "flex justify-between text-sm"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-orange-600 dark:text-orange-400"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.refunded_amount"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-orange-600 dark:text-orange-400"
                              },
                              "text": "-{{order.data?.total_refunded_amount_formatted}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{(order.data?.total_refunded_points_amount ?? 0) > 0}}",
                          "props": {
                            "className": "flex justify-between text-sm"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-purple-600 dark:text-purple-400"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.refund_points_amount"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-purple-600 dark:text-purple-400"
                              },
                              "text": "-{{order.data?.total_refunded_points_amount_formatted}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Hr",
                      "props": {
                        "className": "border-gray-100 dark:border-gray-800"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.taxable_amount"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-700 dark:text-gray-300"
                          },
                          "text": "{{order.data?.total_tax_amount_formatted}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.vat"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-700 dark:text-gray-300"
                          },
                          "text": "{{order.data?.total_vat_amount_formatted}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "if": "{{order.data?.total_earned_points_amount > 0 && order.data?.order_status !== 'cancelled' && !order.data?.is_partially_cancelled}}",
                      "props": {
                        "className": "flex justify-between text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-blue-600 dark:text-blue-400"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.order.detail.payment_info.expected_points"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-blue-600 dark:text-blue-400"
                          },
                          "text": "{{order.data?.total_earned_points_amount | number}}P"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
