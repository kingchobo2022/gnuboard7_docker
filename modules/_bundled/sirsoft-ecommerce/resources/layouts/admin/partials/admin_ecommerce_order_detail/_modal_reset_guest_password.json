{
  "meta": {
    "is_partial": true,
    "description": "Order Detail - Reset Guest Lookup Password Modal"
  },
  "id": "modal_reset_guest_password",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.title",
    "size": "md",
    "closeOnOverlayClick": false,
    "closeOnEscape": false
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-4"
      },
      "lifecycle": {
        "onMount": [
          {
            "handler": "setState",
            "params": {
              "target": "$parent._local",
              "isResettingGuestPassword": false,
              "guestPasswordErrors": null,
              "guestNewPassword": "",
              "guestNewPasswordConfirmation": ""
            }
          }
        ]
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.description"
        },
        {
          "comment": "주문 정보 요약 (주문번호 / 주문자명 / 전화번호)",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-3 space-y-1.5 text-sm"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "w-16 flex-shrink-0 text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.order_number"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "font-medium text-gray-900 dark:text-gray-100"
                  },
                  "text": "{{route.orderNumber}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "w-16 flex-shrink-0 text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.orderer_name"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-900 dark:text-gray-100"
                  },
                  "text": "{{order?.data?.orderer_name ?? '-'}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "w-16 flex-shrink-0 text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.orderer_phone"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-gray-900 dark:text-gray-100"
                  },
                  "text": "{{order?.data?.orderer_phone ?? '-'}}"
                }
              ]
            }
          ]
        },
        {
          "comment": "새 비밀번호 필드 (회원 폼과 동일 패턴: 라벨 + password input + 인라인 에러)",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label-block"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.new_password"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-required"
                  },
                  "text": "*"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "password",
                "name": "guest_lookup_password",
                "autoComplete": "new-password",
                "placeholder": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.new_password_placeholder",
                "className": "{{$parent._local.guestPasswordErrors?.guest_lookup_password ? 'w-full px-3 py-2 border border-red-500 dark:border-red-400 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 dark:focus:ring-red-400' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400'}}",
                "value": "{{$parent._local.guestNewPassword}}"
              },
              "actions": [
                {
                  "type": "input",
                  "handler": "setState",
                  "params": {
                    "target": "$parent._local",
                    "guestNewPassword": "{{$event.target.value}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{$parent._local.guestPasswordErrors?.guest_lookup_password}}",
              "props": {
                "className": "form-error-xs mt-1 block"
              },
              "text": "{{$parent._local.guestPasswordErrors?.guest_lookup_password?.[0] ?? ''}}"
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{!$parent._local.guestPasswordErrors?.guest_lookup_password}}",
              "props": {
                "className": "text-hint mt-1 block"
              },
              "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.hint"
            }
          ]
        },
        {
          "comment": "새 비밀번호 확인 필드",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label-block"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.new_password_confirmation"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-required"
                  },
                  "text": "*"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "password",
                "name": "guest_lookup_password_confirmation",
                "autoComplete": "new-password",
                "placeholder": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.new_password_confirmation_placeholder",
                "className": "text-primary w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400",
                "value": "{{$parent._local.guestNewPasswordConfirmation}}"
              },
              "actions": [
                {
                  "type": "input",
                  "handler": "setState",
                  "params": {
                    "target": "$parent._local",
                    "guestNewPasswordConfirmation": "{{$event.target.value}}"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{$parent._local.isResettingGuestPassword}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 text-sm bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{$parent._local.isResettingGuestPassword || !$parent._local.guestNewPassword || !$parent._local.guestNewPasswordConfirmation}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "$parent._local",
                    "isResettingGuestPassword": true,
                    "guestPasswordErrors": null
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_mode": "required",
                  "target": "/api/modules/sirsoft-ecommerce/admin/orders/{{route.orderNumber}}/reset-guest-lookup-password",
                  "params": {
                    "method": "POST",
                    "body": {
                      "guest_lookup_password": "{{$parent._local.guestNewPassword}}",
                      "guest_lookup_password_confirmation": "{{$parent._local.guestNewPasswordConfirmation}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "isResettingGuestPassword": false,
                        "guestNewPassword": "",
                        "guestNewPasswordConfirmation": "",
                        "guestPasswordErrors": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "message": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.reset_success",
                        "type": "success"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "isResettingGuestPassword": false,
                        "guestPasswordErrors": "{{error.errors}}"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "message": "{{error.message}}",
                        "type": "error"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{$parent._local.isResettingGuestPassword}}",
              "props": {
                "name": "spinner",
                "className": "animate-spin",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.reset_guest_password.reset"
            }
          ]
        }
      ]
    }
  ]
}
