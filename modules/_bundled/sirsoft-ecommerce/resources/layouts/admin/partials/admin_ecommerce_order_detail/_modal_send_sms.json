{
  "meta": {
    "is_partial": true,
    "description": "Order Detail - Send SMS Modal"
  },
  "id": "modal_send_sms",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.title",
    "size": "md"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.description"
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "form-label-block"
              },
              "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.phone"
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "text",
                "className": "input-readonly",
                "value": "{{_local.smsPhone}}",
                "readOnly": true
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-between mb-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-body font-medium"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.message"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-hint"
                  },
                  "text": "{{(_local.smsMessage || '').length}}자"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Textarea",
              "props": {
                "className": "input w-full min-h-[100px]",
                "placeholder": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.message_placeholder",
                "value": "{{_local.smsMessage}}",
                "dataKey": "smsMessage"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center text-hint gap-1"
          },
          "children": [
            {
              "type": "composite",
              "name": "Icon",
              "props": {
                "name": "puzzle-piece",
                "className": "text-xs"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.plugin_label"
            }
          ]
        }
      ],
      "props": {
      }
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isSending}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isSending}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isSending}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isSending ? '$t:common.sending' : '$t:sirsoft-ecommerce.admin.order.detail.modal.send_sms.send'}}"
            }
          ]
        }
      ]
    }
  ]
}
