                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "value": "{{String(_local.logsPerPage)}}",
                    "className": "w-auto min-w-20",
                    "options": [
                      {
                        "value": "5",
                        "label": "$t:sirsoft-ecommerce.admin.order.detail.activity_log.per_page_option|count=5"
                      },
                      {
                        "value": "10",
                        "label": "$t:sirsoft-ecommerce.admin.order.detail.activity_log.per_page_option|count=10"
                      },
                      {
                        "value": "20",
                        "label": "$t:sirsoft-ecommerce.admin.order.detail.activity_log.per_page_option|count=20"
                      },
                      {
                        "value": "50",
                        "label": "$t:sirsoft-ecommerce.admin.order.detail.activity_log.per_page_option|count=50"
                      }
                    ]
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "sequence",
                      "params": {
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "local",
                              "logsPerPage": "{{Number($event.target.value)}}",
                              "logsPage": 1
                            }
                          },
                          {
                            "handler": "refetchDataSource",
                            "params": {
                              "dataSourceId": "order_logs"
