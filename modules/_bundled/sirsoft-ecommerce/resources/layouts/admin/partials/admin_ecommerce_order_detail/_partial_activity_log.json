                                "className": "w-20 text-center"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.order.detail.activity_log.changes.after"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "iteration": {
                            "source": "{{group.changes ?? []}}",
                            "item_var": "change",
                            "index_var": "changeIdx"
                          },
                          "props": {
                            "className": "px-3 py-1.5 text-xs flex gap-3 border-t border-gray-100 dark:border-gray-700"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "flex-1 font-medium text-gray-700 dark:text-gray-300"
                              },
                              "text": "{{change.label ?? change.field}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "w-20 text-center text-red-600 dark:text-red-400"
                              },
                              "text": "{{change.old_label ?? change.old ?? '-'}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "w-20 text-center text-green-600 dark:text-green-400"
                              },
                              "text": "{{change.new_label ?? change.new ?? '-'}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "log_pagination",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-center pt-4 border-t border-gray-200 dark:border-gray-700 mt-4"
          },
          "children": [
            {
              "type": "composite",
              "name": "Pagination",
              "props": {
                "currentPage": "{{order_logs.data?.meta?.current_page ?? 1}}",
                "totalPages": "{{order_logs.data?.meta?.last_page ?? 1}}",
                "showFirstLast": true
              },
              "actions": [
                {
                  "event": "onPageChange",
                  "handler": "sequence",
                  "params": {
                    "actions": [
                      {
                        "handler": "setState",
                        "params": {
                          "target": "local",
                          "logsPage": "{{$args[0]}}"
                        }
                      },
                      {
                        "handler": "refetchDataSource",
                        "params": {
                          "dataSourceId": "order_logs"
                        }
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
