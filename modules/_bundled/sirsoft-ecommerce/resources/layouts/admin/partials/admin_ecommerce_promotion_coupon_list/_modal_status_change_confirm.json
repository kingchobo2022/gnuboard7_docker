{
  "meta": {
    "is_partial": true,
    "description": "Coupon - Status Change Confirm Modal"
  },
  "id": "modal_status_change_confirm",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.promotion_coupon.modal.status_change.title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "if": "{{_global.bulkIssueStatus === 'issuing'}}",
      "props": {
        "className": "text-secondary"
      },
      "text": "$t:sirsoft-ecommerce.admin.promotion_coupon.modal.status_change.message|count={{(_global.bulkSelectedItems ?? []).length}}|status=$t:sirsoft-ecommerce.enums.coupon_issue_status.issuing"
    },
    {
      "type": "basic",
      "name": "P",
      "if": "{{_global.bulkIssueStatus !== 'issuing'}}",
      "props": {
        "className": "text-secondary"
      },
      "text": "$t:sirsoft-ecommerce.admin.promotion_coupon.modal.status_change.message|count={{(_global.bulkSelectedItems ?? []).length}}|status=$t:sirsoft-ecommerce.enums.coupon_issue_status.stopped"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isChangingStatus}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isChangingStatus}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isChangingStatus": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/modules/sirsoft-ecommerce/admin/promotion-coupons/bulk-status",
                  "params": {
                    "method": "PATCH",
                    "body": {
                      "ids": "{{_global.bulkSelectedItems}}",
                      "issue_status": "{{_global.bulkIssueStatus}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isChangingStatus": false,
                        "bulkSelectedItems": [],
                        "bulkIssueStatus": ""
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "coupons"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.admin.promotion_coupon.toast.status_changed"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isChangingStatus": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "$t:sirsoft-ecommerce.common.error.general"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isChangingStatus}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isChangingStatus ? '$t:sirsoft-ecommerce.common.processing' : '$t:common.confirm'}}"
            }
          ]
        }
      ]
    }
  ]
}
