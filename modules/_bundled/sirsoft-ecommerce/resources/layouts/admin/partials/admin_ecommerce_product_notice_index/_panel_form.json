{
  "meta": {
    "is_partial": true,
    "description": "Product Notice Template Form Panel - Create/Edit Form with Dynamic Fields"
  },
  "id": "form_panel",
  "type": "basic",
  "name": "Div",
  "if": "{{_global.panelMode === 'create' || _global.panelMode === 'edit'}}",
  "children": [
    {
      "id": "form_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 panel-header flex-between"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "if": "{{_global.panelMode === 'create'}}",
          "props": {
            "className": "text-heading"
          },
          "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.create_title"
        },
        {
          "type": "basic",
          "name": "H3",
          "if": "{{_global.panelMode === 'edit'}}",
          "props": {
            "className": "text-heading"
          },
          "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.edit_title"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "px-3 py-1.5 text-label hover:bg-gray-100 dark:bg-gray-700 dark:hover:bg-gray-700 rounded-lg transition-colors"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "panelMode": "{{_global.selectedTemplateId ? 'view' : 'empty'}}"
                  }
                },
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "errors": null,
                    "form": null
                  }
                }
              ],
              "text": "$t:sirsoft-ecommerce.common.cancel"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "submit",
                "form": "template_form",
                "disabled": "{{_local?.isSaving || (_global.panelMode === 'edit' && _global.selectedTemplate?.abilities?.can_update !== true)}}",
                "className": "flex-center gap-1.5 px-3 py-1.5 text-sm bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{!_local.isSaving}}",
                  "props": {
                    "name": "save",
                    "className": "w-4 h-4"
                  }
                },
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{_local.isSaving}}",
                  "props": {
                    "name": "spinner",
                    "className": "spinner-sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{!_local.isSaving}}",
                  "text": "$t:sirsoft-ecommerce.common.save"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.isSaving}}",
                  "text": "$t:sirsoft-ecommerce.common.saving"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "validation_error",
      "type": "basic",
      "name": "Div",
      "if": "{{_local.errors}}",
      "props": {
        "className": "alert-danger"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "w-5 h-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "H3",
                  "props": {
                    "className": "text-error-strong"
                  },
                  "text": "$t:common.validation_error"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "if": "{{typeof _local.errors === 'string'}}",
                  "props": {
                    "className": "text-error-soft mt-2"
                  },
                  "text": "{{_local.errors}}"
                },
                {
                  "type": "basic",
                  "name": "Ul",
                  "if": "{{typeof _local.errors === 'object' && Object.keys(_local.errors).length > 0}}",
                  "props": {
                    "className": "mt-2 list-disc list-inside space-y-1"
                  },
                  "iteration": {
                    "source": "Object.entries(_local.errors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                    "item_var": "message"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Li",
                      "props": {
                        "className": "text-error-soft"
                      },
                      "text": "{{message}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "template_form",
      "type": "basic",
      "name": "Form",
      "dataKey": "form",
      "trackChanges": true,
      "props": {
        "id": "template_form",
        "className": "p-4 space-y-6"
      },
      "actions": [
        {
          "type": "submit",
          "handler": "sequence",
          "actions": [
            {
              "handler": "setState",
              "params": {
                "target": "local",
                "isSaving": true,
                "errors": null
              }
            },
            {
              "handler": "apiCall",
              "auth_required": true,
              "target": "{{_global.panelMode === 'create' ? '/api/modules/sirsoft-ecommerce/admin/product-notice-templates' : '/api/modules/sirsoft-ecommerce/admin/product-notice-templates/' + _global.selectedTemplateId}}",
              "params": {
                "method": "{{_global.panelMode === 'create' ? 'POST' : 'PUT'}}",
                "body": "{{_local.form}}"
              },
              "onSuccess": [
                {
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "toast",
                      "if": "{{_global.panelMode === 'create'}}",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.admin.product_notice_template.messages.created"
                      }
                    },
                    {
                      "handler": "toast",
                      "if": "{{_global.panelMode === 'edit'}}",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.admin.product_notice_template.messages.updated"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "templates"
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "panelMode": "view",
                        "selectedTemplateId": "{{result.data.id}}",
                        "selectedTemplate": "{{result.data}}"
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isSaving": false,
                        "errors": null
                      }
                    }
                  ]
                }
              ],
              "onError": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "isSaving": false,
                    "errors": "{{error.errors}}"
                  }
                },
                {
                  "handler": "toast",
                  "params": {
                    "type": "error",
                    "message": "{{error.message}}",
                    "icon": "triangle-exclamation"
                  }
                }
              ]
            }
          ]
        }
      ],
      "children": [
        {
          "id": "form_name_section",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "id": "form_name_label",
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.name"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-required"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "id": "form_name_input",
                  "type": "composite",
                  "name": "MultilingualInput",
                  "props": {
                    "name": "name",
                    "placeholder": "$t:sirsoft-ecommerce.admin.product_notice_template.form.name_placeholder",
                    "layout": "tabs",
                    "disabled": "{{_global.panelMode === 'edit' && _global.selectedTemplate?.abilities?.can_update !== true}}",
                    "error": "{{_local.errors?.name?.[0] ?? _local.errors?.['name.ko']?.[0] ?? ''}}"
                  }
                }
              ],
              "props": {
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-200 dark:border-gray-700 pt-6"
          }
        },
        {
          "id": "form_fields_section",
          "type": "basic",
          "name": "Div",
          "onComponentEvent": [
            {
              "event": "notice:bulkChangeConfirmed",
              "handler": "sirsoft-ecommerce.fillTemplateFieldsWithDetailReference",
              "params": {
                "form": "{{_eventData.form}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-between"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "H4",
                      "props": {
                        "className": "text-body font-medium"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.fields_title"
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "disabled": "{{_global.panelMode === 'edit' && _global.selectedTemplate?.abilities?.can_update !== true}}",
                        "className": "px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "sequence",
                          "actions": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "tempFormForBulkChange": "{{_local.form}}"
                              }
                            },
                            {
                              "handler": "openModal",
                              "target": "bulk_change_modal"
                            }
                          ]
                        }
                      ],
                      "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.fill_detail_ref"
                    }
                  ]
                },
                {
                  "id": "fields_tab_panel",
                  "type": "composite",
                  "name": "MultilingualTabPanel",
                  "props": {
                    "variant": "underline",
                    "className": ""
                  },
                  "children": [
                    {
                      "id": "fields_editor",
                      "type": "composite",
                      "name": "DynamicFieldList",
                      "props": {
                        "name": "fields",
                        "items": "{{_local.form.fields ?? []}}",
                        "columns": [
                          {
                            "key": "name",
                            "type": "multilingual",
                            "label": "$t:sirsoft-ecommerce.admin.product_notice_template.fields.name",
                            "placeholder": "$t:sirsoft-ecommerce.admin.product_notice_template.form.field_name_placeholder"
                          },
                          {
                            "key": "content",
                            "type": "multilingual",
                            "label": "$t:sirsoft-ecommerce.admin.product_notice_template.fields.content",
                            "placeholder": "$t:sirsoft-ecommerce.admin.product_notice_template.form.field_content_placeholder"
                          }
                        ],
                        "addLabel": "$t:sirsoft-ecommerce.admin.product_notice_template.form.add_field",
                        "enableDrag": true,
                        "disabled": "{{_global.panelMode === 'edit' && _global.selectedTemplate?.abilities?.can_update !== true}}",
                        "minItems": 1,
                        "emptyMessage": "$t:sirsoft-ecommerce.admin.product_notice_template.form.empty_fields",
                        "errors": "{{_local.errors}}"
                      },
                      "actions": [
                        {
                          "event": "onChange",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form.fields": "{{$args[0]}}"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.fields}}",
                  "props": {
                    "className": "form-error-xs"
                  },
                  "text": "{{_local.errors?.fields?.[0] ?? ''}}"
                }
              ],
              "props": {
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-200 dark:border-gray-700 pt-6"
          }
        },
        {
          "id": "form_status_section",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "id": "form_status_title",
                  "type": "basic",
                  "name": "H4",
                  "props": {
                    "className": "text-table-header"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.status_title"
                },
                {
                  "id": "form_toggle",
                  "type": "composite",
                  "name": "Toggle",
                  "props": {
                    "label": "$t:sirsoft-ecommerce.admin.product_notice_template.form.is_active",
                    "name": "is_active",
                    "disabled": "{{_global.panelMode === 'edit' && _global.selectedTemplate?.abilities?.can_update !== true}}"
                  }
                }
              ],
              "props": {
              }
            }
          ]
        }
      ]
    }
  ]
}
