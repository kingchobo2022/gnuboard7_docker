{
  "meta": {
    "is_partial": true,
    "description": "Product Notice Template Bulk Change Confirmation Modal"
  },
  "id": "bulk_change_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.product_notice_template.modals.bulk_change.title",
    "size": "medium"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-start gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-shrink-0 mt-0.5"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "info-circle",
                    "className": "w-5 h-5 text-blue-600 dark:text-blue-400"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-primary text-base mb-2"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product_notice_template.modals.bulk_change.message"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "bg-gray-100 dark:bg-gray-700 rounded-lg p-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.product_notice_template.modals.bulk_change.preview_label"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-primary font-medium mt-1"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.product_notice_template.form.detail_reference"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm text-amber-600 dark:text-amber-400 mt-3"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product_notice_template.modals.bulk_change.notice"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "emitEvent",
                  "params": {
                    "event": "notice:bulkChangeConfirmed",
                    "data": {
                      "form": "{{_global.tempFormForBulkChange}}"
                    }
                  }
                },
                {
                  "handler": "closeModal"
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.product_notice_template.modals.bulk_change.confirm"
            }
          ]
        }
      ]
    }
  ]
}
