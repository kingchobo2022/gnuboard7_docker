{
  "meta": {
    "is_partial": true,
    "description": "Shipping Policy Bulk Delete Confirmation Modal"
  },
  "id": "bulk_delete_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.bulk_delete.title",
    "size": "medium"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-gray-700 dark:text-gray-300"
              },
              "text": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.bulk_delete.message|count={{(_global.bulkSelectedItems || []).length}}"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "alert-warning"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "triangle-exclamation",
                    "className": "w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0 mt-0.5"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-warning-soft"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.bulk_delete.warning"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "mt-1"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.bulk_delete.product_warning"
                    }
                  ]
                }
              ]
            }
          ],
          "props": {
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isBulkDeleting}}"
          },
          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.common.cancel",
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isBulkDeleting}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isBulkDeleting}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isBulkDeleting ? '$t:sirsoft-ecommerce.admin.shipping_policy.common.deleting' : '$t:sirsoft-ecommerce.admin.shipping_policy.common.delete'}}"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isBulkDeleting": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/modules/sirsoft-ecommerce/admin/shipping-policies/bulk",
                  "params": {
                    "method": "DELETE",
                    "body": {
                      "ids": "{{_global.bulkSelectedItems}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isBulkDeleting": false,
                        "bulkSelectedItems": []
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "shipping_policies"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.admin.shipping_policy.messages.bulk_deleted"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isBulkDeleting": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{$error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
