{
  "meta": {
    "is_partial": true,
    "description": "Set Default Shipping Policy Confirmation Modal"
  },
  "id": "set_default_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.set_default.title",
    "size": "medium"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-gray-700 dark:text-gray-300"
              },
              "text": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.set_default.message"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-primary font-medium"
                  },
                  "text": "{{_global.targetDefaultPolicy?.name_localized}}"
                }
              ]
            }
          ],
          "props": {
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isSettingDefault}}"
          },
          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.set_default.cancel",
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "remount",
                  "params": {
                    "componentId": "is_default_toggle_{{_global.targetDefaultPolicy?.id}}"
                  }
                },
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "targetDefaultPolicy": null
                  }
                },
                {
                  "handler": "closeModal"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isSettingDefault}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isSettingDefault}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.set_default.confirm"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isSettingDefault": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/modules/sirsoft-ecommerce/admin/shipping-policies/{{_global.targetDefaultPolicy?.id}}/set-default",
                  "params": {
                    "method": "PATCH"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isSettingDefault": false,
                        "targetDefaultPolicy": null
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "shipping_policies"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.admin.shipping_policy.modal.set_default.success"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isSettingDefault": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{$error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
