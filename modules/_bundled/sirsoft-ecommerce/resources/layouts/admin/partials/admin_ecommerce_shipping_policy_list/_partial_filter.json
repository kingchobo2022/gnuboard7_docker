        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Select",
              "props": {
                "name": "searchType",
                "className": "select-composite w-36",
                "value": "{{_local.filter.searchType || 'name'}}",
                "options": [
                  {
                    "value": "name",
                    "label": "$t:sirsoft-ecommerce.admin.shipping_policy.filter.search_type.name"
                  }
                ]
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "filter.searchType": "{{$event.target.value}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "relative flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "search",
                    "className": "absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 dark:text-gray-500"
                  }
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "search",
                    "placeholder": "$t:sirsoft-ecommerce.admin.shipping_policy.search.placeholder",
                    "className": "input pl-10",
                    "value": "{{_local.filter.search || ''}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "_local",
                        "filter.search": "{{$event.target.value}}"
                      }
                    },
                    {
                      "type": "keypress",
                      "key": "Enter",
                      "actionRef": "searchShippingPolicies"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
