                            "filter.countries": "{{$event.target.checked ? [...(_local.filter.countries || []).filter(c => c !== acountry.code), acountry.code] : (_local.filter.countries || []).filter(c => c !== acountry.code)}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "fi fi-{{acountry.code?.toLowerCase()}} fis rounded"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "{{acountry.code}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "is_active_filter",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "filter-row"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "filter-label w-32"
              },
              "text": "$t:sirsoft-ecommerce.admin.shipping_policy.filter.is_active"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center flex-wrap gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "inline-clickable"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "is_active_filter",
                        "className": "radio",
                        "checked": "{{!_local.filter.is_active || _local.filter.is_active === ''}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "_local",
                            "filter.is_active": ""
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.filter.all"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "inline-clickable"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "is_active_filter",
                        "className": "radio",
                        "checked": "{{_local.filter.is_active === 'true'}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "_local",
                            "filter.is_active": "true"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.filter.active"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "inline-clickable"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "is_active_filter",
                        "className": "radio",
                        "checked": "{{_local.filter.is_active === 'false'}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "_local",
                            "filter.is_active": "false"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.filter.inactive"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "filter_buttons",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-center gap-3 mt-6"
      },
      "responsive": {
        "portable": {
          "props": {
            "className": "flex gap-3 mt-6"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "btn btn-primary px-6"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "btn btn-primary flex-1"
              }
            }
          },
          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.action.search",
          "actions": [
            {
              "type": "click",
              "actionRef": "searchShippingPolicies"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "btn btn-secondary px-6"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "btn btn-secondary flex-1"
              }
            }
          },
          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.action.reset",
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "filter": {
                      "searchType": "name",
                      "search": "",
                      "shipping_methods": [],
                      "charge_policies": [],
                      "countries": [],
                      "is_active": ""
                    }
                  }
                },
                {
                  "handler": "navigate",
                  "params": {
                    "path": "/admin/ecommerce/shipping-policies"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
