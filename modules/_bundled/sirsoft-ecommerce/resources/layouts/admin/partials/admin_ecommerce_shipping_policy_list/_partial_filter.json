                },
                {
                  "type": "basic",
                  "name": "Label",
                  "iteration": {
                    "source": "(ecommerce_settings?.data?.shipping?.types ?? []).filter(t => t.is_active).map(t => ({value: t.code, label: t.name?.[$locale] ?? t.name?.[_global.locale] ?? t.name?.ko ?? t.code}))",
                    "item_var": "option"
                  },
                  "props": {
                    "className": "inline-clickable"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "className": "checkbox",
                        "checked": "{{(_local.filter.shipping_methods || []).includes(option.value)}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "_local",
                            "filter.shipping_methods": "{{$event.target.checked ? [...(_local.filter.shipping_methods || []).filter(m => m !== option.value), option.value] : (_local.filter.shipping_methods || []).filter(m => m !== option.value)}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label"
                      },
                      "text": "{{option.label}}"
                    }
                  ]
                }
              ]
            }
          ]
