{
  "meta": {
    "is_partial": true,
    "description": "Order List - Bulk Action Confirm Modal"
  },
  "id": "modal_bulk_confirm",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_title",
    "size": "md"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-label"
              },
              "text": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_message|count={{(_global.bulkConfirmData?.selectedItems || []).length}}"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "p-3 bg-gray-50 dark:bg-gray-800 rounded-lg space-y-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_global.bulkConfirmData?.orderStatus}}",
                  "props": {
                    "className": "flex-center text-sm"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-gray-500 dark:text-gray-400 w-28 flex-shrink-0"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_status_label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "font-semibold text-gray-900 dark:text-gray-100"
                      },
                      "text": "{{({'pending_order':'$t:sirsoft-ecommerce.admin.order.status.waiting','pending_payment':'$t:sirsoft-ecommerce.admin.order.status.payment_pending','payment_complete':'$t:sirsoft-ecommerce.admin.order.status.payment_complete','shipping_hold':'$t:sirsoft-ecommerce.admin.order.status.shipping_hold','preparing':'$t:sirsoft-ecommerce.admin.order.status.preparing','shipping_ready':'$t:sirsoft-ecommerce.admin.order.status.shipping_ready','shipping':'$t:sirsoft-ecommerce.admin.order.status.shipping','delivered':'$t:sirsoft-ecommerce.admin.order.status.delivered','cancelled':'$t:sirsoft-ecommerce.admin.order.status.cancelled','confirmed':'$t:sirsoft-ecommerce.admin.order.status.confirmed'})[_global.bulkConfirmData.orderStatus] ?? _global.bulkConfirmData.orderStatus}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_global.bulkConfirmData?.courierId}}",
                  "props": {
                    "className": "flex-center text-sm"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-gray-500 dark:text-gray-400 w-28 flex-shrink-0"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_carrier_label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "font-semibold text-gray-900 dark:text-gray-100"
                      },
                      "text": "{{(active_carriers?.data ?? []).find(c => String(c.value) === String(_global.bulkConfirmData.courierId))?.label ?? _global.bulkConfirmData.courierId}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_global.bulkConfirmData?.trackingNumber}}",
                  "props": {
                    "className": "flex-center text-sm"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-gray-500 dark:text-gray-400 w-28 flex-shrink-0"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_tracking_label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "font-semibold text-gray-900 dark:text-gray-100"
                      },
                      "text": "{{_global.bulkConfirmData.trackingNumber}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "if": "{{!_global.bulkConfirmData?.orderStatus && !_global.bulkConfirmData?.courierId && !_global.bulkConfirmData?.trackingNumber}}",
                  "props": {
                    "className": "text-sm text-yellow-600 dark:text-yellow-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_no_changes"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "if": "{{(_global.bulkConfirmData?.orderStatus === 'shipping_ready' || _global.bulkConfirmData?.orderStatus === 'shipping') && (!_global.bulkConfirmData?.courierId || !_global.bulkConfirmData?.trackingNumber)}}",
                  "props": {
                    "className": "text-sm text-red-600 dark:text-red-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.order.bulk.carrier_required"
                }
              ]
            }
          ],
          "props": {
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isProcessing}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.order.bulk.confirm_cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{(!_global.bulkConfirmData?.orderStatus && !_global.bulkConfirmData?.courierId && !_global.bulkConfirmData?.trackingNumber) || ((_global.bulkConfirmData?.orderStatus === 'shipping_ready' || _global.bulkConfirmData?.orderStatus === 'shipping') && (!_global.bulkConfirmData?.courierId || !_global.bulkConfirmData?.trackingNumber)) || _global.isProcessing}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isProcessing": true
                  }
                },
                {
                  "handler": "sirsoft-ecommerce.executeOrderBulkAction",
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isProcessing": false
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isProcessing": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{$error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isProcessing}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isProcessing ? '$t:common.processing' : '$t:sirsoft-ecommerce.admin.order.bulk.confirm_apply'}}"
            }
          ]
        }
      ]
    }
  ]
}
