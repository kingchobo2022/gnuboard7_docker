{
  "meta": {
    "is_partial": true,
    "description": "Order List - Preset Save Modal"
  },
  "id": "modal_preset_save",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.order.modal.preset_save.title",
    "description": "$t:sirsoft-ecommerce.admin.order.modal.preset_save.description",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "Input",
      "props": {
        "type": "text",
        "placeholder": "$t:sirsoft-ecommerce.admin.order.modal.preset_save.placeholder",
        "className": "input",
        "value": "{{_local.presetName}}"
      },
      "actions": [
        {
          "type": "input",
          "handler": "setState",
          "params": {
            "target": "local",
            "presetName": "{{$event.target.value}}"
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isSaving}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{!_local.presetName || _local.presetName.trim() === '' || _global.isSaving}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isSaving": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/modules/sirsoft-ecommerce/admin/presets",
                  "params": {
                    "method": "POST",
                    "body": {
                      "target_screen": "orders",
                      "name": "{{_local.presetName}}",
                      "conditions": {
                        "searchField": "{{_global.savingPresetConditions.searchField || 'all'}}",
                        "searchKeyword": "{{_global.savingPresetConditions.searchKeyword || ''}}",
                        "dateType": "{{_global.savingPresetConditions.dateType || 'ordered_at'}}",
                        "startDate": "{{_global.savingPresetConditions.startDate || ''}}",
                        "endDate": "{{_global.savingPresetConditions.endDate || ''}}",
                        "dateQuick": "{{_global.savingPresetConditions.dateQuick || ''}}",
                        "orderStatus": "{{_global.savingPresetConditions.orderStatus || []}}",
                        "claimRefundStatus": "{{_global.savingPresetConditions.claimRefundStatus || []}}",
                        "claimReturnStatus": "{{_global.savingPresetConditions.claimReturnStatus || []}}",
                        "claimExchangeStatus": "{{_global.savingPresetConditions.claimExchangeStatus || []}}",
                        "deliveryMethods": "{{_global.savingPresetConditions.deliveryMethods || []}}",
                        "paymentMethods": "{{_global.savingPresetConditions.paymentMethods || []}}",
                        "category1": "{{_global.savingPresetConditions.category1 || ''}}",
                        "category2": "{{_global.savingPresetConditions.category2 || ''}}",
                        "category3": "{{_global.savingPresetConditions.category3 || ''}}",
                        "category4": "{{_global.savingPresetConditions.category4 || ''}}",
                        "minPrice": "{{_global.savingPresetConditions.minPrice || ''}}",
                        "maxPrice": "{{_global.savingPresetConditions.maxPrice || ''}}",
                        "countries": "{{_global.savingPresetConditions.countries || []}}",
                        "devices": "{{_global.savingPresetConditions.devices || []}}"
                      }
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isSaving": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "presetName": ""
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "presets"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.messages.presets.created"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isSaving": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{$error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isSaving}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isSaving ? '$t:common.saving' : '$t:sirsoft-ecommerce.admin.order.modal.preset_save.save'}}"
            }
          ]
        }
      ]
    }
  ]
}
