                {
                  "type": "basic",
                  "name": "H4",
                  "props": {
                    "className": "text-body font-medium mb-2"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.edit_modal.variables_title"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-wrap gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "iteration": {
                        "source": "{{_global.ecommerce_notification_template_form_modal?.definition?.variables ?? []}}",
                        "item_var": "v"
                      },
                      "props": {
                        "className": "inline-flex items-center gap-1 text-xs px-2 py-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded text-gray-700 dark:text-gray-300"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-mono"
                          },
                          "text": "{"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-mono"
                          },
                          "text": "{{v.key}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-mono"
                          },
                          "text": "}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": " — {{v.description ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "ecommerce_template_modal_footer",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-between pt-4 pb-4 border-t border-gray-200 dark:border-gray-700 mt-4 flex-shrink-0"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "text-body px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors",
                    "disabled": "{{_global.ecommerce_notification_template_form_modal?.isSaving ?? false}}"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.edit_modal.btn_preview",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "apiCall",
                      "auth_required": true,
                      "target": "/api/admin/notification-templates/preview",
                      "params": {
                        "method": "POST",
                        "body": {
                          "definition_id": "{{_global.ecommerce_notification_template_form_modal?.definition?.id}}",
                          "subject": "{{_global.ecommerce_notification_template_form_modal?.template?.subject}}",
                          "body": "{{_global.ecommerce_notification_template_form_modal?.template?.body}}",
                          "locale": "{{_global.ecommerce_notification_template_form_modal?.editLang ?? $locale}}"
                        }
                      },
                      "onSuccess": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "ecommerce_notification_template_form_modal.preview": "{{response.data}}"
                          }
                        },
                        {
                          "handler": "openModal",
                          "target": "modal_ecommerce_notification_definition_preview"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "text-body px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_global.ecommerce_notification_template_form_modal?.isSaving ?? false}}"
                  },
                  "text": "$t:common.cancel",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "closeModal",
                      "target": "modal_ecommerce_notification_template_edit"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "flex-center gap-2 text-sm px-4 py-2 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_global.ecommerce_notification_template_form_modal?.isSaving ?? false}}"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{_global.ecommerce_notification_template_form_modal?.isSaving}}",
                      "props": {
                        "name": "spinner",
                        "className": "animate-spin",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{_global.ecommerce_notification_template_form_modal?.isSaving ? '$t:common.saving' : '$t:common.save'}}"
                    }
                  ],
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "params": {
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "global",
                              "ecommerce_notification_template_form_modal.isSaving": true,
                              "ecommerce_notification_template_form_modal.errors": null
                            }
                          },
                          {
                            "handler": "apiCall",
                            "auth_required": true,
                            "target": "{{'/api/admin/notification-templates/' + _global.ecommerce_notification_template_form_modal?.template?.id}}",
                            "params": {
                              "method": "PUT",
                              "body": {
                                "subject": "{{_global.ecommerce_notification_template_form_modal?.template?.subject}}",
                                "body": "{{_global.ecommerce_notification_template_form_modal?.template?.body}}",
                                "click_url": "{{_global.ecommerce_notification_template_form_modal?.template?.click_url ?? null}}",
                                "recipients": "{{_global.ecommerce_notification_template_form_modal?.recipients ?? []}}"
                              }
                            },
                            "onSuccess": [
                              {
                                "handler": "refetchDataSource",
                                "params": {
                                  "dataSourceId": "ecommerceNotificationDefinitions"
                                }
                              },
                              {
                                "handler": "toast",
                                "params": {
                                  "message": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.save_success",
                                  "type": "success"
                                }
                              },
                              {
                                "handler": "closeModal",
                                "target": "modal_ecommerce_notification_template_edit"
                              },
                              {
                                "handler": "setState",
                                "params": {
                                  "target": "global",
                                  "ecommerce_notification_template_form_modal": null
                                }
                              }
                            ],
                            "onError": [
                              {
                                "handler": "setState",
                                "params": {
                                  "target": "global",
                                  "ecommerce_notification_template_form_modal.isSaving": false,
                                  "ecommerce_notification_template_form_modal.errors": "{{error.errors}}"
                                }
                              },
                              {
                                "handler": "toast",
                                "params": {
                                  "message": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.save_error",
                                  "type": "error"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
