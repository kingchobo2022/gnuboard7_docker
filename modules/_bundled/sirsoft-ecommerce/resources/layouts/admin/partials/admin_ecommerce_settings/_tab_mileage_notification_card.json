{
  "meta": {
    "is_partial": true,
    "description": "마일리지 설정 - 소멸 예정 알림 카드 (활성 채널 동적 표시)"
  },
  "id": "mileage_expiry_notification_card",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "children": [
    {
      "type": "basic",
      "name": "H3",
      "props": {
        "className": "section-heading mb-4"
      },
      "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.title"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-between py-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-900 dark:text-white"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.enabled"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.enabled_hint"
            }
          ]
        },
        {
          "type": "composite",
          "name": "Toggle",
          "props": {
            "name": "mileage.expiry_notification_enabled",
            "value": "{{_local.form?.mileage?.expiry_notification_enabled ?? true}}",
            "disabled": "{{_computed.isReadOnly}}"
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_local.form?.mileage?.expiry_notification_enabled ?? true}}",
      "props": {
        "className": "border-t border-gray-200 dark:border-gray-700 pt-4 space-y-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-900 dark:text-white mb-2"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.days_before"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-600 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.days_before_prefix"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "mileage.expiry_notification_days_before",
                    "value": "{{_local.form?.mileage?.expiry_notification_days_before ?? 7}}",
                    "min": "1",
                    "className": "input w-20 text-center",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-600 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.days_before_suffix"
                }
              ]
            }
          ]
        },
        {
          "id": "template_status_block",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-100 dark:border-gray-700/50 pt-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "block text-sm font-medium text-gray-900 dark:text-white mb-2"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.template_status_title"
            },
            {
              "id": "template_status_list",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "id": "template_status_row",
                  "type": "basic",
                  "name": "Div",
                  "iteration": {
                    "source": "(((ecommerceNotificationDefinitions?.data?.data ?? []).find(d => d.type === 'mileage_expiring_soon')?.templates) ?? [])",
                    "item_var": "tpl",
                    "index_var": "tplIndex"
                  },
                  "props": {
                    "className": "flex-between gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-700/40"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-center gap-2 min-w-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "{{tpl.channel === 'mail' ? 'envelope' : 'bell'}}",
                            "size": "sm",
                            "className": "text-gray-400 dark:text-gray-500 flex-shrink-0"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "min-w-0"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "block text-xs font-medium text-gray-500 dark:text-gray-400"
                              },
                              "text": "{{tpl.channel === 'mail' ? $t('sirsoft-ecommerce.admin.mileage_settings.notification.channel_mail') : (tpl.channel === 'database' ? $t('sirsoft-ecommerce.admin.mileage_settings.notification.channel_database') : tpl.channel)}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "block text-sm text-gray-800 dark:text-gray-200 truncate"
                              },
                              "text": "{{tpl.subject?.[$locale] ?? tpl.subject?.ko ?? $t('sirsoft-ecommerce.admin.mileage_settings.notification.template_status_empty')}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "{{tpl.is_active ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300' : 'bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400'}} inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0"
                      },
                      "text": "{{tpl.is_active ? $t('sirsoft-ecommerce.admin.mileage_settings.notification.template_status_active') : $t('sirsoft-ecommerce.admin.mileage_settings.notification.template_status_inactive')}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{(((ecommerceNotificationDefinitions?.data?.data ?? []).find(d => d.type === 'mileage_expiring_soon')?.templates) ?? []).length === 0}}",
                  "props": {
                    "className": "px-3 py-2 text-sm text-gray-400 dark:text-gray-500"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.template_status_empty"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-between gap-2 flex-wrap mt-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.template_status_hint"
                },
                {
                  "id": "go_to_notification_settings",
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "flex items-center gap-1.5 px-3 py-2 text-sm bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "params": {
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "global",
                              "activeEcommerceSettingsTab": "notification_definitions"
                            }
                          },
                          {
                            "handler": "navigate",
                            "params": {
                              "path": "/admin/ecommerce/settings",
                              "query": {
                                "tab": "notification_definitions"
                              },
                              "replace": true
                            }
                          }
                        ]
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "arrow-up-right-from-square",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.mileage_settings.notification.go_to_notification_settings"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
