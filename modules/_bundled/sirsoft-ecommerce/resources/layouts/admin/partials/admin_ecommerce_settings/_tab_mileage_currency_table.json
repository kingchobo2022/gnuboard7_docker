                          ],
                          "children": [
                            { "type": "basic", "name": "Icon", "props": { "name": "xmark", "size": "sm" } }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(_local.form?.mileage?.currency_rules ?? []).length === 0 && _local.isAddingMileageCurrency !== true}}",
      "props": {
        "className": "py-6 text-center text-sm text-gray-400 dark:text-gray-500"
      },
      "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.empty"
    }
  ]
}
