{
  "meta": {
    "is_partial": true,
    "description": "환불 사유 관리 - Mobile 카드 뷰"
  },
  "id": "refund_reason_cards_container",
  "type": "basic",
  "name": "Div",
  "props": {
  },
  "children": [
    {
      "id": "refund_reason_card",
      "type": "basic",
      "name": "Div",
      "iteration": {
        "source": "(_local.form?.claim?.refund_reasons ?? []).map((r, i) => ({...r, _idx: i}))",
        "item_var": "reason",
        "index_var": "rIdx"
      },
      "props": {
        "className": "excel-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "excel-card-header"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 min-w-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "excel-card-title font-mono"
                      },
                      "text": "{{reason.code}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 shrink-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Toggle",
                  "props": {
                    "checked": "{{reason.is_active ?? false}}",
                    "size": "sm",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form.claim.refund_reasons": "{{(_local.form?.claim?.refund_reasons ?? []).map((r, i) => i === reason._idx ? {...r, is_active: !(r.is_active)} : r)}}",
                        "hasChanges": true
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "excel-card-body"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "excel-card-row"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "excel-card-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.columns.name"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "excel-card-value flex-1"
                  },
                  "children": [
                    {
                      "type": "composite",
                      "name": "MultilingualInput",
                      "props": {
                        "value": "{{reason.name ?? {}}}",
                        "layout": "compact",
                        "placeholder": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.form.name_ko_placeholder",
                        "disabled": "{{_computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form.claim.refund_reasons": "{{(_local.form?.claim?.refund_reasons ?? []).map((r, i) => i === reason._idx ? {...r, name: $event.target.value} : r)}}",
                            "hasChanges": true
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "excel-card-row"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "excel-card-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.columns.fault_type"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "excel-card-value flex-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Select",
                      "props": {
                        "value": "{{reason.fault_type ?? 'customer'}}",
                        "className": "w-full",
                        "options": [
                          {
                            "value": "customer",
                            "label": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.form.fault_types.customer"
                          },
                          {
                            "value": "seller",
                            "label": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.form.fault_types.seller"
                          },
                          {
                            "value": "carrier",
                            "label": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.form.fault_types.carrier"
                          }
                        ],
                        "disabled": "{{_computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form.claim.refund_reasons": "{{(_local.form?.claim?.refund_reasons ?? []).map((r, i) => i === reason._idx ? {...r, fault_type: $event.target.value} : r)}}",
                            "hasChanges": true
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "excel-card-row"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "excel-card-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.columns.is_user_selectable"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "excel-card-value"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "checked": "{{reason.is_user_selectable ?? false}}",
                        "className": "checkbox",
                        "disabled": "{{_computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form.claim.refund_reasons": "{{(_local.form?.claim?.refund_reasons ?? []).map((r, i) => i === reason._idx ? {...r, is_user_selectable: !(r.is_user_selectable)} : r)}}",
                            "hasChanges": true
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "excel-card-footer"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "p-1.5 text-gray-400 hover:text-red-600 dark:text-red-400 dark:text-gray-500 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                "title": "$t:common.delete",
                "disabled": "{{_computed.isReadOnly}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "confirm": "$t:sirsoft-ecommerce.admin.settings.claim.refund_reasons.confirm_delete",
                  "params": {
                    "target": "local",
                    "form.claim.refund_reasons": "{{(_local.form?.claim?.refund_reasons ?? []).filter((_, i) => i !== reason._idx)}}",
                    "hasChanges": true
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "fa-solid fa-trash",
                    "className": "text-sm"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
