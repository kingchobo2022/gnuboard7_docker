{
  "meta": {
    "is_partial": true,
    "description": "이커머스 본인인증 정책 삭제 확인 모달"
  },
  "id": "ecommerce_identity_policy_delete_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.identity.policies.delete_title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-gray-700 dark:text-gray-300"
      },
      "text": "$t:admin.identity.policies.delete_confirm"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "modal-footer-buttons"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.ecommerceIdentityPolicyDeleting}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal",
              "target": "ecommerce_identity_policy_delete_modal"
            }
          ],
          "text": "$t:common.cancel"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.ecommerceIdentityPolicyDeleting}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "ecommerceIdentityPolicyDeleting": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/identity/policies/{{_global.ecommerceIdentityPolicyDeleteId}}",
                  "params": {
                    "method": "DELETE"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "ecommerceIdentityPolicyDeleting": false,
                        "ecommerceIdentityPolicyDeleteId": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.identity.policies.delete_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "ecommerceIdentityPolicies"
                      }
                    },
                    {
                      "handler": "closeModal",
                      "target": "ecommerce_identity_policy_delete_modal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "ecommerceIdentityPolicyDeleting": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message ?? '$t:admin.identity.policies.delete_failed'}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.ecommerceIdentityPolicyDeleting}}",
              "props": {
                "name": "spinner",
                "className": "spinner-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.ecommerceIdentityPolicyDeleting ? '$t:common.deleting' : '$t:common.delete'}}"
            }
          ]
        }
      ]
    }
  ]
}
