{
  "meta": {
    "is_partial": true,
    "description": "마일리지 설정 - 유효기간 카드"
  },
  "id": "mileage_expiry_card",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "children": [
    {
      "type": "basic",
      "name": "H3",
      "props": {
        "className": "text-lg font-semibold text-gray-900 dark:text-white mb-4"
      },
      "text": "$t:sirsoft-ecommerce.admin.mileage_settings.expiry.title"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center justify-between py-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-900 dark:text-white"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.expiry.enabled"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.expiry.enabled_hint"
            }
          ]
        },
        {
          "type": "composite",
          "name": "Toggle",
          "props": {
            "name": "mileage.expiry_enabled",
            "value": "{{_local.form?.mileage?.expiry_enabled ?? true}}",
            "disabled": "{{_computed.isReadOnly}}"
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_local.form?.mileage?.expiry_enabled ?? true}}",
      "props": {
        "className": "border-t border-gray-200 dark:border-gray-700 pt-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-gray-900 dark:text-white mb-2"
          },
          "text": "$t:sirsoft-ecommerce.admin.mileage_settings.expiry.days"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "number",
                "name": "mileage.expiry_days",
                "value": "{{_local.form?.mileage?.expiry_days ?? 365}}",
                "min": "1",
                "className": "input w-28 text-center",
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-sm text-gray-600 dark:text-gray-400"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.expiry.days_suffix"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{_local.errors?.['mileage.expiry_days']}}",
          "props": {
            "className": "text-red-500 dark:text-red-400 text-xs mt-1 block"
          },
          "text": "{{_local.errors?.['mileage.expiry_days']?.[0] ?? ''}}"
        }
      ]
    }
  ]
}
