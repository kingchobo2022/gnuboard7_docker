{
  "meta": {
    "is_partial": true,
    "description": "쇼핑몰 설정 마일리지 탭 콘텐츠"
  },
  "id": "tab_content_mileage",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeEcommerceSettingsTab || query.tab || 'basic_info') === 'mileage'}}",
  "props": {
    "className": "mt-6 space-y-6"
  },
  "children": [
    {
      "partial": "_tab_mileage_basic_card.json"
    },
    {
      "id": "mileage_currency_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-between mb-4 gap-2 flex-wrap"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "section-heading"
              },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.title"
            },
            {
              "id": "add_currency_rule_button",
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "flex items-center gap-1.5 px-3 py-2 text-sm bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                "disabled": "{{_computed.isReadOnly || _local.isAddingMileageCurrency === true}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "isAddingMileageCurrency": true,
                    "form.newMileageCurrency": {
                      "currency_code": "",
                      "point_value": 1,
                      "min_use_amount": 0,
                      "use_unit": 1,
                      "max_use_type": "percent",
                      "max_use_percent": 30,
                      "max_use_value": 0
                    }
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "plus",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.add"
                }
              ]
            }
          ]
        },
        {
          "id": "currency_rules_view",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "w-full"
          },
          "children": [
            {
              "partial": "_tab_mileage_currency_table.json"
            }
          ],
          "responsive": {
            "portable": {
              "children": [
                {
                  "partial": "_tab_mileage_currency_cards.json"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "partial": "_tab_mileage_expiry_card.json"
    },
    {
      "partial": "_tab_mileage_notification_card.json"
    }
  ]
}
