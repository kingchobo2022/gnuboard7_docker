{
  "meta": {
    "is_partial": true,
    "description": "쇼핑몰 설정 주문설정 탭 콘텐츠"
  },
  "id": "tab_content_order_settings",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeEcommerceSettingsTab || query.tab || 'basic_info') === 'order_settings'}}",
  "children": [
    {
      "id": "default_pg_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-ecommerce.admin.settings.order_settings.default_pg_provider.title"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:sirsoft-ecommerce.admin.settings.order_settings.default_pg_provider.description"
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{(_local.form?.available_pg_providers ?? []).length === 0}}",
          "props": {
            "className": "flex-center gap-2 text-label-subtle"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "circle-info",
                "className": "text-sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.settings.order_settings.default_pg_provider.not_installed"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{(_local.form?.available_pg_providers ?? []).length > 0}}",
          "children": [
            {
              "type": "basic",
              "name": "Select",
              "props": {
                "value": "{{_local.form?.order_settings?.default_pg_provider ?? ''}}",
                "className": "w-64",
                "options": "{{[{value: '', label: '---'}].concat((_local.form?.available_pg_providers ?? []).map(p => ({value: p.id, label: $localized(p.name)})))}}",
                "disabled": "{{_computed.isReadOnly}}"
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "form.order_settings.default_pg_provider": "{{$event.target.value || null}}",
                    "hasChanges": true
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "payment_methods_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-ecommerce.admin.settings.order_settings.payment_methods.title"
