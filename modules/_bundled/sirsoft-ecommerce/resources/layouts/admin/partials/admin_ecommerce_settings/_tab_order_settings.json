                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 flex-shrink-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "btn btn-outline disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "openModal",
                      "target": "bank_management_modal"
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "building-columns",
                        "className": "text-sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.settings.order_settings.bank_accounts.manage_banks"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "btn btn-secondary disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form.order_settings.bank_accounts": "{{[...(_local.form?.order_settings?.bank_accounts ?? []), { bank_code: '', account_number: '', account_holder: '', is_active: true, is_default: false }]}}",
                        "hasChanges": true
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "plus",
                        "className": "text-sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.settings.order_settings.bank_accounts.add_account"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "w-full"
          },
          "children": [
            {
              "partial": "_bank_accounts_table.json"
            }
          ],
          "responsive": {
            "portable": {
              "children": [
                {
                  "partial": "_bank_accounts_cards.json"
                }
              ]
            }
          }
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{_local.errors?.['order_settings.bank_accounts']}}",
          "props": {
            "className": "form-error-xs mt-2 block"
          },
          "text": "{{_local.errors?.['order_settings.bank_accounts']?.[0] ?? ''}}"
