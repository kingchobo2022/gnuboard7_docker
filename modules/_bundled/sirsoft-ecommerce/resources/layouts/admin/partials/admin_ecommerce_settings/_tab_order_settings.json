        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "w-full"
          },
          "children": [
            {
              "partial": "_payment_methods_list.json"
            }
          ],
          "responsive": {
            "portable": {
              "children": [
                {
                  "partial": "_payment_methods_cards.json"
                }
              ]
            }
          }
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{_local.errors?.['order_settings.payment_methods']}}",
          "props": {
            "className": "form-error-xs mt-2 block"
          },
          "text": "{{_local.errors?.['order_settings.payment_methods']?.[0] ?? ''}}"
        }
      ]
    },
    {
      "id": "bank_accounts_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "admin-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-between mb-6"
          },
          "children": [
            {
              "type": "basic",
