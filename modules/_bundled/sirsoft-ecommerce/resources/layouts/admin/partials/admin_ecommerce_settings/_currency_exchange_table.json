                      "type": "basic",
                      "name": "Span",
                      "if": "{{Object.keys(_local.errors ?? {}).some(k => k.startsWith('language_currency.currencies.' + currency._idx + '.locales'))}}",
                      "props": {
                        "className": "form-error"
                      },
                      "text": "{{_local.errors?.[Object.keys(_local.errors ?? {}).find(k => k.startsWith('language_currency.currencies.' + currency._idx + '.locales'))]?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Td",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
