                        "options": "{{(_global.appConfig?.supportedLocales ?? ['ko', 'en']).map(l => ({ value: l, label: _global.appConfig?.localeNames?.[l] ?? l }))}}",
                        "placeholder": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.locales_placeholder",
                        "className": "{{Object.keys(_local.errors ?? {}).some(k => k.startsWith('language_currency.currencies.' + currency._idx + '.locales')) ? 'min-w-40 input-error' : 'min-w-40'}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
