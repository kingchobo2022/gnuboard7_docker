                        "className": "{{_local.form?.newCurrency?.hasError ? 'input input-error w-20 uppercase' : 'input w-20 uppercase'}}",
                        "maxLength": "3",
                        "disabled": "{{_computed.isReadOnly}}"
                      },
                      "actions": [
                        {
