                              "name": "Icon",
                              "props": {
                                "name": "pencil",
                                "size": "sm"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "{{currency.code === (_local.form?.language_currency?.default_currency ?? 'KRW') ? 'btn-icon text-gray-300 cursor-not-allowed' : 'btn-icon text-error'}} disabled:opacity-50 disabled:cursor-not-allowed",
