                            "value": "{{currency.base_unit ?? 1}}",
                            "className": "{{_local.errors?.['language_currency.currencies.' + currency._idx + '.base_unit'] ? 'input w-20 text-center input-error' : 'input w-20 text-center'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-label-subtle"
