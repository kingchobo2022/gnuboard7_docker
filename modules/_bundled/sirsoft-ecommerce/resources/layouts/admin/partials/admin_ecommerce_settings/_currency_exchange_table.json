                            "className": "btn-icon text-gray-500 hover:text-gray-700 dark:hover:text-gray-200 dark:text-gray-300 disabled:opacity-50 disabled:cursor-not-allowed",
                            "disabled": "{{_computed.isReadOnly}}"
