                        "maxLength": "8",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Td",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{currency.code === (_local.form?.language_currency?.default_currency ?? 'KRW')}}",
                      "props": {
                        "className": "text-label-subtle"
