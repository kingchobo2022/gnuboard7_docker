                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.currency_symbol"
                },
                {
                  "type": "basic",
                  "name": "Th",
                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.exchange_rate"
                },
                {
                  "type": "basic",
