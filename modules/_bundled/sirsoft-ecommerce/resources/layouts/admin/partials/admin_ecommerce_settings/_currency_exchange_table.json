                                  "params": {
                                    "target": "local",
                                    "form.language_currency.currencies": "{{(Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).map((c, i) => i === _local.editingCurrencyIdx ? { ...c, code: (_local.editingCurrency?.code || '').toUpperCase().trim(), name: _local.form?.editingCurrency?.name ?? _local.editingCurrency?.name ?? c.name } : c)}}",
                                    "editingCurrencyIdx": null,
                                    "editingCurrency": null,
                                    "form.editingCurrency": null,
                                    "hasChanges": true
                                  }
                                }
                              ]
                            }
