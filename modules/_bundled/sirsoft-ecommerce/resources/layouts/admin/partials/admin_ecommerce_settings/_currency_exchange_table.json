                            "disabled": "{{_computed.isReadOnly}}"
                          },
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "toast",
                                  "if": "{{_local.editingCurrency?.code?.trim() && (_local.editingCurrency?.code?.toUpperCase().trim() !== _local.editingCurrency?.originalCode) && (Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).some(c => (c.code || '').toUpperCase() === (_local.editingCurrency?.code || '').toUpperCase().trim())}}",
                                  "params": {
                                    "type": "error",
                                    "message": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.duplicate_currency_error"
                                  }
                                },
                                {
                                  "handler": "setState",
                                  "if": "{{_local.editingCurrency?.code?.trim() && (_local.editingCurrency?.code?.toUpperCase().trim() !== _local.editingCurrency?.originalCode) && (Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).some(c => (c.code || '').toUpperCase() === (_local.editingCurrency?.code || '').toUpperCase().trim())}}",
                                  "params": {
                                    "target": "local",
                                    "editingCurrency.hasError": true
                                  }
                                },
                                {
                                  "handler": "setState",
