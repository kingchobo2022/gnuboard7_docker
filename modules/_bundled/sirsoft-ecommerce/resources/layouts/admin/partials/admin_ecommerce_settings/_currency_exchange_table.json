                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-label-subtle whitespace-nowrap"
                          },
                          "text": "{{(_local.form?.language_currency?.default_currency ?? 'KRW') + ' ' + (((_local.form?.language_currency?.currencies ?? []).find(c => c.code === (_local.form?.language_currency?.default_currency ?? 'KRW'))?.base_unit ?? 1).toLocaleString()) + ' ='}}"
                        },
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "text",
                            "name": "{{'language_currency.currencies.' + currency._idx + '.exchange_rate'}}",
                            "value": "{{currency.exchange_rate}}",
                            "className": "{{_local.errors?.['language_currency.currencies.' + currency._idx + '.exchange_rate'] ? 'input w-20 text-center input-error' : 'input w-20 text-center'}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-label-subtle"
                          },
                          "text": "{{currency.code}}"
                        }
