                                            "actions": [
                                                {
                                                    "type": "change",
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "identity_policy_form_modal.form.fail_mode": "{{$event.target.value}}"
                                                    }
