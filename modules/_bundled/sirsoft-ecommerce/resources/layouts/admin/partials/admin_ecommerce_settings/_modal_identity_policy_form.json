                                            "props": {
                                                "value": "{{_global.identity_policy_form_modal?.form?.scope ?? 'route'}}",
                                                "disabled": "{{!_global.identity_policy_form_modal?.isNew && _global.identity_policy_form_modal?.form?.source_type !== 'admin'}}",
                                                "className": "{{_global.identity_policy_form_modal?.errors?.errors?.scope ? 'input-error disabled:bg-gray-100 dark:disabled:bg-gray-900' : ' disabled:bg-gray-100 dark:disabled:bg-gray-900'}}",
                                                "options": [
                                                    { "value": "route", "label": "$t:admin.identity.policies.scope.route" },
                                                    { "value": "hook", "label": "$t:admin.identity.policies.scope.hook" },
                                                    { "value": "custom", "label": "$t:admin.identity.policies.scope.custom" }
                                                ]
                                            },
                                            "actions": [
                                                {
                                                    "type": "change",
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "identity_policy_form_modal.form.scope": "{{$event.target.value}}"
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Span",
