                                                "auth_required": true,
                                                "target": "{{_global.identity_policy_form_modal?.isNew ? '/api/admin/identity/policies' : '/api/admin/identity/policies/' + _global.identity_policy_form_modal?.form?.id}}",
                                                "params": {
                                                    "method": "{{_global.identity_policy_form_modal?.isNew ? 'POST' : 'PUT'}}",
                                                    "body": {
                                                        "key": "{{_global.identity_policy_form_modal?.form?.key}}",
                                                        "scope": "{{_global.identity_policy_form_modal?.form?.scope}}",
                                                        "target": "{{_global.identity_policy_form_modal?.form?.target}}",
                                                        "purpose": "{{_global.identity_policy_form_modal?.form?.purpose}}",
                                                        "provider_id": "{{_global.identity_policy_form_modal?.form?.provider_id || null}}",
                                                        "grace_minutes": "{{Number(_global.identity_policy_form_modal?.form?.grace_minutes ?? 0)}}",
