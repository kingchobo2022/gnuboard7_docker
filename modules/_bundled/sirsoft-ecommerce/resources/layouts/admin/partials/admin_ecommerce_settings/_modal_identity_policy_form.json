                                        "value": "{{_global.identity_policy_form_modal?.form?.conditions?.signup_stage ?? ''}}",
                                        "className": "",
                                        "options": [
                                            { "value": "", "label": "$t:admin.identity.policies.form.signup_stage_unset" },
                                            { "value": "before_submit", "label": "$t:admin.identity.policies.form.signup_stage_before_submit" },
                                            { "value": "after_create", "label": "$t:admin.identity.policies.form.signup_stage_after_create" }
                                        ]
                                    },
                                    "actions": [
                                        {
                                            "type": "change",
