                                        "className": "{{_global.identity_policy_form_modal?.errors?.errors?.key ? 'input-error font-mono disabled:bg-gray-100 dark:disabled:bg-gray-900' : 'font-mono disabled:bg-gray-100 dark:disabled:bg-gray-900'}}"
                                    },
                                    "actions": [
                                        {
                                            "type": "change",
                                            "handler": "setState",
                                            "params": {
                                                "target": "global",
                                                "identity_policy_form_modal.form.key": "{{$event.target.value}}"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_global.identity_policy_form_modal?.errors?.errors?.key}}",
                                    "props": { "className": "form-error" },
                                    "text": "{{_global.identity_policy_form_modal?.errors?.errors?.key?.[0] ?? ''}}"
                                }
