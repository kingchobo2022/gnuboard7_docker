                                                    "name": "Ul",
                                                    "if": "{{_global.identity_policy_form_modal?.errors?.errors && Object.keys(_global.identity_policy_form_modal.errors.errors).length > 0}}",
                                                    "props": {
                                                        "className": "mt-1 list-disc list-inside space-y-0.5"
                                                    },
                                                    "iteration": {
                                                        "source": "Object.entries(_global.identity_policy_form_modal?.errors?.errors ?? {}).flatMap(([f, m]) => Array.isArray(m) ? m : [m])",
                                                        "item_var": "msg"
                                                    },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Li",
                                                            "props": {
                                                                "className": "text-danger-soft"
                                                            },
                                                            "text": "{{msg}}"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        },

