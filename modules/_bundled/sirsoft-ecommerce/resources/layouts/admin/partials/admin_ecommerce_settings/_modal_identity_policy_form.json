                                    "text": "$t:admin.identity.policies.form.priority_desc"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{_global.identity_policy_form_modal?.errors?.errors?.priority}}",
                                    "props": { "className": "form-error" },
                                    "text": "{{_global.identity_policy_form_modal?.errors?.errors?.priority?.[0] ?? ''}}"
                                }
