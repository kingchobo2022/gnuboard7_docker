                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "grid-2col-responsive" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Label",
                                            "props": { "className": "form-label" },
                                            "text": "$t:admin.identity.policies.form.purpose"
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Select",
                                            "props": {
                                                "value": "{{_global.identity_policy_form_modal?.form?.purpose ?? 'sensitive_action'}}",
                                                "className": "{{_global.identity_policy_form_modal?.errors?.errors?.purpose ? 'input-error' : ''}}",
                                                "options": "{{(ecommerceIdentityPurposes?.data ?? []).map(function(p) { return {value: p.id, label: p.label ?? p.id}; })}}"
                                            },
                                            "actions": [
                                                {
                                                    "type": "change",
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "identity_policy_form_modal.form.purpose": "{{$event.target.value}}"
                                                    }
