                                                        "priority": "{{Number(_global.identity_policy_form_modal?.form?.priority ?? 100)}}",
                                                        "conditions": "{{_global.identity_policy_form_modal?.form?.conditions ?? null}}",
                                                        "source_type": "{{_global.identity_policy_form_modal?.isNew ? 'admin' : (_global.identity_policy_form_modal?.form?.source_type ?? 'admin')}}",
                                                        "source_identifier": "{{_global.identity_policy_form_modal?.isNew ? 'sirsoft-ecommerce' : (_global.identity_policy_form_modal?.form?.source_identifier ?? 'sirsoft-ecommerce')}}"
                                                    }
                                                },
                                                "onSuccess": [
                                                    {
                                                        "handler": "toast",
                                                        "params": {
                                                            "message": "$t:admin.identity.policies.save_success",
                                                            "type": "success"
                                                        }
                                                    },
                                                    {
                                                        "handler": "closeModal",
                                                        "target": "identity_policy_form_modal"
                                                    },
                                                    {
                                                        "handler": "refetchDataSource",
                                                        "params": { "dataSourceId": "ecommerceIdentityPolicies" }
                                                    },
                                                    {
                                                        "handler": "setState",
                                                        "params": {
                                                            "target": "global",
                                                            "identity_policy_form_modal": null
                                                        }
                                                    }
                                                ],
                                                "onError": [
                                                    {
                                                        "handler": "setState",
                                                        "params": {
                                                            "target": "global",
                                                            "identity_policy_form_modal.isSaving": false,
                                                            "identity_policy_form_modal.errors": "{{error}}"
                                                        }
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                }
                            ],
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Icon",
                                    "if": "{{_global.identity_policy_form_modal?.isSaving}}",
                                    "props": {
                                        "name": "spinner",
                                        "className": "animate-spin",
                                        "size": "sm"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "{{_global.identity_policy_form_modal?.isSaving ? '$t:common.saving' : '$t:common.save'}}"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
