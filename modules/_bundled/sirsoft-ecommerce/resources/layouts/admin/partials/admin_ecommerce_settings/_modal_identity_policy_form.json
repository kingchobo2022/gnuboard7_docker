                                        },
                                        {
                                            "type": "composite",
                                            "name": "Toggle",
                                            "props": {
                                                "checked": "{{Boolean(_global.identity_policy_form_modal?.form?.enabled)}}",
                                                "size": "md"
                                            },
                                            "actions": [
                                                {
                                                    "type": "change",
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "identity_policy_form_modal.form.enabled": "{{!_global.identity_policy_form_modal?.form?.enabled}}"
                                                    }
                                                }
                                            ]
                                        }
                                    ]
