          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1" },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.use_unit"
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "number",
                "name": "newMileageCurrency.use_unit",
