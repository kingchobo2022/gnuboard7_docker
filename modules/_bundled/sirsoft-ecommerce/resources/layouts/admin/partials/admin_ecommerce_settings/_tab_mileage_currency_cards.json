                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "newMileageCurrency.max_use_type",
                        "value": "percent",
                        "checked": "{{(_local.form?.newMileageCurrency?.max_use_type ?? 'percent') === 'percent'}}",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "pointer-events-none"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "text-xs text-gray-600 dark:text-gray-400" },
                      "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.max_use_percent"
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "newMileageCurrency.max_use_percent",
                        "value": "{{_local.form?.newMileageCurrency?.max_use_percent ?? 30}}",
                        "min": "0",
                        "max": "100",
                        "className": "input w-16 text-center",
                        "disabled": "{{_computed.isReadOnly || (_local.form?.newMileageCurrency?.max_use_type ?? 'percent') !== 'percent'}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                      "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.max_use_percent_suffix"
