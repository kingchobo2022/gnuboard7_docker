            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1" },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.min_use"
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "number",
                "name": "newMileageCurrency.min_use_amount",
                "value": "{{_local.form?.newMileageCurrency?.min_use_amount ?? 0}}",
                "min": "0",
                "className": "input w-full",
                "disabled": "{{_computed.isReadOnly}}"
              }
