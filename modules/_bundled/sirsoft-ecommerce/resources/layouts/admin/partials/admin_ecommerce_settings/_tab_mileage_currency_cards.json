                "min": "1",
                "className": "input w-full",
                "disabled": "{{_computed.isReadOnly}}"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-xs font-medium text-gray-500 dark:text-gray-400 mb-2" },
              "text": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.max_use"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "space-y-2" },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": { "className": "flex items-center gap-2 cursor-pointer" },
                  "actions": [
                    {
                      "type": "click",
