              "props": {
                "type": "number",
                "name": "{{'mileage.currency_rules.' + rule._idx + '.point_value'}}",
                "value": "{{rule.point_value ?? 1}}",
                "min": "0.001",
                "step": "0.001",
                "className": "input w-full",
                "disabled": "{{_computed.isReadOnly}}"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
