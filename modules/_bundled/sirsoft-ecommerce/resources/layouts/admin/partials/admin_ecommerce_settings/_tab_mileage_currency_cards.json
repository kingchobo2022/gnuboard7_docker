                "disabled": "{{_computed.isReadOnly}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": { "target": "local", "isAddingMileageCurrency": false, "form.newMileageCurrency": null }
                }
              ],
              "children": [
                { "type": "basic", "name": "Span", "text": "$t:common.cancel" }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "flex items-center gap-1.5 px-3 py-1.5 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50",
                "disabled": "{{_computed.isReadOnly}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "toast",
                      "if": "{{_local.form?.newMileageCurrency?.currency_code?.trim() && (_local.form?.mileage?.currency_rules ?? []).some(c => (c.currency_code || '').toUpperCase() === (_local.form?.newMileageCurrency?.currency_code || '').toUpperCase().trim())}}",
                      "params": {
                        "type": "error",
                        "message": "$t:sirsoft-ecommerce.admin.mileage_settings.currency.duplicate_currency_error"
                      }
                    },
                    {
                      "handler": "setState",
                      "if": "{{_local.form?.newMileageCurrency?.currency_code?.trim() && (_local.form?.mileage?.currency_rules ?? []).some(c => (c.currency_code || '').toUpperCase() === (_local.form?.newMileageCurrency?.currency_code || '').toUpperCase().trim())}}",
                      "params": { "target": "local", "form.newMileageCurrency.hasError": true }
                    },
                    {
                      "handler": "setState",
                      "if": "{{_local.form?.newMileageCurrency?.currency_code?.trim() && !((_local.form?.mileage?.currency_rules ?? []).some(c => (c.currency_code || '').toUpperCase() === (_local.form?.newMileageCurrency?.currency_code || '').toUpperCase().trim()))}}",
                      "params": {
                        "target": "local",
                        "form.mileage.currency_rules": "{{[...(_local.form?.mileage?.currency_rules ?? []), { currency_code: (_local.form?.newMileageCurrency?.currency_code || '').toUpperCase().trim(), point_value: _local.form?.newMileageCurrency?.point_value ?? 1, min_use_amount: _local.form?.newMileageCurrency?.min_use_amount ?? 0, use_unit: _local.form?.newMileageCurrency?.use_unit ?? 1, max_use_type: _local.form?.newMileageCurrency?.max_use_type ?? 'percent', max_use_percent: _local.form?.newMileageCurrency?.max_use_percent ?? 30, max_use_value: _local.form?.newMileageCurrency?.max_use_value ?? 0 }]}}",
                        "isAddingMileageCurrency": false,
                        "form.newMileageCurrency": null,
                        "hasChanges": true
                      }
                    }
                  ]
