{
  "meta": {
    "is_partial": true,
    "description": "Brand View Panel - Read-only Brand Details"
  },
  "id": "view_panel",
  "type": "basic",
  "name": "Div",
  "if": "{{_global.selectedBrandId && _global.panelMode === 'view'}}",
  "children": [
    {
      "id": "view_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 panel-header"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-heading"
          },
          "text": "$t:sirsoft-ecommerce.admin.brand.info.title"
        }
      ]
    },
    {
      "id": "view_content",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "divider-list p-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "py-4 first:pt-0"
          },
          "children": [
            {
              "type": "basic",
              "name": "H4",
              "props": {
                "className": "text-table-header mb-3"
              },
              "text": "$t:sirsoft-ecommerce.admin.brand.info.basic"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid-2col-responsive"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "form-sub-label"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.brand.info.slug"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-primary block text-sm font-mono"
                          },
                          "text": "{{_global.selectedBrand?.slug}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": ""
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "form-sub-label"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.brand.info.name"
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "iteration": {
                            "source": "{{Object.entries(_global.selectedBrand?.name || {})}}",
                            "item_var": "nameEntry"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{nameEntry[1]}}",
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "text-hint inline-block w-8 uppercase"
                                  },
                                  "text": "{{nameEntry[0]}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "text-primary text-sm"
                                  },
                                  "text": "{{nameEntry[1]}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "form-sub-label"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.brand.info.website"
                        },
                        {
                          "type": "basic",
                          "name": "A",
                          "if": "{{_global.selectedBrand?.website}}",
                          "props": {
                            "href": "{{_global.selectedBrand?.website}}",
                            "target": "_blank",
                            "rel": "noopener noreferrer",
                            "className": "text-sm text-blue-600 dark:text-blue-400 hover:underline inline-flex items-center gap-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "{{_global.selectedBrand?.website}}"
                            },
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "external-link",
                                "className": "w-3 h-3"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{!_global.selectedBrand?.website}}",
                          "props": {
                            "className": "block text-sm text-gray-400 dark:text-gray-500"
                          },
                          "text": "-"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "form-sub-label"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.brand.info.status"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_global.selectedBrand?.is_active}}",
                          "props": {
                            "className": "inline-block px-2 py-0.5 text-xs bg-green-100 dark:bg-green-900/20 text-green-600 dark:text-green-400 rounded"
                          },
                          "text": "$t:sirsoft-ecommerce.common.active"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{!_global.selectedBrand?.is_active}}",
                          "props": {
                            "className": "text-secondary inline-block px-2 py-0.5 text-xs bg-gray-100 dark:bg-gray-700 rounded"
                          },
                          "text": "$t:sirsoft-ecommerce.common.inactive"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "section_statistics",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "py-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "H4",
              "props": {
                "className": "text-table-header mb-3"
              },
              "text": "$t:sirsoft-ecommerce.admin.brand.info.statistics"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid grid-cols-1 gap-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "bg-gray-50 dark:bg-gray-700 rounded-lg p-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center gap-3"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex-center w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg justify-center"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "box",
                                "size": "lg",
                                "className": "text-blue-600 dark:text-blue-400"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "children": [
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-xs text-secondary"
                              },
                              "text": "$t:sirsoft-ecommerce.admin.brand.info.products_count"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": {
                                "className": "text-page-heading"
                              },
                              "text": "{{_global.selectedBrand?.products_count ?? 0}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "py-4 last:pb-0"
          },
          "children": [
            {
              "type": "basic",
              "name": "H4",
              "props": {
                "className": "text-table-header mb-3"
              },
              "text": "$t:sirsoft-ecommerce.admin.brand.info.system"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid-2col-responsive"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-tertiary"
                      },
                      "text": "$t:sirsoft-ecommerce.common.created_at"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center text-primary gap-1.5 text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "calendar",
                            "className": "w-4 h-4 text-gray-400 dark:text-gray-500"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{{_global.selectedBrand?.created_at}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-tertiary"
                      },
                      "text": "$t:sirsoft-ecommerce.common.updated_at"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center text-primary gap-1.5 text-sm"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "clock",
                            "className": "w-4 h-4 text-gray-400 dark:text-gray-500"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{{_global.selectedBrand?.updated_at}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "view_footer",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 py-4 border-t border-gray-200 dark:border-gray-700"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_global.selectedBrand?.abilities?.can_update !== true}}",
                "className": "flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 text-body rounded-lg hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "panelMode": "edit"
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form": "{{_global.selectedBrand}}",
                        "isSaving": false,
                        "errors": null
                      }
                    }
                  ]
                }
              ],
              "text": "$t:sirsoft-ecommerce.common.edit"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "flex-1 px-4 py-2 text-red-600 dark:text-red-400 border border-red-300 dark:border-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors text-sm disabled:opacity-50 disabled:cursor-not-allowed",
                "disabled": "{{_global.selectedBrand?.abilities?.can_delete !== true}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "modal_data": {
                          "brandId": "{{_global.selectedBrandId}}",
                          "brandName": "{{$localized(_global.selectedBrand?.name)}}",
                          "productsCount": "{{_global.selectedBrand?.products_count ?? 0}}"
                        }
                      }
                    },
                    {
                      "handler": "openModal",
                      "target": "delete_confirm_modal"
                    }
                  ]
                }
              ],
              "text": "$t:sirsoft-ecommerce.common.delete"
            }
          ]
        }
      ]
    }
  ]
}
