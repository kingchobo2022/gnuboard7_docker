{
  "meta": {
    "is_partial": true,
    "description": "Brand List Panel - Left Sidebar with Search/Sort"
  },
  "id": "brand_list_panel",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card col-span-1-lg flex flex-col"
  },
  "children": [
    {
      "id": "brand_list_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 panel-header flex-between"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "tag",
                "className": "w-5 h-5 text-gray-700 dark:text-gray-300"
              }
            },
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "text-heading"
              },
              "text": "$t:sirsoft-ecommerce.admin.brand.list.title"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300"
              },
              "text": "{{brands?.data?.data?.length ?? 0}}"
            }
          ]
        }
      ]
    },
    {
      "id": "search_sort_area",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-4 panel-header"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "search-bar"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1 min-w-0"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "SearchBar",
                  "props": {
                    "placeholder": "$t:sirsoft-ecommerce.admin.brand.list.search_placeholder",
                    "value": "{{query.search || ''}}",
                    "className": "w-full"
                  },
                  "actions": [
                    {
                      "type": "submit",
                      "handler": "navigate",
                      "params": {
                        "path": "/admin/ecommerce/brands",
                        "mergeQuery": true,
                        "query": {
                          "search": "{{$event.target.search.value}}",
                          "sort": "{{query.sort || 'name_asc'}}"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "shrink-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Select",
                  "props": {
                    "name": "sortOrder",
                    "className": "search-bar-select",
                    "value": "{{query.sort || 'name_asc'}}",
                    "options": [
                      {
                        "value": "name_asc",
                        "label": "$t:sirsoft-ecommerce.admin.brand.list.sort.name_asc"
                      },
                      {
                        "value": "name_desc",
                        "label": "$t:sirsoft-ecommerce.admin.brand.list.sort.name_desc"
                      },
                      {
                        "value": "created_desc",
                        "label": "$t:sirsoft-ecommerce.admin.brand.list.sort.created_desc"
                      },
                      {
                        "value": "created_asc",
                        "label": "$t:sirsoft-ecommerce.admin.brand.list.sort.created_asc"
                      }
                    ]
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "navigate",
                      "params": {
                        "path": "/admin/ecommerce/brands",
                        "query": {
                          "search": "{{query.search}}",
                          "sort": "{{$event.target.value}}"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "id": "sortable_brand_list",
          "type": "composite",
          "name": "SortableMenuList",
          "if": "{{(brands?.data?.data?.length ?? 0) > 0}}",
          "props": {
            "items": "{{brands?.data?.data ?? []}}",
            "selectedId": "{{_global.selectedBrandId}}",
            "className": "p-2 max-h-[calc(90vh-140px)] overflow-y-auto",
            "itemClassName": "py-1 px-5 mb-1 rounded-lg border",
            "itemSelectedClassName": "bg-blue-50 dark:bg-blue-900/30 border-blue-500",
            "itemDefaultClassName": "bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600",
            "enableDrag": false,
            "toggleDisabled": "{{brands?.data?.abilities?.can_update !== true}}"
          },
          "lifecycle": {
            "onMount": [
              {
                "type": "click",
                "handler": "sirsoft-ecommerce.initBrandFromUrl"
              }
            ]
          },
          "actions": [
            {
              "event": "onSelect",
              "type": "action",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "selectedBrandId": "{{$args[0].id}}",
                    "selectedBrand": "{{$args[0]}}",
                    "panelMode": "view"
                  }
                },
                {
                  "handler": "replaceUrl",
                  "params": {
                    "query": {
                      "id": "{{$args[0].id}}",
                      "mode": "view"
                    }
                  }
                }
              ]
            },
            {
              "event": "onToggleStatus",
              "type": "action",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isTogglingStatus": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/modules/sirsoft-ecommerce/admin/brands/{{$args[0]}}/toggle-status",
                  "params": {
                    "method": "PATCH"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isTogglingStatus": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:sirsoft-ecommerce.admin.brand.messages.status_changed"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "brands"
                      }
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isTogglingStatus": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "brands"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "empty_brand_state",
      "type": "basic",
      "name": "Div",
      "if": "{{(brands?.data?.data?.length ?? 0) === 0}}",
      "props": {
        "className": "flex-center flex-1 justify-center gap-3 px-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "tag",
            "className": "w-5 h-5 text-gray-400 dark:text-gray-500"
          }
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-label-subtle"
          },
          "text": "$t:sirsoft-ecommerce.admin.brand.list.empty"
        }
      ]
    }
  ]
}
