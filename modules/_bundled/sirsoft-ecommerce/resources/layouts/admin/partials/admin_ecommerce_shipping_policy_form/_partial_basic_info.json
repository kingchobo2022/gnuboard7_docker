{
  "meta": {
    "is_partial": true,
    "description": "배송정책 폼 - 기본정보 섹션 (정책명, 사용여부, 기본정책)"
  },
  "id": "basic_info_section",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "children": [
    {
      "type": "basic",
      "name": "H2",
      "props": {
        "className": "card-title"
      },
      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.section_basic"
    },
    {
      "id": "basic_info_fields",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "row-stack"
      },
      "children": [
        {
          "id": "field_name",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.name"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-required"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "MultilingualInput",
                  "props": {
                    "name": "name",
                    "placeholder": "$t:sirsoft-ecommerce.admin.shipping_policy.form.name_placeholder",
                    "maxLength": 200,
                    "required": true,
                    "layout": "tabs",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.name}}",
                  "props": {
                    "className": "form-error-xs"
                  },
                  "text": "{{_local.errors?.name?.[0] ?? ''}}"
                }
              ]
            }
          ]
        },
        {
          "id": "field_row_status",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid-2col-responsive"
          },
          "children": [
            {
              "id": "field_is_active",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "label": "$t:sirsoft-ecommerce.admin.shipping_policy.form.is_active",
                        "name": "is_active",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_is_default",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "composite",
                      "name": "Toggle",
                      "props": {
                        "label": "$t:sirsoft-ecommerce.admin.shipping_policy.form.is_default",
                        "name": "is_default",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
