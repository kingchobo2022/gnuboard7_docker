{
  "meta": {
    "is_partial": true,
    "description": "배송정책 폼 - 국가별 기본 배송 설정 (배송방법, 통화, 활성화, 국가 삭제)"
  },
  "id": "country_basic_fields_section",
  "type": "basic",
  "name": "Div",
  "if": "{{_computed.activeCountrySetting}}",
  "props": {
    "className": "admin-card"
  },
  "children": [
    {
      "type": "basic",
      "name": "H2",
      "props": {
        "className": "card-title"
      },
      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.section_country_basic"
    },
    {
      "id": "country_basic_content",
      "type": "basic",
      "name": "Div",
      "props": {
      },
      "children": [
        {
          "id": "country_basic_fields",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid-2col-responsive"
          },
          "children": [
            {
              "id": "field_country_shipping_method",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.shipping_method"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-required"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Select",
                      "props": {
                        "className": "{{_local.errors?.['country_settings.' + (_local.activeCountryTab ?? 0) + '.shipping_method'] ? 'input input-error w-full' : 'input w-full'}}",
                        "value": "{{_computed.activeCountrySetting?.shipping_method ?? (ecommerce_settings?.data?.shipping?.types ?? []).find(t => t.is_active)?.code ?? 'parcel'}}",
                        "options": "{{_computed.shippingMethodOptions ?? []}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "sirsoft-ecommerce.updateCountryField",
                          "params": {
                            "field": "shipping_method",
                            "value": "{{$event.target.value}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['country_settings.' + (_local.activeCountryTab ?? 0) + '.shipping_method']}}",
                      "props": {
                        "className": "form-error-xs mt-0.5"
                      },
                      "text": "{{_local.errors?.['country_settings.' + (_local.activeCountryTab ?? 0) + '.shipping_method']?.[0]}}"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "if": "{{_computed.activeCountrySetting?.shipping_method === 'custom'}}",
                      "props": {
                        "className": ""
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "text-secondary block text-xs font-medium mb-1"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.custom_shipping_name"
                        },
                        {
                          "type": "composite",
                          "name": "MultilingualInput",
                          "props": {
                            "value": "{{_computed.activeCountrySetting?.custom_shipping_name ?? {}}}",
                            "layout": "inline",
                            "placeholder": "$t:sirsoft-ecommerce.admin.shipping_policy.form.custom_shipping_name_placeholder",
                            "error": "{{_local.errors?.['country_settings.' + (_local.activeCountryTab ?? 0) + '.custom_shipping_name.' + (_global.locale || 'ko')]?.[0] ?? ''}}",
                            "disabled": "{{_computed.isReadOnly}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "sirsoft-ecommerce.updateCountryField",
                              "params": {
                                "field": "custom_shipping_name",
                                "value": "{{$event.target.value}}"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "country_currency_fields",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid-2col-responsive"
          },
          "children": [
            {
              "id": "field_country_currency",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "form-label"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.currency_code"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-required"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "input w-full opacity-60 cursor-not-allowed flex items-center"
                      },
                      "text": "{{_computed.defaultCurrencyLabel}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "form-hint-xs mt-0.5"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.currency_code_fixed_hint"
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_country_is_active",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-end"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Toggle",
                  "props": {
                    "label": "$t:sirsoft-ecommerce.admin.shipping_policy.form.country_active",
                    "checked": "{{_computed.activeCountrySetting?.is_active ?? true}}",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "sirsoft-ecommerce.updateCountryField",
                      "params": {
                        "field": "is_active",
                        "value": "{{!(_computed.activeCountrySetting?.is_active ?? true)}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "country_remove_area",
          "type": "basic",
          "name": "Div",
          "if": "{{(_local.form?.country_settings ?? []).length > 1 && policy?.data?.abilities?.can_update === true}}",
          "props": {
            "className": "flex justify-end border-t border-gray-100 dark:border-gray-700"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "btn btn-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "trash",
                    "className": "text-xs mr-1"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.country_tab_remove"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "sirsoft-ecommerce.removeCountrySetting",
                  "confirm": "$t:sirsoft-ecommerce.admin.shipping_policy.form.country_tab_remove_confirm",
                  "params": {
                    "index": "{{_local.activeCountryTab ?? 0}}"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
