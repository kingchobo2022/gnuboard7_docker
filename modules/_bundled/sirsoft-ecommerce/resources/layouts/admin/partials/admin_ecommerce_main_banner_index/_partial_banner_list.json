{
  "meta": {
    "is_partial": true,
    "description": "Main Banner List Partial"
  },
  "id": "banner_list_section",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "admin-card"
  },
  "children": [
    {
      "id": "list_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-center gap-2 mb-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:sirsoft-ecommerce.admin.main_banner.list.title"
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "badge"
          },
          "text": "7"
        }
      ]
    },
    {
      "id": "list_tabs",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex-center gap-2 mb-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "{{_local.activeTab === 'all' ? 'btn btn-primary btn-sm' : 'btn btn-secondary btn-sm'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.main_banner.list.tabs.all"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "ml-1"
              },
              "text": "7"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "_local",
                "activeTab": "all"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "{{_local.activeTab === 'active' ? 'btn btn-primary btn-sm' : 'btn btn-secondary btn-sm'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.main_banner.list.tabs.active"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "ml-1"
              },
              "text": "4"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "_local",
                "activeTab": "active"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "{{_local.activeTab === 'inactive' ? 'btn btn-primary btn-sm' : 'btn btn-secondary btn-sm'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.main_banner.list.tabs.inactive"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "ml-1"
              },
              "text": "3"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "_local",
                "activeTab": "inactive"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "banner_list_items",
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "id": "banner_item_1",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "{{_local.selectedBannerId === 'banner_1' ? 'drag-item ring-2 ring-blue-500' : 'drag-item'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "drag-handle"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "grip-vertical",
                    "className": "w-4 h-4"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "w-16 h-10 rounded bg-gradient-to-r from-orange-400 to-red-400 flex-shrink-0"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1 min-w-0 cursor-pointer"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm font-medium text-primary truncate"
                  },
                  "text": "겨울 신상품 최대 50% 할인"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-secondary"
                  },
                  "text": "2025-01-01 ~ 2025-12-31"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "selectedBannerId": "banner_1",
                    "viewMode": "detail"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "toggle active"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "toggle-track"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "toggle-handle"
                  }
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "bannerStatus.banner_1": "{{!_local.bannerStatus.banner_1}}"
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "banner_item_2",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "{{_local.selectedBannerId === 'banner_2' ? 'drag-item ring-2 ring-blue-500' : 'drag-item'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "drag-handle"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "grip-vertical",
                    "className": "w-4 h-4"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center w-16 h-10 rounded bg-gray-200 dark:bg-gray-700 justify-center flex-shrink-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-secondary text-xl font-bold"
                  },
                  "text": "SALE"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1 min-w-0 cursor-pointer"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-sm font-medium text-primary truncate"
                      },
                      "text": "봄 맞이 새학기 준비"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "badge badge-gray text-xs flex-shrink-0"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.main_banner.list.status_ended"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-secondary"
                  },
                  "text": "2025-03-01 ~ 2025-03-31"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "selectedBannerId": "banner_2",
                    "viewMode": "detail"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "toggle"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "toggle-track"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "toggle-handle"
                  }
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "_local",
                    "bannerStatus.banner_2": "{{!_local.bannerStatus.banner_2}}"
                  }
                }
              ]
            }
          ]
        }
      ],
      "props": {
      }
    }
  ]
}
