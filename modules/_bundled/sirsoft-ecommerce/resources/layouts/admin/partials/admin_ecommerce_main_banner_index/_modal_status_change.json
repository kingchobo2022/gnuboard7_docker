{
  "meta": {
    "is_partial": true,
    "description": "Main Banner Status Change Modal"
  },
  "id": "modal_status_change",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.main_banner.modal.status_change.title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-body mb-4"
      },
      "text": "$t:sirsoft-ecommerce.admin.main_banner.modal.status_change.message"
    }
  ],
  "footer": [
    {
      "type": "basic",
      "name": "Button",
      "props": {
        "type": "button",
        "className": "btn btn-outline"
      },
      "text": "$t:sirsoft-ecommerce.admin.main_banner.modal.status_change.cancel",
      "actions": [
        {
          "type": "click",
          "handler": "closeModal"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Button",
      "props": {
        "type": "button",
        "className": "btn btn-primary"
      },
      "text": "$t:sirsoft-ecommerce.admin.main_banner.modal.status_change.confirm",
      "actions": [
        {
          "type": "click",
          "handler": "closeModal"
        }
      ]
    }
  ]
}
