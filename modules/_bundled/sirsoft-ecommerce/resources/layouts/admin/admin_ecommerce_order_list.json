{
    "version": "1.0.0",
    "layout_name": "admin_ecommerce_order_list",
    "permissions": [
        "sirsoft-ecommerce.orders.read"
    ],
    "extends": "_admin_base",
    "meta": {
        "title": "$t:sirsoft-ecommerce.admin.order.title",
        "description": "$t:sirsoft-ecommerce.admin.order.description"
    },
    "computed": {
        "filterSearchField": "{{_local.filter.searchField ?? query.search_field ?? 'all'}}",
        "filterSearchKeyword": "{{_local.filter.searchKeyword ?? query.search_keyword ?? ''}}",
        "filterDateType": "{{_local.filter.dateType ?? query.date_type ?? 'ordered_at'}}",
        "filterStartDate": "{{_local.filter.startDate ?? query.start_date ?? ''}}",
        "filterEndDate": "{{_local.filter.endDate ?? query.end_date ?? ''}}",
        "filterMinPrice": "{{_local.filter.minPrice ?? query.min_amount ?? ''}}",
        "filterMaxPrice": "{{_local.filter.maxPrice ?? query.max_amount ?? ''}}",
        "filterCategoryId": "{{_local.filter.category4 || _local.filter.category3 || _local.filter.category2 || _local.filter.category1 || query.category4 || query.category3 || query.category2 || query.category1 || ''}}",
        "category1Options": "{{[{ value: '', label: '$t:common.all' }, ...((categories?.data?.data || []).filter(c => c.depth === 0).map(c => ({ value: String(c.id), label: c.localized_name })))]}}",
        "category2Options": "{{_local.filter.category1 ? [{ value: '', label: '$t:common.all' }, ...((categories?.data?.data || []).find(c => String(c.id) === _local.filter.category1)?.children || []).map(c => ({ value: String(c.id), label: c.localized_name }))] : []}}",
        "category3Options": "{{_local.filter.category2 ? [{ value: '', label: '$t:common.all' }, ...(((categories?.data?.data || []).find(c => String(c.id) === _local.filter.category1)?.children || []).find(c => String(c.id) === _local.filter.category2)?.children || []).map(c => ({ value: String(c.id), label: c.localized_name }))] : []}}",
        "category4Options": "{{_local.filter.category3 ? [{ value: '', label: '$t:common.all' }, ...((((categories?.data?.data || []).find(c => String(c.id) === _local.filter.category1)?.children || []).find(c => String(c.id) === _local.filter.category2)?.children || []).find(c => String(c.id) === _local.filter.category3)?.children || []).map(c => ({ value: String(c.id), label: c.localized_name }))] : []}}",
        "availableCountries": "{{(ecommerce_settings?.data?.shipping?.available_countries || []).filter(c => c.is_active).map(c => ({ code: c.code.toLowerCase(), name: c.name?.[$locale] ?? c.name?.[_global.locale] ?? c.name?.ko ?? c.code }))}}",
        "availablePaymentMethods": "{{(ecommerce_settings?.data?.order_settings?.payment_methods || []).filter(m => m.is_active).map(m => ({ id: m.id, name: m._cached_name?.[$locale] ?? m._cached_name?.[_global.locale] ?? m._cached_name?.ko ?? m.id }))}}",
        "filterShippingPolicy": "{{_local.filter.shippingPolicy ?? query.shipping_policy_id ?? ''}}",
        "shippingPolicyOptions": "{{[{ value: '', label: '$t:common.all' }, ...((shipping_policies?.data || []).map(sp => ({ value: String(sp.value), label: sp.label })))]}}",
        "filterMinShippingFee": "{{_local.filter.minShippingFee ?? query.min_shipping_amount ?? ''}}",
        "filterMaxShippingFee": "{{_local.filter.maxShippingFee ?? query.max_shipping_amount ?? ''}}",
        "shippingTypeOptions": "{{(ecommerce_settings?.data?.shipping?.types ?? []).filter(t => t.is_active).map(t => ({value: t.code, label: t.name?.[$locale] ?? t.name?.[_global.locale] ?? t.name?.ko ?? t.code}))}}"
    },
    "state": {
        "showDetailFilter": false,
        "isEditMode": false,
        "filter": {
            "selectedPreset": "",
            "searchField": "all",
            "searchKeyword": "",
            "dateType": "ordered_at",
            "startDate": "",
            "endDate": "",
            "dateQuick": "",
            "orderStatus": [],
            "deliveryMethods": [],
            "paymentMethods": [],
            "category1": "",
            "category2": "",
            "category3": "",
            "category4": "",
            "minPrice": "",
            "maxPrice": "",
            "countries": [],
            "devices": [],
            "shippingPolicy": "",
            "minShippingFee": "",
            "maxShippingFee": ""
        },
        "ordererSearchResults": [],
        "selectedItems": [],
        "selectAll": false,
        "bulkOrderStatus": "",
        "bulkCourier": "",
        "bulkTrackingNumber": "",
        "sortBy": "ordered_at_desc",
        "perPage": "20",
        "currentPage": 1,
        "presetName": "",
        "editingPresetId": null,
        "editingPresetName": "",
        "deletingPresetId": null,
        "deletingPresetName": "",
        "savingPresetConditions": null,
        "excelDownloadType": "search",
        "visibleColumns": [
            "ordered_at",
            "order_number",
            "product",
            "order_amount",
            "order_status",
            "orderer",
            "payment_method",
            "delivery_method",
            "country",
            "device"
        ],
        "visibleFilters": [
            "searchField",
            "searchKeyword",
            "date",
            "orderStatus"
        ]
    },
    "transition_overlay": {
        "wait_for": [
            "orders"
        ]
    },
    "data_sources": [
        {
            "id": "orders",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.orders",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/orders",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "progressive",
            "params": {
                "page": "{{query.page || 1}}",
                "per_page": "{{query.per_page || 20}}",
                "sort_by": "{{query.sort_by || 'ordered_at'}}",
                "sort_order": "{{query.sort_order || 'desc'}}",
                "search_field": "{{query.search_field}}",
                "search_keyword": "{{query.search_keyword}}",
                "date_type": "{{query.date_type}}",
                "start_date": "{{query.start_date}}",
                "end_date": "{{query.end_date}}",
                "order_status": "{{query['order_status[]']}}",
                "shipping_type": "{{query['shipping_type[]']}}",
                "payment_method": "{{query['payment_method[]']}}",
                "category_id": "{{query.category4 || query.category3 || query.category2 || query.category1}}",
                "min_amount": "{{query.min_amount}}",
                "max_amount": "{{query.max_amount}}",
                "country_codes": "{{query['country_codes[]']}}",
                "order_device": "{{query['order_device[]']}}",
                "shipping_policy_id": "{{query.shipping_policy_id}}",
                "min_shipping_amount": "{{query.min_shipping_amount}}",
                "max_shipping_amount": "{{query.max_shipping_amount}}",
                "orderer_uuid": "{{query.orderer_uuid}}",
                "member_type": "{{query.member_type}}"
            },
            "errorHandling": {
                "403": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                },
                "default": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                }
            }
        },
        {
            "id": "categories",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.categories",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/categories",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "background",
            "params": {
                "hierarchical": "1"
            }
        },
        {
            "id": "ecommerce_settings",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.ecommerce_settings",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/settings",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "background"
        },
        {
            "id": "active_carriers",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.active_carriers",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/shipping-carriers/active",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "background"
        },
        {
            "id": "shipping_policies",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.shipping_policies",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/shipping-policies/active",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "background"
        },
        {
            "id": "presets",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.presets",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/presets",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "background",
            "params": {
                "target_screen": "orders"
            }
        }
    ],
    "init_actions": [
        {
            "handler": "loadFromLocalStorage",
            "params": {
                "key": "g7_order_visible_columns",
                "stateKey": "visibleColumns",
                "defaultValue": [
                    "order_date",
                    "order_number",
                    "order_status",
                    "order_amount",
                    "product",
                    "orderer",
                    "payment_method",
                    "delivery_method",
                    "country"
                ]
            }
        },
        {
            "handler": "setState",
            "params": {
                "target": "global",
                "_local": {
                    "filter": {
                        "searchField": "{{query.search_field || 'all'}}",
                        "searchKeyword": "{{query.search_keyword || ''}}",
                        "dateType": "{{query.date_type || 'ordered_at'}}",
                        "startDate": "{{query.start_date || ''}}",
                        "endDate": "{{query.end_date || ''}}",
                        "orderStatus": "{{query['order_status[]'] || []}}",
                        "deliveryMethods": "{{query['shipping_type[]'] || []}}",
                        "paymentMethods": "{{query['payment_method[]'] || []}}",
                        "category1": "{{query.category1 || ''}}",
                        "category2": "{{query.category2 || ''}}",
                        "category3": "{{query.category3 || ''}}",
                        "category4": "{{query.category4 || ''}}",
                        "minPrice": "{{query.min_amount || ''}}",
                        "maxPrice": "{{query.max_amount || ''}}",
                        "countries": "{{query['country_codes[]'] || []}}",
                        "devices": "{{query['order_device[]'] || []}}",
                        "shippingPolicy": "{{query.shipping_policy_id || ''}}",
                        "minShippingFee": "{{query.min_shipping_amount || ''}}",
                        "maxShippingFee": "{{query.max_shipping_amount || ''}}",
                        "selectedPreset": "{{query.preset_id || ''}}",
                        "ordererUuid": "{{query.orderer_uuid || ''}}",
                        "memberType": "{{query.member_type || ''}}"
                    }
                }
            }
        },
        {
            "handler": "apiCall",
            "if": "{{!!query.orderer_uuid}}",
            "auth_required": true,
            "target": "/api/admin/users/search",
            "params": {
                "method": "GET",
                "query": {
                    "uuid": "{{query.orderer_uuid}}"
                }
            },
            "onSuccess": [
                {
                    "handler": "setState",
                    "params": {
                        "target": "local",
                        "ordererSearchResults": "{{(response.data ?? []).map(u => ({ value: u.uuid, label: u.name, description: u.email }))}}"
                    }
                }
            ]
        },
        {
            "handler": "sirsoft-ecommerce.loadVisibleFilters",
            "params": {
                "id": "admin_ecommerce_order_filters",
                "defaultFilters": [
                    "searchField",
                    "searchKeyword",
                    "date",
                    "orderStatus"
                ]
            },
            "resultTo": {
                "target": "_local",
                "key": "visibleFilters"
            }
        }
    ],
    "named_actions": {
        "searchOrders": {
            "handler": "navigate",
            "params": {
                "path": "/admin/ecommerce/orders",
                "replace": true,
                "mergeQuery": true,
                "query": {
                    "page": 1,
                    "search_field": "{{_local.filter.searchField !== 'all' ? _local.filter.searchField : null}}",
                    "search_keyword": "{{_local.filter.searchKeyword || null}}",
                    "date_type": "{{_local.filter.dateType}}",
                    "start_date": "{{_local.filter.startDate || null}}",
                    "end_date": "{{_local.filter.endDate || null}}",
                    "order_status[]": "{{(_local.filter.orderStatus || []).length > 0 ? _local.filter.orderStatus : null}}",
                    "shipping_type[]": "{{(_local.filter.deliveryMethods || []).length > 0 ? _local.filter.deliveryMethods : null}}",
                    "payment_method[]": "{{(_local.filter.paymentMethods || []).length > 0 ? _local.filter.paymentMethods : null}}",
                    "category1": "{{_local.filter.category1 || null}}",
                    "category2": "{{_local.filter.category2 || null}}",
                    "category3": "{{_local.filter.category3 || null}}",
                    "category4": "{{_local.filter.category4 || null}}",
                    "min_amount": "{{_local.filter.minPrice || null}}",
                    "max_amount": "{{_local.filter.maxPrice || null}}",
                    "country_codes[]": "{{(_local.filter.countries || []).length > 0 ? _local.filter.countries : null}}",
                    "order_device[]": "{{(_local.filter.devices || []).length > 0 ? _local.filter.devices : null}}",
                    "shipping_policy_id": "{{_local.filter.shippingPolicy || null}}",
                    "min_shipping_amount": "{{_local.filter.minShippingFee || null}}",
                    "max_shipping_amount": "{{_local.filter.maxShippingFee || null}}",
                    "orderer_uuid": "{{_local.filter.ordererUuid || null}}",
                    "member_type": "{{_local.filter.memberType || null}}"
                },
                "transition_overlay_target": "order_datagrid__body"
            }
        }
    },
    "slots": {
        "content": [
            {
                "id": "order_list_content",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "admin-page-content"
                },
                "children": [
                    {
                        "id": "page_header",
                        "type": "basic",
                        "name": "Div",
                        "comment": "H-001 ~ H-004",
                        "props": {
                            "className": "page-header"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "flex-center gap-3"
                                },
                                "children": [
                                    {
                                        "id": "mb_001_back_button",
                                        "type": "basic",
                                        "name": "Button",
                                        "comment": "MB-001 모바일 뒤로가기 버튼",
                                        "props": {
                                            "type": "button",
                                            "className": "btn btn-ghost btn-square hidden"
                                        },
                                        "responsive": {
                                            "portable": {
                                                "props": {
                                                    "className": "btn btn-ghost btn-square flex"
                                                }
                                            }
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Icon",
                                                "props": {
                                                    "name": "arrow-left",
                                                    "className": "w-5 h-5"
                                                }
                                            }
                                        ],
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "back"
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "children": [
                                            {
                                                "id": "h_002_page_title",
                                                "type": "basic",
                                                "name": "H1",
                                                "comment": "H-002",
                                                "props": {
                                                    "className": "page-title"
                                                },
                                                "text": "$t:sirsoft-ecommerce.admin.order.title"
                                            },
                                            {
                                                "id": "h_003_page_description",
                                                "type": "basic",
                                                "name": "P",
                                                "comment": "H-003",
                                                "props": {
                                                    "className": "page-description"
                                                },
                                                "text": "$t:sirsoft-ecommerce.admin.order.description"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "page-actions"
                                },
                                "children": [
                                    {
                                        "id": "h_004_refresh_button",
                                        "type": "basic",
                                        "name": "Button",
                                        "comment": "H-004",
                                        "props": {
                                            "type": "button",
                                            "className": "btn btn-icon"
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Icon",
                                                "props": {
                                                    "name": "refresh-cw",
                                                    "className": "w-5 h-5"
                                                }
                                            }
                                        ],
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/admin/ecommerce/orders",
                                                    "mergeQuery": false
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "mobile_top_actions",
                        "type": "basic",
                        "name": "Div",
                        "comment": "MB-010, MB-011",
                        "props": {
                            "className": "hidden"
                        },
                        "responsive": {
                            "portable": {
                                "props": {
                                    "className": "flex gap-2 mb-4"
                                }
                            }
                        },
                        "children": [
                            {
                                "id": "mb_010_search_edit_button",
                                "type": "basic",
                                "name": "Button",
                                "comment": "MB-010",
                                "props": {
                                    "type": "button",
                                    "className": "btn btn-outline flex-1"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Icon",
                                        "props": {
                                            "name": "settings",
                                            "className": "w-4 h-4"
                                        }
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Span",
                                        "text": "$t:sirsoft-ecommerce.admin.order.search.edit_search"
                                    }
                                ],
                                "actions": [
                                    {
                                        "type": "click",
                                        "handler": "setState",
                                        "params": {
                                            "target": "_local",
                                            "isEditMode": "{{!_local.isEditMode}}"
                                        }
                                    }
                                ]
                            },
                            {
                                "id": "mb_011_preset_manage_button",
                                "type": "basic",
                                "name": "Button",
                                "comment": "MB-011",
                                "props": {
                                    "type": "button",
                                    "className": "btn btn-outline flex-1"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Icon",
                                        "props": {
                                            "name": "list",
                                            "className": "w-4 h-4"
                                        }
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Span",
                                        "text": "$t:sirsoft-ecommerce.admin.order.search.preset_manage"
                                    }
                                ],
                                "actions": [
                                    {
                                        "type": "click",
                                        "handler": "openModal",
                                        "target": "modal_preset_manage"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "partial": "partials/admin_ecommerce_order_list/_partial_filter_section.json"
                    },
                    {
                        "id": "data_table_section",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "mt-6"
                        },
                        "children": [
                            {
                                "partial": "partials/admin_ecommerce_order_list/_partial_bulk_action_section.json"
                            },
                            {
                                "partial": "partials/admin_ecommerce_order_list/_partial_order_datagrid.json"
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "modals": [
        {
            "partial": "partials/admin_ecommerce_order_list/_modal_bulk_confirm.json"
        },
        {
            "partial": "partials/admin_ecommerce_order_list/_modal_preset_manage.json"
        },
        {
            "partial": "partials/admin_ecommerce_order_list/_modal_preset_save.json"
        },
        {
            "partial": "partials/admin_ecommerce_order_list/_modal_preset_edit.json"
        },
        {
            "partial": "partials/admin_ecommerce_order_list/_modal_preset_delete_confirm.json"
        },
        {
            "partial": "partials/admin_ecommerce_order_list/_modal_excel_download.json"
        }
    ]
}
