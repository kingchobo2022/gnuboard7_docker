{
    "version": "1.0.0",
    "layout_name": "admin_ecommerce_shipping_policy_form",
    "permissions": [
        "sirsoft-ecommerce.shipping-policies.read"
    ],
    "extends": "_admin_base",
    "meta": {
        "title": "{{route.id ? '$t:sirsoft-ecommerce.admin.shipping_policy.title_edit' : '$t:sirsoft-ecommerce.admin.shipping_policy.title_create'}}"
    },
    "computed": {
        "availableCountries": "{{(ecommerce_settings?.data?.shipping?.available_countries ?? []).filter(c => c.is_active)}}",
        "addableCountries": "{{(ecommerce_settings?.data?.shipping?.available_countries ?? []).filter(c => c.is_active && !(_local.form?.country_settings ?? []).some(cs => cs.country_code === c.code))}}",
        "addableCountryOptions": "{{(_computed.addableCountries ?? []).map(c => ({ value: c.code, label: $localized(c.name) + ' (' + c.code + ')' }))}}",
        "shippingMethodOptions": "{{(ecommerce_settings?.data?.shipping?.types ?? []).filter(t => t.is_active).map(t => ({value: t.code, label: t.name?.[$locale] ?? t.name?.[_global.locale] ?? t.name?.ko ?? t.code}))}}",
        "chargePolicyOptions": "{{[{value: 'free', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.free')}, {value: 'fixed', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.fixed')}, {value: 'conditional_free', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.conditional_free')}, {value: 'range_amount', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.range_amount')}, {value: 'range_quantity', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.range_quantity')}, {value: 'range_weight', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.range_weight')}, {value: 'range_volume', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.range_volume')}, {value: 'range_volume_weight', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.range_volume_weight')}, {value: 'per_quantity', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.per_quantity')}, {value: 'per_weight', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.per_weight')}, {value: 'per_volume', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.per_volume')}, {value: 'per_volume_weight', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.per_volume_weight')}, {value: 'per_amount', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.per_amount')}, {value: 'api', label: $t('sirsoft-ecommerce.admin.shipping_policy.enums.charge_policy.api')}]}}",
        "currencyOptions": "{{(ecommerce_settings?.data?.language_currency?.currencies ?? []).map(c => ({ value: c.code, label: $localized(c.name) }))}}",
        "defaultCurrencyCode": "{{ecommerce_settings?.data?.language_currency?.default_currency ?? 'KRW'}}",
        "defaultCurrencyLabel": "{{(() => { const code = ecommerce_settings?.data?.language_currency?.default_currency ?? 'KRW'; const match = (ecommerce_settings?.data?.language_currency?.currencies ?? []).find(c => c.code === code); const name = match ? $localized(match.name) : ''; if (!name) return code; return name.includes(code) ? name : name + ' (' + code + ')'; })()}}",
        "apiRequestFieldOptions": "{{ecommerce_settings?.data?.shipping?.api_request_fields ?? []}}",
        "apiHttpMethodOptions": "{{ecommerce_settings?.data?.shipping?.api_http_methods ?? []}}",
        "apiAuthTypeOptions": "{{ecommerce_settings?.data?.shipping?.api_auth_types ?? []}}",
        "apiResponseTypeOptions": "{{ecommerce_settings?.data?.shipping?.api_response_types ?? []}}",
        "activeCountrySetting": "{{(_local.form?.country_settings ?? [])[_local.activeCountryTab ?? 0]}}",
        "activeCountryCode": "{{(_local.form?.country_settings ?? [])[_local.activeCountryTab ?? 0]?.country_code ?? ''}}",
        "isReadOnly": "{{!!route.id && policy?.data?.abilities?.can_update !== true}}"
    },
    "state": {
        "form": {
            "name": [],
            "is_active": true,
            "is_default": false,
            "country_settings": []
        },
        "activeCountryTab": 0,
        "isSaving": false,
        "errors": null,
        "rangeErrors": [],
        "showBaseFee": true,
        "showFreeThreshold": false,
        "showRanges": false,
        "showApiSettings": false,
        "showUnitValue": false,
        "templateSearch": "",
        "selectedTemplateIds": [],
        "editingTemplate": null,
        "templateForm": {
            "zipcode": "",
            "fee": 3000,
            "region": "",
            "description": ""
        },
        "templateFormErrors": []
    },
    "transition_overlay": {
        "wait_for": [
            "extra_fee_templates"
        ]
    },
    "data_sources": [
        {
            "id": "policy",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.policy",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/shipping-policies/{{route.id}}",
            "method": "GET",
            "if": "{{!!route.id}}",
            "initLocal": "form",
            "refetchOnMount": true,
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "blocking",
            "errorHandling": {
                "403": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                },
                "404": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                },
                "default": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                }
            },
            "errorCondition": {
                "if": "{{response?.data?.abilities?.can_update !== true}}",
                "errorCode": 403
            }
        },
        {
            "id": "copy_source",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.copy_source",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/shipping-policies/{{query.copy_id}}",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "if": "{{!!query?.copy_id && !route?.id}}",
            "initLocal": "form",
            "loading_strategy": "blocking",
            "fallback": {
                "data": null
            }
        },
        {
            "id": "ecommerce_settings",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.ecommerce_settings",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/settings",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "blocking"
        },
        {
            "id": "extra_fee_templates",
            "label_key": "$t:sirsoft-ecommerce.editor.data_source.extra_fee_templates",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/admin/extra-fee-templates",
            "method": "GET",
            "auto_fetch": false,
            "auth_required": true,
            "loading_strategy": "progressive",
            "params": {
                "search": "{{_local.templateSearch ?? ''}}",
                "per_page": 20
            }
        }
    ],
    "init_actions": [
        {
            "handler": "setState",
            "params": {
                "target": "global",
                "isTemplateSaving": false,
                "isTemplateDeleting": false,
                "infiniteScroll": "{{({ currentPage: 1, hasMore: true, isLoadingMore: false })}}"
            }
        },
        {
            "handler": "sirsoft-ecommerce.initShippingPolicyForm",
            "params": {
                "isEdit": "{{!!route.id}}",
                "isCopy": "{{!!query?.copy_id && !route?.id}}",
                "policy": "{{route.id ? policy?.data : copy_source?.data}}",
                "availableCountries": "{{_computed.availableCountries}}"
            }
        },
        {
            "if": "{{!!query?.copy_id && !route?.id}}",
            "handler": "setState",
            "params": {
                "target": "local",
                "form.is_default": false
            }
        }
    ],
    "modals": [
        {
            "partial": "partials/admin_ecommerce_shipping_policy_form/_modal_extra_fee_template.json"
        }
    ],
    "slots": {
        "content": [
            {
                "id": "shipping_policy_form_container",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "admin-page-content"
                },
                "children": [
                    {
                        "id": "page_header",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "page-header"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Div",
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "H1",
                                        "props": {
                                            "className": "page-title"
                                        },
                                        "text": "{{route.id ? '$t:sirsoft-ecommerce.admin.shipping_policy.title_edit' : '$t:sirsoft-ecommerce.admin.shipping_policy.title_create'}}"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "props": {
                                            "className": "page-description"
                                        },
                                        "text": "$t:sirsoft-ecommerce.admin.shipping_policy.form.description"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "validation_error_banner",
                        "type": "basic",
                        "name": "Div",
                        "if": "{{_local.errors}}",
                        "props": {
                            "className": "alert-danger"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Icon",
                                "props": {
                                    "name": "triangle-exclamation",
                                    "className": "text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5",
                                    "size": "md"
                                }
                            },
                            {
                                "type": "basic",
                                "name": "Div",
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "H3",
                                        "props": {
                                            "className": "text-error-strong"
                                        },
                                        "text": "$t:sirsoft-ecommerce.common.validation_error"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Ul",
                                        "if": "{{typeof _local.errors === 'object'}}",
                                        "props": {
                                            "className": "mt-2 list-disc list-inside space-y-1"
                                        },
                                        "iteration": {
                                            "source": "Object.entries(_local.errors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                                            "item_var": "message"
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Li",
                                                "props": {
                                                    "className": "text-error-soft"
                                                },
                                                "text": "{{message}}"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "form_sections",
                        "type": "basic",
                        "name": "Div",
                        "dataKey": "form",
                        "debounce": 300,
                        "props": {
                            "className": "row-stack"
                        },
                        "children": [
                            {
                                "partial": "partials/admin_ecommerce_shipping_policy_form/_partial_basic_info.json"
                            },
                            {
                                "id": "country_settings_wrapper",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "row-stack"
                                },
                                "children": [
                                    {
                                        "partial": "partials/admin_ecommerce_shipping_policy_form/_partial_country_tabs.json"
                                    },
                                    {
                                        "partial": "partials/admin_ecommerce_shipping_policy_form/_partial_country_basic_fields.json"
                                    },
                                    {
                                        "partial": "partials/admin_ecommerce_shipping_policy_form/_partial_charge_settings.json"
                                    },
                                    {
                                        "partial": "partials/admin_ecommerce_shipping_policy_form/_partial_extra_fee.json"
                                    }
                                ]
                            },
                            {
                                "id": "footer_buttons",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "sticky-footer-buttons-between"
                                },
                                "children": [
                                    {
                                        "id": "footer_list_button",
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "className": "flex-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors"
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "text": "$t:common.list"
                                            }
                                        ],
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "navigate",
                                                "params": {
                                                    "path": "/admin/ecommerce/shipping-policies"
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "id": "footer_save_button",
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "disabled": "{{_local.isSaving || (route.id && policy?.data?.abilities?.can_update !== true)}}",
                                            "className": "btn btn-primary flex-center gap-1.5"
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Icon",
                                                "if": "{{_local.isSaving}}",
                                                "props": {
                                                    "name": "spinner",
                                                    "className": "spinner-sm"
                                                }
                                            },
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "if": "{{!_local.isSaving}}",
                                                "text": "$t:sirsoft-ecommerce.common.save"
                                            },
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "if": "{{_local.isSaving}}",
                                                "text": "$t:sirsoft-ecommerce.common.saving"
                                            }
                                        ],
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "sequence",
                                                "params": {
                                                    "actions": [
                                                        {
                                                            "handler": "setState",
                                                            "params": {
                                                                "target": "local",
                                                                "isSaving": true,
                                                                "errors": null
                                                            }
                                                        },
                                                        {
                                                            "handler": "apiCall",
                                                            "auth_required": true,
                                                            "target": "{{route.id ? '/api/modules/sirsoft-ecommerce/admin/shipping-policies/' + route.id : '/api/modules/sirsoft-ecommerce/admin/shipping-policies'}}",
                                                            "params": {
                                                                "method": "{{route.id ? 'PUT' : 'POST'}}",
                                                                "body": "{{_local.form}}"
                                                            },
                                                            "onSuccess": [
                                                                {
                                                                    "handler": "setState",
                                                                    "params": {
                                                                        "target": "local",
                                                                        "isSaving": false
                                                                    }
                                                                },
                                                                {
                                                                    "handler": "toast",
                                                                    "params": {
                                                                        "type": "success",
                                                                        "message": "{{route.id ? '$t:sirsoft-ecommerce.admin.shipping_policy.messages.updated' : '$t:sirsoft-ecommerce.admin.shipping_policy.messages.created'}}"
                                                                    }
                                                                },
                                                                {
                                                                    "handler": "navigate",
                                                                    "params": {
                                                                        "path": "/admin/ecommerce/shipping-policies"
                                                                    }
                                                                }
                                                            ],
                                                            "onError": [
                                                                {
                                                                    "handler": "setState",
                                                                    "params": {
                                                                        "target": "local",
                                                                        "isSaving": false,
                                                                        "errors": "{{error.errors}}"
                                                                    }
                                                                },
                                                                {
                                                                    "handler": "toast",
                                                                    "params": {
                                                                        "type": "error",
                                                                        "message": "{{error.message || '$t:common.validation_error'}}"
                                                                    }
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
