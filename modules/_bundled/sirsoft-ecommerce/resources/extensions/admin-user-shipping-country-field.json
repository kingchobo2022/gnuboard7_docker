{
  "target_layout": "admin_user_form",
  "injections": [
    {
      "target_id": "extension_form_content",
      "position": "append_child",
      "components": [
        {
          "id": "ext_user_shipping_country",
          "comment": "회원 배송국가 설정 (MP08 후속 — 편집 모드 + 이커머스 설치 + 해외배송 활성 시에만)",
          "type": "basic",
          "name": "Div",
          "if": "{{route?.id && user?.data?.ecommerce_preferred_shipping_country !== undefined && _global.modules?.['sirsoft-ecommerce']?.shipping?.international_shipping_enabled === true}}",
          "props": {
            "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mt-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-center justify-between mb-4" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex items-center gap-2" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": { "name": "earth-asia", "size": "md", "className": "text-gray-600 dark:text-gray-400" }
                    },
                    {
                      "type": "basic",
                      "name": "H3",
                      "props": { "className": "text-lg font-semibold text-gray-900 dark:text-white" },
                      "text": "$t:sirsoft-ecommerce.admin.user_shipping_country.title"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "ExtensionBadge",
                  "props": {
                    "type": "module",
                    "identifier": "sirsoft-ecommerce",
                    "installedModules": "{{_global.installedModules}}"
                  }
                }
              ]
            },
            {
              "comment": "배송국가 Select — name 바인딩으로 회원정보 폼(dataKey=form)에 자동 포함. 별도 저장버튼 없음: 화면 하단 회원정보 [저장] 시 함께 저장된다.",
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-end gap-3" },
              "children": [
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "ecommerce_preferred_shipping_country",
                    "value": "{{_local.form?.ecommerce_preferred_shipping_country ?? user?.data?.ecommerce_preferred_shipping_country ?? _global.modules?.['sirsoft-ecommerce']?.shipping?.default_country ?? 'KR'}}",
                    "options": "{{(_global.modules?.['sirsoft-ecommerce']?.shipping?.available_countries ?? []).filter(c => c.is_active).map(c => ({ value: c.code, label: ($localized(c.name, 'sirsoft-ecommerce::settings.countries.' + (c.code ?? '') + '.name') || c.code) }))}}",
                    "className": "w-full sm:w-64"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "P",
              "props": { "className": "text-xs text-gray-500 dark:text-gray-400 mt-2" },
              "text": "$t:sirsoft-ecommerce.admin.user_shipping_country.description"
            }
          ]
        }
      ]
    }
  ],
  "priority": 331
}
