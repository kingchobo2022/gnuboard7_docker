{
  "target_layout": "admin_user_form",
  "injections": [
    {
      "target_id": "extension_form_content",
      "position": "append_child",
      "components": [
        {
          "id": "ext_user_currency",
          "comment": "회원 결제 통화 설정 (A3 — 편집 모드 + 이커머스 설치 시에만)",
          "type": "basic",
          "name": "Div",
          "if": "{{route?.id && user?.data?.ecommerce_preferred_currency !== undefined}}",
          "props": {
            "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mt-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-center justify-between mb-4" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex items-center gap-2" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": { "name": "coins", "size": "md", "className": "text-gray-600 dark:text-gray-400" }
                    },
                    {
                      "type": "basic",
                      "name": "H3",
                      "props": { "className": "text-lg font-semibold text-gray-900 dark:text-white" },
                      "text": "$t:sirsoft-ecommerce.admin.user_currency.title"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "ExtensionBadge",
                  "props": {
                    "type": "module",
                    "identifier": "sirsoft-ecommerce",
                    "installedModules": "{{_global.installedModules}}"
                  }
                }
              ]
            },
            {
              "comment": "통화 Select — name 바인딩으로 회원정보 폼(dataKey=form)에 자동 포함. 별도 저장버튼 없음(D9): 화면 하단 회원정보 [저장] 시 함께 저장된다. 저장 체인은 admin_user_form.json 의 footer 저장 onSuccess 가 담당.",
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-end gap-3" },
              "children": [
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "ecommerce_preferred_currency",
                    "value": "{{_local.form?.ecommerce_preferred_currency ?? user?.data?.ecommerce_preferred_currency ?? _global.modules?.['sirsoft-ecommerce']?.language_currency?.default_currency ?? 'KRW'}}",
                    "options": "{{(_global.modules?.['sirsoft-ecommerce']?.language_currency?.currencies ?? []).filter(c => c.is_default || (c.exchange_rate ?? 0) > 0).map(c => ({ value: c.code, label: c.code + ' (' + (c.symbol ?? c.code) + ')' }))}}",
                    "className": "w-full sm:w-64"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "P",
              "props": { "className": "text-xs text-gray-500 dark:text-gray-400 mt-2" },
              "text": "$t:sirsoft-ecommerce.admin.user_currency.description"
            }
          ]
        }
      ]
    }
  ],
  "priority": 330
}
