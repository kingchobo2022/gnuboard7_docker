{
  "version": "1.0.0",
  "layout_name": "admin_ecommerce_common_info_view",
  "meta": {
    "is_partial": true,
    "description": "Common Info View Panel - Read-only Details with Language Tabs"
  },
  "initLocal": {
    "viewLocale": "ko"
  },
  "initGlobal": {
    "selectedId": 1,
    "panelMode": "view",
    "selectedItem": {
      "id": 1,
      "name": {
        "ko": "일반 상품 안내",
        "en": "General Product Info"
      },
      "content": {
        "ko": "이 상품은 품질 보증이 됩니다.",
        "en": "This product is quality guaranteed."
      },
      "content_mode": "text",
      "is_default": true,
      "is_active": true,
      "created_at": "2026-01-15T10:00:00Z",
      "updated_at": "2026-01-20T14:30:00Z"
    }
  },
  "components": [
    {
      "id": "view_panel",
      "type": "basic",
      "name": "Div",
      "if": "{{_global.selectedId && _global.panelMode === 'view'}}",
      "children": [
        {
          "id": "view_header",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "px-4 panel-header"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "text-heading"
              },
              "text": "공통정보 정보"
            }
          ]
        },
        {
          "id": "view_content",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "p-4"
          },
          "children": [
            {
              "id": "info_name_display",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "mb-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-tertiary mb-1"
                  },
                  "text": "공통정보명"
                },
                {
                  "type": "basic",
                  "name": "H2",
                  "props": {
                    "className": "section-heading"
                  },
                  "text": "{{$localized(_global.selectedItem?.name)}}"
                }
              ]
            },
            {
              "id": "status_badges",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-2 mb-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-tertiary mr-2"
                  },
                  "text": "상태"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_global.selectedItem?.is_default}}",
                  "props": {
                    "className": "px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400",
                    "data-testid": "badge-default"
                  },
                  "text": "기본"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_global.selectedItem?.is_active}}",
                  "props": {
                    "className": "px-2 py-0.5 text-xs bg-green-100 dark:bg-green-900/20 text-green-600 dark:text-green-400 rounded",
                    "data-testid": "badge-active"
                  },
                  "text": "사용"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{!_global.selectedItem?.is_active}}",
                  "props": {
                    "className": "px-2 py-0.5 text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded",
                    "data-testid": "badge-inactive"
                  },
                  "text": "미사용"
                }
              ]
            },
            {
              "id": "content_section",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "border-t border-gray-200 dark:border-gray-700 pt-4"
              },
              "children": [
                {
                  "id": "language_tabs",
                  "type": "composite",
                  "name": "TabNavigation",
                  "props": {
                    "tabs": [
                      {
                        "id": "ko",
                        "label": "한국어"
                      },
                      {
                        "id": "en",
                        "label": "English"
                      }
                    ],
                    "activeTabId": "{{_local.viewLocale ?? 'ko'}}",
                    "variant": "underline",
                    "className": "mb-4"
                  },
                  "actions": [
                    {
                      "event": "onTabChange",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "viewLocale": "{{$args[0]}}"
                      }
                    }
                  ]
                },
                {
                  "id": "content_display_ko",
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_local.viewLocale === 'ko'}}",
                  "props": {
                    "className": "p-4 bg-gray-50 dark:bg-gray-900 rounded-lg min-h-[200px]",
                    "data-testid": "content-ko"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-body whitespace-pre-wrap"
                      },
                      "text": "{{_global.selectedItem?.content?.ko ?? '-'}}"
                    }
                  ]
                },
                {
                  "id": "content_display_en",
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_local.viewLocale === 'en'}}",
                  "props": {
                    "className": "p-4 bg-gray-50 dark:bg-gray-900 rounded-lg min-h-[200px]",
                    "data-testid": "content-en"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-body whitespace-pre-wrap"
                      },
                      "text": "{{_global.selectedItem?.content?.en ?? '-'}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
