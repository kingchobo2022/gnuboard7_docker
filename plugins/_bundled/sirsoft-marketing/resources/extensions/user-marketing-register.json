{
  "target_layout": "auth/register",
  "data_sources": [
    {
      "id": "marketing_settings",
      "label_key": "$t:sirsoft-marketing.editor.data_source.marketing_settings",
      "type": "api",
      "endpoint": "/api/plugins/sirsoft-marketing/settings",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": false
    }
  ],
  "injections": [
    {
      "target_id": "register_privacy_agreement",
      "position": "append",
      "components": [
        {
          "id": "register_marketing_consent_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "if": "{{marketing_settings?.data?.marketing_consent_enabled === true}}",
              "props": {
                "className": "flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-center gap-2 flex-1 cursor-pointer text-sm text-gray-700 dark:text-gray-300"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Checkbox",
                      "props": {
                        "name": "agree_marketing_consent",
                        "disabled": "{{_local?.isRegistering}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "sequence",
                          "actions": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "registerForm": "{{Object.assign({}, _local.registerForm, { agree_marketing_consent: $event.target.checked }, Object.fromEntries((marketing_settings?.data?.channels ?? []).map(ch => ['agree_' + ch.key, $event.target.checked ? true : false])))}}"
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-marketing.agree_marketing_consent"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "if": "{{marketing_settings?.data?.marketing_consent_terms_slug_set === true}}",
                  "props": {
                    "type": "button",
                    "className": "text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 underline flex-shrink-0"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "marketingTermsModalType": "marketing_consent",
                            "marketingTermsPageData": null,
                            "marketingTermsLoading": true
                          }
                        },
                        {
                          "handler": "openModal",
                          "target": "marketing_terms_modal"
                        },
                        {
                          "handler": "apiCall",
                          "target": "/api/modules/sirsoft-page/pages/{{marketing_settings?.data?.marketing_consent_terms_slug}}",
                          "auth_mode": "optional",
                          "params": {
                            "method": "GET"
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsPageData": "{{response.data}}",
                                "marketingTermsLoading": false
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsLoading": false
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-marketing.view_terms"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{marketing_settings?.data?.marketing_consent_enabled === true}}",
              "iteration": {
                "source": "marketing_settings?.data?.channels ?? []",
                "item_var": "channel"
              },
              "props": {
                "className": "flex items-center gap-2 ml-8"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-center gap-2 flex-1 cursor-pointer text-sm text-gray-700 dark:text-gray-300"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Checkbox",
                      "props": {
                        "name": "agree_{{channel.key}}",
                        "disabled": "{{_local?.isRegistering}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "registerForm": "{{Object.assign({}, _local.registerForm, $event.target.checked ? { ['agree_' + channel.key]: true, agree_marketing_consent: true } : { ['agree_' + channel.key]: false })}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{$get(channel.label_i18n, _global.locale, channel.label)}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "if": "{{channel.terms_slug_set === true}}",
                  "props": {
                    "type": "button",
                    "className": "text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 underline flex-shrink-0"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "marketingTermsModalType": "{{channel.key}}",
                            "marketingTermsPageData": null,
                            "marketingTermsLoading": true
                          }
                        },
                        {
                          "handler": "openModal",
                          "target": "marketing_terms_modal"
                        },
                        {
                          "handler": "apiCall",
                          "target": "/api/modules/sirsoft-page/pages/{{channel.terms_slug}}",
                          "auth_mode": "optional",
                          "params": {
                            "method": "GET"
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsPageData": "{{response.data}}",
                                "marketingTermsLoading": false
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsLoading": false
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-marketing.view_terms"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{marketing_settings?.data?.third_party_consent_enabled === true}}",
              "props": {
                "className": "flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-center gap-2 flex-1 cursor-pointer text-sm text-gray-700 dark:text-gray-300"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Checkbox",
                      "props": {
                        "name": "agree_third_party_consent",
                        "disabled": "{{_local?.isRegistering}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "registerForm": "{{Object.assign({}, _local.registerForm, { agree_third_party_consent: $event.target.checked })}}"
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-marketing.agree_third_party_consent"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "if": "{{marketing_settings?.data?.third_party_consent_terms_slug_set === true}}",
                  "props": {
                    "type": "button",
                    "className": "text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 underline flex-shrink-0"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "marketingTermsModalType": "third_party_consent",
                            "marketingTermsPageData": null,
                            "marketingTermsLoading": true
                          }
                        },
                        {
                          "handler": "openModal",
                          "target": "marketing_terms_modal"
                        },
                        {
                          "handler": "apiCall",
                          "target": "/api/modules/sirsoft-page/pages/{{marketing_settings?.data?.third_party_consent_terms_slug}}",
                          "auth_mode": "optional",
                          "params": {
                            "method": "GET"
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsPageData": "{{response.data}}",
                                "marketingTermsLoading": false
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsLoading": false
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-marketing.view_terms"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{marketing_settings?.data?.info_disclosure_enabled === true}}",
              "props": {
                "className": "space-y-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "flex items-center gap-2 flex-1 cursor-pointer text-sm text-gray-700 dark:text-gray-300"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Checkbox",
                          "props": {
                            "name": "agree_info_disclosure",
                            "disabled": "{{_local?.isRegistering}}"
                          },
                          "actions": [
                            {
                              "type": "change",
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "registerForm": "{{Object.assign({}, _local.registerForm, { agree_info_disclosure: $event.target.checked })}}"
                              }
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-marketing.agree_info_disclosure"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "if": "{{marketing_settings?.data?.info_disclosure_terms_slug_set === true}}",
                      "props": {
                        "type": "button",
                        "className": "text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 underline flex-shrink-0"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "sequence",
                          "actions": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "marketingTermsModalType": "info_disclosure",
                                "marketingTermsPageData": null,
                                "marketingTermsLoading": true
                              }
                            },
                            {
                              "handler": "openModal",
                              "target": "marketing_terms_modal"
                            },
                            {
                              "handler": "apiCall",
                              "target": "/api/modules/sirsoft-page/pages/{{marketing_settings?.data?.info_disclosure_terms_slug}}",
                              "auth_mode": "optional",
                              "params": {
                                "method": "GET"
                              },
                              "onSuccess": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "global",
                                    "marketingTermsPageData": "{{response.data}}",
                                    "marketingTermsLoading": false
                                  }
                                }
                              ],
                              "onError": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "global",
                                    "marketingTermsLoading": false
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-marketing.view_terms"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "block text-xs text-gray-400 dark:text-gray-500 ml-8"
                  },
                  "text": "$t:sirsoft-marketing.info_disclosure_warning"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "modals": [
    {
      "id": "marketing_terms_modal",
      "type": "composite",
      "name": "Modal",
      "props": {
        "title": {
          "$switch": "{{_global.marketingTermsModalType}}",
          "$cases": {
            "marketing_consent": "$t:sirsoft-marketing.terms_modal_marketing_consent",
            "email_subscription": "$t:sirsoft-marketing.terms_modal_email_subscription",
            "third_party_consent": "$t:sirsoft-marketing.terms_modal_third_party_consent",
            "info_disclosure": "$t:sirsoft-marketing.terms_modal_info_disclosure"
          },
          "$default": "{{_global.marketingTermsModalType ?? ''}}"
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex flex-col"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_global.marketingTermsLoading}}",
              "props": {
                "className": "flex justify-center items-center py-12"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "circle-notch",
                    "className": "text-blue-600 animate-spin text-3xl"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_global.marketingTermsPageData?.published_at}}",
              "props": {
                "className": "flex-shrink-0 flex items-center gap-2 mb-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-marketing.terms_published_at: {{_global.marketingTermsPageData?.published_at | date}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_global.marketingTermsPageData}}",
              "props": {
                "className": "flex-1 overflow-y-auto min-h-0 max-h-96"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "HtmlContent",
                  "props": {
                    "content": "{{_global.marketingTermsPageData?.content ?? ''}}",
                    "isHtml": "{{(_global.marketingTermsPageData?.content_mode ?? 'html') === 'html'}}",
                    "className": "prose dark:prose-invert prose-sm max-w-none text-gray-700 dark:text-gray-300"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{!_global.marketingTermsLoading && !_global.marketingTermsPageData}}",
              "props": {
                "className": "py-8 text-center text-gray-500 dark:text-gray-400"
              },
              "text": "$t:sirsoft-marketing.no_terms_content"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-shrink-0 flex justify-end gap-3 mt-4 pt-4 border-t border-gray-200 dark:border-gray-700"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "closeModal"
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:common.close"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "priority": 100
}
