# 시나리오 매니페스트 예시 (실제 적용 아님 — .yaml.example 확장자)
# 실제 매니페스트로 채택할 때 .yaml 로 이름 변경 + test_files 의 실재 경로 매핑

feature: order_payment_pg_kginicis
description: KG 이니시스 표준결제창을 통한 주문 결제 흐름 (회원/비회원, 결제 수단, 가상계좌, 에스크로, 일본결제 등)

test_files:
  - plugins/_bundled/sirsoft-pay_kginicis/tests/Feature/Payment/InicisAuthCallbackTest.php
  - plugins/_bundled/sirsoft-pay_kginicis/tests/Feature/Payment/VbankNotifyTest.php
  - plugins/_bundled/sirsoft-pay_kginicis/tests/Feature/Payment/EscrowNotifyTest.php
  - plugins/_bundled/sirsoft-pay_kginicis/tests/Feature/Payment/CancelTest.php

coverage_strategy: pairwise

axes:
  user_type: [member, guest]
  payment_method: [card, bank_transfer, virtual_account, mobile]
  is_test_mode: [true, false]
  is_japan: [true, false]   # CBT(일본결제) 분기
  use_escrow: [true, false]
  device: [pc, mobile]
  product_options: [single, multi_option, bundle]
  shipping_region: [domestic, jeju, remote_island]
  shipping_policy: [free, fixed, range_based, conditional_free]
  coupon_applied: [none, product, category, all]
  rounding_unit: [1, 10, 100]

exclusions:
  - { is_japan: true, use_escrow: true, reason: "일본결제는 에스크로 미지원" }
  - { payment_method: virtual_account, is_japan: true, reason: "일본결제는 가상계좌 미지원" }

effects:
  - auth_callback_received
  - signature_verified
  - server_authorize_called
  - payment_completed              # card / mobile / bank_transfer
  - vbank_issued                   # virtual_account 1단계
  - vbank_notification_received    # virtual_account 2단계
  - vbank_deposit_completed        # resultCode 0000 입금완료
  - escrow_notification_received   # use_escrow=true
  - notification_sent_to_user
  - notification_amount_matches_total
  - vat_calculated
  - tax_free_amount_split
  - coupon_marked_used
  - inventory_decremented
  - order_status_transitioned_to_paid

sub_flows:
  - id: partial_cancel
    description: 부분 취소 (type=partialRefund)
    effects:
      - before_cancel_hook_invoked
      - cancel_api_called
      - after_cancel_hook_invoked
      - shipping_policy_recalculated
      - mileage_partial_refunded

  - id: full_cancel
    description: 전체 취소 (type=refund)
    effects:
      - before_cancel_hook_invoked
      - payment_voided
      - after_cancel_hook_invoked
      - mileage_fully_refunded
      - coupon_unused
      - inventory_restored
      - order_status_transitioned_to_cancelled

  - id: cash_receipt_issue
    description: 별도 현금영수증 발행 (어드민)
    effects:
      - admin_endpoint_called
      - issue_number_validated
      - cash_receipt_api_called
      - receipt_url_stored

  - id: escrow_buyer_confirm
    description: 에스크로 구매결정
    effects:
      - user_confirm_page_loaded
      - escrow_confirm_api_called
      - settlement_triggered

notes: |
  이 매니페스트는 예시이며 실제 채택 시 다음을 갱신하세요:
   1. test_files 경로
   2. axes 값 목록 (특히 일본결제 CBT, 에스크로 분기 검증 필요)
   3. effects 명명 (테스트 docblock @effects 와 1:1 매칭)
   4. before_cancel / after_cancel 훅: sirsoft-pay_kginicis.payment.before_cancel / after_cancel
